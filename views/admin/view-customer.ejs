<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Customer Details - Kharidlow</title>
    <link rel="icon" type="image/x-icon" href="/assets/Kharidlow.ico">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
    <link
        href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&family=DM+Mono:wght@400;500&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="/styles/adminPage.css">
    <style>
        /* ── Page-specific only ── */

        .page-grid {
            display: grid;
            grid-template-columns: 280px 1fr;
            gap: 20px;
            align-items: start;
        }

        /* ── Shared card ── */
        .view-card {
            background: var(--bg3);
            border: 1px solid var(--border);
            border-radius: 14px;
            overflow: hidden;
        }

        .view-card-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 15px 20px;
            border-bottom: 1px solid var(--border);
            gap: 12px;
        }

        .view-card-head h3 {
            font-size: 13.5px;
            font-weight: 600;
            color: var(--text-primary);
            display: flex;
            align-items: center;
            gap: 8px;
            margin: 0;
        }

        .view-card-head h3 i {
            color: var(--accent2);
            font-size: 13px;
        }

        .view-card-body {
            padding: 20px;
        }

        /* ── Profile card ── */
        .profile-top {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 10px;
            padding-bottom: 16px;
            border-bottom: 1px solid var(--border);
            margin-bottom: 14px;
            text-align: center;
        }

        .profile-avatar {
            width: 56px;
            height: 56px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--accent), var(--accent2));
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            font-weight: 600;
            color: #fff;
            flex-shrink: 0;
        }

        .profile-name {
            font-size: 15px;
            font-weight: 600;
            color: var(--text-primary);
        }

        .profile-email {
            font-size: 12px;
            color: var(--text-muted);
            word-break: break-all;
            margin-top: 2px;
        }

        /* ── Info rows ── */
        .info-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 9px 0;
            border-bottom: 1px solid var(--border);
            gap: 12px;
        }

        .info-row:last-child {
            border-bottom: none;
            padding-bottom: 0;
        }

        .info-row:first-child {
            padding-top: 0;
        }

        .info-label {
            font-size: 11px;
            font-weight: 500;
            color: var(--text-muted);
            letter-spacing: 0.3px;
            text-transform: uppercase;
            flex-shrink: 0;
        }

        .info-value {
            font-size: 13px;
            color: var(--text-primary);
            text-align: right;
        }

        .info-value.mono {
            font-family: 'DM Mono', monospace;
        }

        /* ── Address chips ── */
        .address-section {
            margin-top: 14px;
            padding-top: 14px;
            border-top: 1px solid var(--border);
        }

        .address-section-label {
            font-size: 10.5px;
            font-weight: 600;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.8px;
            margin-bottom: 8px;
        }

        .address-chips {
            display: flex;
            flex-direction: column;
            gap: 7px;
        }

        .address-chip {
            display: flex;
            align-items: flex-start;
            gap: 8px;
            background: var(--bg4);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 9px 11px;
            font-size: 12px;
            color: var(--text-secondary);
            line-height: 1.5;
        }

        .address-chip i {
            color: var(--accent2);
            font-size: 11px;
            margin-top: 3px;
            flex-shrink: 0;
        }

        .address-chip strong {
            display: block;
            font-size: 10.5px;
            color: var(--accent2);
            text-transform: uppercase;
            letter-spacing: 0.4px;
            margin-bottom: 2px;
        }

        /* ── Back button ── */
        .back-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 10px 18px;
            border-radius: 10px;
            margin-top: 12px;
            background: var(--bg4);
            border: 1px solid var(--border);
            color: var(--text-secondary);
            font-size: 13px;
            font-weight: 500;
            font-family: 'DM Sans', sans-serif;
            text-decoration: none;
            transition: all 0.15s;
            width: 100%;
        }

        .back-btn:hover {
            border-color: var(--border-hover);
            color: var(--text-primary);
        }

        /* ── Right column ── */
        .right-col {
            display: flex;
            flex-direction: column;
            gap: 16px;
            min-width: 0;
        }

        /* Stat bar */
        .stat-bar {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 12px;
        }

        .stat-mini {
            background: var(--bg3);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 14px 16px;
            display: flex;
            flex-direction: column;
            gap: 4px;
            min-width: 0;
        }

        .stat-mini-label {
            font-size: 11px;
            color: var(--text-muted);
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 0.3px;
        }

        .stat-mini-value {
            font-size: 22px;
            font-weight: 600;
            font-family: 'DM Mono', monospace;
        }

        .stat-mini-value.accent {
            color: var(--accent2);
        }

        .stat-mini-value.success {
            color: var(--success);
        }

        .stat-mini-value.warning {
            color: var(--warning);
        }

        /* ── Orders table ── */
        .table-wrap {
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            min-width: 360px;
        }

        thead th {
            background: var(--bg4);
            padding: 10px 16px;
            text-align: left;
            font-size: 11px;
            font-weight: 600;
            color: var(--text-muted);
            letter-spacing: 0.6px;
            text-transform: uppercase;
            white-space: nowrap;
        }

        tbody tr {
            border-bottom: 1px solid var(--border);
            transition: background 0.12s;
        }

        tbody tr:last-child {
            border-bottom: none;
        }

        tbody tr:hover {
            background: rgba(255, 255, 255, 0.025);
        }

        tbody td {
            padding: 12px 16px;
            font-size: 13px;
            color: var(--text-primary);
            white-space: nowrap;
        }

        .order-id {
            font-family: 'DM Mono', monospace;
            font-size: 12px;
            color: var(--accent2);
        }

        /* Badges */
        .badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600;
        }

        .badge::before {
            content: '';
            width: 5px;
            height: 5px;
            border-radius: 50%;
            display: inline-block;
            flex-shrink: 0;
        }

        .badge-warning {
            background: rgba(251, 191, 36, 0.12);
            color: var(--warning);
        }

        .badge-warning::before {
            background: var(--warning);
        }

        .badge-success {
            background: rgba(52, 211, 153, 0.12);
            color: var(--success);
        }

        .badge-success::before {
            background: var(--success);
        }

        .badge-danger {
            background: rgba(248, 113, 113, 0.12);
            color: var(--danger);
        }

        .badge-danger::before {
            background: var(--danger);
        }

        .badge-info {
            background: rgba(96, 165, 250, 0.12);
            color: var(--info);
        }

        .badge-info::before {
            background: var(--info);
        }

        /* ── Table footer / pagination ── */
        .table-footer {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 12px 16px;
            border-top: 1px solid var(--border);
            gap: 10px;
            flex-wrap: wrap;
        }

        .table-info {
            font-size: 12px;
            color: var(--text-muted);
        }

        .pagination {
            display: flex;
            gap: 4px;
            flex-wrap: wrap;
        }

        .page-btn {
            min-width: 30px;
            height: 30px;
            border-radius: 8px;
            background: var(--bg4);
            border: 1px solid var(--border);
            color: var(--text-secondary);
            font-size: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.15s;
            font-family: 'DM Mono', monospace;
            padding: 0 8px;
        }

        .page-btn:hover {
            border-color: var(--border-hover);
            color: var(--text-primary);
        }

        .page-btn.active {
            background: var(--accent-glow);
            color: var(--accent2);
            border-color: rgba(108, 99, 255, 0.3);
        }

        .page-btn:disabled {
            opacity: 0.3;
            cursor: not-allowed;
            pointer-events: none;
        }

        .empty-note {
            padding: 40px;
            text-align: center;
            color: var(--text-muted);
            font-size: 13.5px;
        }

        .empty-note i {
            display: block;
            font-size: 28px;
            margin-bottom: 10px;
            opacity: 0.35;
        }

        /* ── Responsive ── */

        /* Tablet */
        @media (max-width: 900px) {
            .page-grid {
                grid-template-columns: 1fr;
            }

            /* On tablet, show profile as horizontal strip */
            .profile-top {
                flex-direction: row;
                text-align: left;
                align-items: center;
                gap: 14px;
            }

            .page-sub {
                display: none;
            }
        }

        /* Large phones */
        @media (max-width: 640px) {
            .stat-bar {
                grid-template-columns: repeat(3, 1fr);
                gap: 8px;
            }

            .stat-mini {
                padding: 10px 12px;
            }

            .stat-mini-value {
                font-size: 18px;
            }

            .stat-mini-label {
                font-size: 10px;
            }

            .content {
                padding: 16px 12px;
            }

            .topbar {
                padding: 0 16px;
                height: 56px;
            }
        }

        /* Small phones */
        @media (max-width: 420px) {
            .stat-bar {
                grid-template-columns: repeat(3, 1fr);
                gap: 6px;
            }

            .stat-mini {
                padding: 8px 10px;
            }

            .stat-mini-value {
                font-size: 16px;
            }

            .content {
                padding: 12px 10px;
            }

            .topbar {
                padding: 0 12px;
            }

            .icon-btn {
                width: 32px;
                height: 32px;
            }

            .topbar .avatar {
                width: 32px !important;
                height: 32px !important;
            }

            .table-footer {
                flex-direction: column;
                align-items: flex-start;
            }
        }
    </style>
</head>

<body>

    <!-- Mobile Sidebar Overlay -->
    <div class="sidebar-overlay" id="overlay" onclick="closeSidebar()"></div>

    <!-- ── Sidebar ── -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-logo">
            <div class="logo-icon"><img src="/assets/Kharidlow.png" alt="logo" width="45"></div>
            <div class="logo-text">Kharid<span>low</span></div>
        </div>

        <nav class="sidebar-nav">
            <div class="nav-label">Overview</div>
            <a href="/admin" class="nav-link">
                <i class="fa-solid fa-chart-pie"></i> Dashboard
            </a>

            <div class="nav-label">Manage</div>
            <a href="/admin/manage/orders" class="nav-link">
                <i class="fa-solid fa-box"></i> Orders
            </a>
            <a href="/admin/manage/customers" class="nav-link active">
                <i class="fa-solid fa-users"></i> Customers
            </a>
            <a href="/admin/manage/products" class="nav-link">
                <i class="fa-solid fa-tags"></i> Products
            </a>

            <div class="nav-label">Store</div>
            <a href="/product/new" class="nav-link">
                <i class="fa-solid fa-plus-circle"></i> Add Product
            </a>
            <a href="/admin/cartanalysis" class="nav-link">
                <i class="fa-solid fa-cart-arrow-down"></i> Cart Insights
            </a>
            <a href="/" class="nav-link">
                <i class="fa-solid fa-store"></i> Store
            </a>

            <div class="nav-label">User</div>
            <a href="/admin/add-user" class="nav-link">
                <i class="fa-solid fa-user-plus"></i> Add User
            </a>
        </nav>

        <div class="sidebar-footer">
            <div class="user-card">
                <div class="avatar">AD</div>
                <div class="user-info">
                    <div class="user-name">Admin</div>
                    <div class="user-role">Super Admin</div>
                </div>
                <a href="/logout" style="color:var(--text-muted);font-size:13px;margin-left:2px;" title="Logout">
                    <i class="fa-solid fa-right-from-bracket"></i>
                </a>
            </div>
        </div>
    </aside>

    <!-- ── Main Wrapper ── -->
    <div class="main-wrap">

        <!-- Topbar -->
        <header class="topbar">
            <div class="topbar-left">
                <button class="hamburger" onclick="toggleSidebar()" aria-label="Toggle Menu">
                    <i class="fa-solid fa-bars"></i>
                </button>
                <div>
                    <div class="page-title">
                        <%= customer.fullName.charAt(0).toUpperCase() + customer.fullName.slice(1).toLowerCase() %>
                    </div>
                    <div class="page-sub">Customer Details</div>
                </div>
            </div>
            <div class="topbar-right">
                <a href="/admin/manage/customers" class="icon-btn" data-tooltip="Back to Customers">
                    <i class="fa-solid fa-arrow-left"></i>
                </a>
                <div class="icon-btn" data-tooltip="Notifications">
                    <i class="fa-solid fa-bell"></i>
                    <span class="notif-dot"></span>
                </div>
                <div class="avatar" style="width:36px;height:36px;font-size:12px;border-radius:10px;cursor:pointer;">AD
                </div>
            </div>
        </header>

        <!-- Content -->
        <main class="content">
            <div class="page-grid">

                <!-- ── Left: Profile ── -->
                <div>
                    <div class="view-card">
                        <div class="view-card-body">

                            <div class="profile-top">
                                <div class="profile-avatar">
                                    <%= customer.fullName.charAt(0).toUpperCase() %>
                                </div>
                                <div>
                                    <div class="profile-name">
                                        <%= customer.fullName.charAt(0).toUpperCase() +
                                            customer.fullName.slice(1).toLowerCase() %>
                                    </div>
                                    <div class="profile-email">
                                        <%= customer.email %>
                                    </div>
                                </div>
                            </div>

                            <div class="info-row">
                                <span class="info-label">Contact</span>
                                <span class="info-value mono">
                                    <%= customer.contactNo %>
                                </span>
                            </div>
                            <div class="info-row">
                                <span class="info-label">Email</span>
                                <span class="info-value" style="font-size:12px;word-break:break-all;">
                                    <%= customer.email %>
                                </span>
                            </div>
                            <div class="info-row">
                                <span class="info-label">Total Orders</span>
                                <span class="info-value mono" style="color:var(--accent2);font-weight:600;">
                                    <%= customer.orderCount %>
                                </span>
                            </div>

                            <div class="address-section">
                                <div class="address-section-label">Saved Addresses</div>
                                <% if (customer.addresses.length> 0) { %>
                                    <div class="address-chips">
                                        <% customer.addresses.forEach((address, index)=> { %>
                                            <div class="address-chip">
                                                <i class="fa-solid fa-location-dot"></i>
                                                <span>
                                                    <strong>Address <%= index + 1 %></strong>
                                                    <%= address.flatNo %>, <%= address.streetNo %>, <%= address.area %>,
                                                                <%= address.state %> - <%= address.pincode %>
                                                </span>
                                            </div>
                                            <% }); %>
                                    </div>
                                    <% } else { %>
                                        <p
                                            style="font-size:12px;color:var(--text-muted);text-align:center;padding:8px 0;">
                                            No address saved</p>
                                        <% } %>
                            </div>

                        </div>
                    </div>

                    <a href="/admin/manage/customers" class="back-btn">
                        <i class="fa-solid fa-arrow-left"></i> Back to Customers
                    </a>
                </div>

                <!-- ── Right: Stats + Orders ── -->
                <div class="right-col">

                    <!-- Stat mini cards -->
                    <div class="stat-bar">
                        <div class="stat-mini">
                            <span class="stat-mini-label">Total</span>
                            <span class="stat-mini-value accent">
                                <%= customer.orderCount %>
                            </span>
                        </div>
                        <div class="stat-mini">
                            <span class="stat-mini-label">Delivered</span>
                            <span class="stat-mini-value success">
                                <%= recentOrders.filter(o=> o.status === 'delivered').length %>
                            </span>
                        </div>
                        <div class="stat-mini">
                            <span class="stat-mini-label">Pending</span>
                            <span class="stat-mini-value warning">
                                <%= recentOrders.filter(o=> o.status === 'pending').length %>
                            </span>
                        </div>
                    </div>

                    <!-- Orders table with pagination -->
                    <div class="view-card">
                        <div class="view-card-head">
                            <h3><i class="fa-solid fa-box"></i>Recent Orders</h3>
                            <span style="font-size:12px;color:var(--text-muted);">
                                <%= recentOrders.length %> order<%= recentOrders.length !==1 ? 's' : '' %>
                            </span>
                        </div>
                        <div class="table-wrap">
                            <table>
                                <thead>
                                    <tr>
                                        <th>Order ID</th>
                                        <th>Date</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody id="ordersTableBody">
                                    <% if (recentOrders.length> 0) { %>
                                        <% recentOrders.forEach(order=> { %>
                                            <tr>
                                                <td><span class="order-id">#<%= order.orderNumber %></span></td>
                                                <td style="color:var(--text-secondary);font-size:12.5px;">
                                                    <%= new Date(order.createdAt).toLocaleDateString() %>
                                                </td>
                                                <td>
                                                    <% if (order.status=="delivered" ) { %>
                                                        <span class="badge badge-success">
                                                            <%= order.status %>
                                                        </span>
                                                        <% } else if (order.status=="pending" ) { %>
                                                            <span class="badge badge-warning">
                                                                <%= order.status %>
                                                            </span>
                                                            <% } else if (order.status=="canceled" ) { %>
                                                                <span class="badge badge-danger">
                                                                    <%= order.status %>
                                                                </span>
                                                                <% } else { %>
                                                                    <span class="badge badge-info">
                                                                        <%= order.status %>
                                                                    </span>
                                                                    <% } %>
                                                </td>
                                            </tr>
                                            <% }); %>
                                                <% } else { %>
                                                    <tr>
                                                        <td colspan="3" class="empty-note">
                                                            <i class="fa-solid fa-box-open"></i>
                                                            No orders yet
                                                        </td>
                                                    </tr>
                                                    <% } %>
                                </tbody>
                            </table>
                        </div>

                        <div class="table-footer">
                            <div class="table-info" id="tableInfo"></div>
                            <div class="pagination" id="pagination"></div>
                        </div>
                    </div>

                </div>
            </div>
        </main>
    </div>

    <script>
        // ── Sidebar ──
        function toggleSidebar() {
            document.getElementById('sidebar').classList.toggle('open');
            document.getElementById('overlay').classList.toggle('open');
        }
        function closeSidebar() {
            document.getElementById('sidebar').classList.remove('open');
            document.getElementById('overlay').classList.remove('open');
        }
        window.addEventListener('resize', () => { if (window.innerWidth > 900) closeSidebar(); });

        // ── Orders pagination ──
        const PAGE_SIZE = 10;
        const allRows = Array.from(document.querySelectorAll('#ordersTableBody tr')).filter(row => !row.querySelector('.empty-note'));
        let currentPage = 1;

        function renderPage() {
            if (allRows.length === 0) return;

            const start = (currentPage - 1) * PAGE_SIZE;
            const end = start + PAGE_SIZE;

            allRows.forEach((row, i) => {
                row.style.display = (i >= start && i < end) ? '' : 'none';
            });

            const from = start + 1;
            const to = Math.min(end, allRows.length);
            const total = allRows.length;
            document.getElementById('tableInfo').textContent = `Showing ${from}–${to} of ${total} orders`;

            renderPagination();
        }

        function renderPagination() {
            const totalPages = Math.ceil(allRows.length / PAGE_SIZE);
            const pag = document.getElementById('pagination');
            pag.innerHTML = '';
            if (totalPages <= 1) return;

            // Prev
            const prev = document.createElement('button');
            prev.className = 'page-btn';
            prev.innerHTML = '<i class="fa-solid fa-chevron-left" style="font-size:10px;"></i>';
            prev.disabled = currentPage === 1;
            prev.onclick = () => { currentPage--; renderPage(); };
            pag.appendChild(prev);

            // Pages with ellipsis
            const range = 2;
            for (let i = 1; i <= totalPages; i++) {
                if (i === 1 || i === totalPages || (i >= currentPage - range && i <= currentPage + range)) {
                    const btn = document.createElement('button');
                    btn.className = 'page-btn' + (i === currentPage ? ' active' : '');
                    btn.textContent = i;
                    btn.onclick = ((page) => () => { currentPage = page; renderPage(); })(i);
                    pag.appendChild(btn);
                } else if (i === currentPage - range - 1 || i === currentPage + range + 1) {
                    const dots = document.createElement('button');
                    dots.className = 'page-btn';
                    dots.textContent = '…';
                    dots.disabled = true;
                    pag.appendChild(dots);
                }
            }

            // Next
            const next = document.createElement('button');
            next.className = 'page-btn';
            next.innerHTML = '<i class="fa-solid fa-chevron-right" style="font-size:10px;"></i>';
            next.disabled = currentPage === totalPages;
            next.onclick = () => { currentPage++; renderPage(); };
            pag.appendChild(next);
        }

        renderPage();
    </script>
</body>

</html>