<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Customer Details - KharidLow</title>
    <link rel="icon" type="image/x-icon" href="/assets/Kharidlow.ico">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" />
    <link rel="stylesheet" href="/styles/adminHeader.css">
    <link rel="stylesheet" href="/styles/customerDetails.css">
    <style>
        .card {
            display: flex;
            flex-direction: column;
            height: 100%;
        }

        .scrollable {
            overflow-y: auto;
            flex-grow: 1;
            max-height: 300px;
            /* Adjust the max-height as needed */
        }
    </style>
</head>

<body>
    <%- include("../includes/admin-header.ejs"); %>
        <div class="container mt-4">
            <h1 class="text-center mb-4">Customer Details</h1>

            <div class="row mb-4">
                <div class="col-md-6">
                    <div class="card shadow-sm">
                        <div class="card-header bg-primary text-white">
                            <h5><i class="fa-solid fa-user"></i> Customer Information</h5>
                        </div>
                        <div class="card-body">
                            <p><strong>Name:</strong>
                                <%= customer.fullName.charAt(0).toUpperCase() + searchTerm.slice(1).toLowerCase(); %>
                            </p>
                            <p><strong>Contact:</strong>
                                <%= customer.contactNo %>
                            </p>
                            <p><strong>Email:</strong>
                                <%= customer.email %>
                            </p>
                            <h6 class="mt-3">Addresses:</h6>
                            <% if (customer.addresses.length> 0) { %>
                                <% customer.addresses.forEach((address, index)=> { %>
                                    <div class="address-item">
                                        <strong>Address <%= index + 1 %>:</strong><br>
                                        <%= address.flatNo %>, <%= address.streetNo %>, <%= address.area %>, <%=
                                                        address.state %>, <%= address.pincode %>
                                    </div>
                                    <hr>
                                    <% }); %>
                                        <% } else { %>
                                            <p>No address saved</p>
                                            <% } %>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="card shadow-sm">
                        <div class="card-header bg-info text-white">
                            <h5><i class="fa-solid fa-box"></i> Order Summary</h5>
                        </div>
                        <div class="card-body d-flex flex-column">
                            <p><strong>Total Orders:</strong>
                                <%= customer.orderCount %>
                            </p>
                            <h6>Recent Orders:</h6>
                            <div class="scrollable">
                                <ul class="list-group">
                                    <% if (recentOrders.length> 0) { %>
                                        <% recentOrders.forEach(order=> { %>
                                            <li class="list-group-item">
                                                <strong>Order No. #<%= order.orderNumber %></strong>
                                                <% if(order.status=="delivered" ) { %>
                                                    <span class="badge rounded-pill text-bg-success">
                                                        <%= order.status %>
                                                    </span>
                                                    <%} else if(order.status=="pending" ) {%>
                                                        <span class="badge rounded-pill text-bg-warning">
                                                            <%= order.status %>
                                                        </span>
                                                        <%} else {%>
                                                            <span class="badge rounded-pill text-bg-info">
                                                                <%= order.status %>
                                                            </span>
                                                            <%} %>
                                                            <br>
                                                <span class="text-muted">Date: <%= new
                                                        Date(order.createdAt).toLocaleDateString() %></span>
                                            </li>
                                            <% }); %>
                                                <% } else { %>
                                                    <li class="list-group-item">No Orders</li>
                                                    <% } %>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="text-center mt-4">
                <a href="/admin/manage/customers" class="btn btn-secondary"><i class="fa-solid fa-arrow-left"></i> Back
                    to Customers</a>
            </div>
        </div>

        <!-- Include Admin Sidebar -->
        <%- include("../includes/admin-sidebar.ejs"); %>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>