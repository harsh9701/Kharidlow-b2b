<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kharidlow Admin Dashboard</title>
    <link rel="icon" type="image/x-icon" href="/assets/Kharidlow.ico">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="/styles/adminAccount.css"> <!-- Link to external CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
</head>

<body>
    <div class="admin-container">

        <%- include("../partials/admin-header.ejs"); %>

            <div class="admin-content">
                <main class="admin-main">
                    <section class="admin-dashboard">
                        <div class="grid">
                            <div class="card">
                                <h5>Total Sales</h5>
                                <p>
                                    <%= data.totalSales[0].totalSales %>
                                </p>
                                <i class="fa-solid fa-chart-line"></i>
                            </div>
                            <div class="card">
                                <h5>Delivered Orders</h5>
                                <p>
                                    <%= data.deliveredOrder %>
                                </p>
                                <i class="fa-solid fa-truck"></i>
                            </div>
                            <div class="card">
                                <h5>Total Orders</h5>
                                <p>
                                    <%= data.orderCount %>
                                </p>
                                <i class="fas fa-box"></i>
                            </div>
                            <div class="card">
                                <h5>Total Customers</h5>
                                <p>
                                    <%= data.userCount %>
                                </p>
                                <i class="fas fa-users"></i>
                            </div>
                            <div class="card">
                                <h5>Total Listings</h5>
                                <p>
                                    <%= data.productCount %>
                                </p>
                                <i class="fas fa-th-list"></i>
                            </div>
                        </div>
                    </section>

                    <section id="manageOrders" class="admin-section">
                        <h2>Manage Orders</h2>
                        <div class="table-responsive">
                            <table class="orderTable">
                                <thead>
                                    <tr>
                                        <th>Order ID</th>
                                        <th>Customer</th>
                                        <th>Status</th>
                                        <th>Total</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if((data.orders).length> 0) { let count = 0; %>
                                        <% data.orders.forEach((order)=> {%>
                                            <% count++; %>
                                                <% if(count < 5) { %>
                                                    <tr>
                                                        <td>
                                                            <%= order.orderNumber %>
                                                        </td>
                                                        <td>
                                                            <%= order.userId.fullName %>
                                                        </td>
                                                        <td>
                                                            <% if(order.status == "pending") { %>
                                                                <span class="badge bg-warning"><%= order.status %></span>
                                                            <% } else if(order.status == "delivered") { %>
                                                                <span class="badge bg-success"><%= order.status %></span>
                                                            <% } else { %>
                                                                <span class="badge bg-info"><%= order.status %></span>
                                                            <% } %>
                                                        </td>
                                                        <td>
                                                            <%= order.grandTotal %>
                                                        </td>
                                                        <td><button class="btn">View</button></td>
                                                    </tr>
                                                    <% } %>
                                                        <% }); %>
                                                            <% if(count==5) {%>
                                                                <tr>
                                                                    <td colspan="5" class="text-center fs-5"><a
                                                                            href="/admin/manage/orders">View More</a></td>
                                                                </tr>
                                                                <% } %>
                                                                    <% } else { %>
                                                                        <tr>
                                                                            <td colspan="5" class="text-center fs-5">No
                                                                                Orders</td>
                                                                        </tr>
                                                                        <% } %>
                                </tbody>
                            </table>
                        </div>
                    </section>

                    <section id="manageCustomers" class="admin-section">
                        <h2>Manage Customers</h2>
                        <div class="table-responsive">
                            <table>
                                <thead>
                                    <tr>
                                        <th>S. No.</th>
                                        <th>Name</th>
                                        <th>Email</th>
                                        <th>Contact</th>
                                        <th>Total Orders</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if((data.customers).length> 0) { let count = 0; %>
                                        <% data.customers.forEach((customer, index)=> { %>
                                            <% count++; %>
                                                <% if(count < 5) { %>
                                                    <tr>
                                                        <td>
                                                            <%= index+1 %>
                                                        </td>
                                                        <td>
                                                            <%= customer.fullName %>
                                                        </td>
                                                        <td>
                                                            <%= customer.email %>
                                                        </td>
                                                        <td>
                                                            <%= customer.contactNo %>
                                                        </td>
                                                        <td>
                                                            <%= customer.orderCount %>
                                                        </td>
                                                        <td><button class="btn">View</button></td>
                                                    </tr>
                                                    <% } %>
                                                        <% }); %>
                                                            <% if(count==5) {%>
                                                                <tr>
                                                                    <td colspan="6" class="text-center fs-5"><a
                                                                            href="/admin/manage/customers">View More</a></td>
                                                                </tr>
                                                                <% } %>
                                                                    <% } else { %>
                                                                        <tr>
                                                                            <td colspan="6" class="text-center fs-5">No
                                                                                Records</td>
                                                                        </tr>
                                                                        <% } %>
                                </tbody>
                            </table>
                        </div>
                    </section>

                    <section id="manageListings" class="admin-section">
                        <h2>Manage Listings</h2>
                        <div class="table-responsive">
                            <table>
                                <thead>
                                    <tr>
                                        <th>S. No.</th>
                                        <th>Product Name</th>
                                        <th>Category</th>
                                        <th>Price</th>
                                        <th>MOQ</th>
                                        <th>Stock</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if((data.listing).length> 0) { let count = 0; %>
                                        <% data.listing.forEach((item, index)=> { %>
                                            <% count++; %>
                                                <% if(count < 5) { %>
                                                    <tr>
                                                        <td>
                                                            <%= index+1 %>
                                                        </td>
                                                        <td>
                                                            <%= item.productName %>
                                                        </td>
                                                        <td>
                                                            <%= item.subCategory %>
                                                        </td>
                                                        <td>
                                                            <%= item.price %>
                                                        </td>
                                                        <td>
                                                            <%= item.moq %>
                                                        </td>
                                                        <td>
                                                            <%= item.stock %>
                                                        </td>
                                                        <td><button class="btn">Edit</button></td>
                                                    </tr>
                                                    <% } %>
                                                        <% }); %>
                                                            <% if(count==5) {%>
                                                                <tr>
                                                                    <td colspan="7" class="text-center fs-5"><a
                                                                            href="/admin/manage/products">View More</a></td>
                                                                </tr>
                                                                <% } %>
                                                                    <% } else { %>
                                                                        <tr>
                                                                            <td colspan="7" class="text-center fs-5">No
                                                                                Records</td>
                                                                        </tr>
                                                                        <% } %>
                                </tbody>
                            </table>
                        </div>
                    </section>
                </main>
            </div>
    </div>
    <div class="offcanvas offcanvas-end bg-dark text-light" data-bs-scroll="true" tabindex="-1"
        id="offcanvasWithBothOptions" aria-labelledby="offcanvasWithBothOptionsLabel">
        <div class="container">
            <div class="offcanvas-header">
                <img src="/assets/KharidLow.png" alt="" width="50">
                <h4 class="offcanvas-title mx-2" id="offcanvasWithBothOptionsLabel">KharidLow</h4>
                <button type="button" class="btn-close btn-dark" data-bs-dismiss="offcanvas"
                    aria-label="Close"></button>
            </div>
            <div class="offcanvas-body d-flex flex-column">
                <a href="/admin/manage/orders" class="d-flex align-items-center my-2">
                    <i class="fa-solid fa-box mx-2"></i>
                    <span>Manage Order</span>
                </a>
                <a href="/admin/manage/customers" class="d-flex align-items-center my-2">
                    <i class="fa-solid fa-users mx-2"></i>
                    <span>Manage Customer</span>
                </a>
                <a href="/admin/manage/products" class="d-flex align-items-center my-2">
                    <i class="fa-solid fa-rectangle-list mx-2"></i>
                    <span>Manage Products</span>
                </a>
                <a href="/admin/manage" class="sidebar-item d-flex align-items-center my-2">
                    <i class="fa-solid fa-chart-line mx-2"></i>
                    <span>Dashboard</span>
                </a>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>