<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kharidlow Admin Dashboard</title>
    <link rel="icon" type="image/x-icon" href="/assets/Kharidlow.ico">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="/styles/adminAccount.css"> <!-- Link to external CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
</head>

<body>
    <div class="admin-container">

        <%- include("../includes/admin-header.ejs"); %>

            <div class="admin-content">
                <main class="admin-main">
                    <section class="admin-dashboard">
                        <div class="grid">
                            <div class="card">
                                <h5>Total Sales</h5>
                                <p>
                                    <%= (data && (data.totalSales).length> 0) ? data.totalSales[0].totalSales : 0 %>
                                </p>
                                <i class="fa-solid fa-chart-line"></i>
                            </div>
                            <div class="card">
                                <h5>Delivered Orders</h5>
                                <p>
                                    <%= (data && data.deliveredOrder) ? data.deliveredOrder : 0 %>
                                </p>
                                <i class="fa-solid fa-truck"></i>
                            </div>
                            <div class="card">
                                <h5>Total Orders</h5>
                                <p>
                                    <%= (data && data.orderCount) ? data.orderCount : 0 %>
                                </p>
                                <i class="fas fa-box"></i>
                            </div>
                            <div class="card">
                                <h5>Total Customers</h5>
                                <p>
                                    <%= (data && data.userCount) ? data.userCount : 0 %>
                                </p>
                                <i class="fas fa-users"></i>
                            </div>
                            <div class="card">
                                <h5>Total Listings</h5>
                                <p>
                                    <%= (data && data.productCount) ? data.productCount : 0 %>
                                </p>
                                <i class="fas fa-th-list"></i>
                            </div>
                        </div>
                    </section>

                    <section id="manageOrders" class="admin-section">
                        <h2>Manage Orders</h2>
                        <div class="table-responsive">
                            <table class="orderTable">
                                <thead>
                                    <tr>
                                        <th>Order ID</th>
                                        <th>Customer</th>
                                        <th>Status</th>
                                        <th>Total</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if((data.orders).length> 0) { let count = 0; %>
                                        <% data.orders.forEach((order)=> {%>
                                            <% count++; %>
                                                <% if(count < 5) { %>
                                                    <tr>
                                                        <td>
                                                            <%= order.orderNumber %>
                                                        </td>
                                                        <td>
                                                            <%= order.userId.fullName.charAt(0).toUpperCase() + fullName.slice(1).toLowerCase(); %>
                                                        </td>
                                                        <td>
                                                            <% if(order.status=="pending" ) { %>
                                                                <span class="badge bg-warning">
                                                                    <%= order.status %>
                                                                </span>
                                                                <% } else if(order.status=="delivered" ) { %>
                                                                    <span class="badge bg-success">
                                                                        <%= order.status %>
                                                                    </span>
                                                                    <% } else { %>
                                                                        <span class="badge bg-info">
                                                                            <%= order.status %>
                                                                        </span>
                                                                        <% } %>
                                                        </td>
                                                        <td>
                                                            <%= order.grandTotal %>
                                                        </td>
                                                        <td class="text-center"><a
                                                                href="/admin/manage/orders/<%= order._id %>"
                                                                class="btn btn-sm btn-info" data-bs-toggle="tooltip"
                                                                data-bs-placement="top" title="View">
                                                                <i class="fa-solid fa-eye"></i>
                                                            </a></td>
                                                    </tr>
                                                    <% } %>
                                                        <% }); %>
                                                            <% if(count==5) {%>
                                                                <tr>
                                                                    <td colspan="5" class="text-center fs-5"><a
                                                                            href="/admin/manage/orders">View More</a>
                                                                    </td>
                                                                </tr>
                                                                <% } %>
                                                                    <% } else { %>
                                                                        <tr>
                                                                            <td colspan="5" class="text-center fs-5">No
                                                                                Orders</td>
                                                                        </tr>
                                                                        <% } %>
                                </tbody>
                            </table>
                        </div>
                    </section>

                    <section id="manageCustomers" class="admin-section">
                        <h2>Manage Customers</h2>
                        <div class="table-responsive">
                            <table>
                                <thead>
                                    <tr>
                                        <th>S. No.</th>
                                        <th>Name</th>
                                        <th>Email</th>
                                        <th>Contact</th>
                                        <th>Total Orders</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if((data.customers).length> 0) { let count = 0; %>
                                        <% data.customers.forEach((customer, index)=> { %>
                                            <% count++; %>
                                                <% if(count < 5) { %>
                                                    <tr>
                                                        <td>
                                                            <%= index+1 %>
                                                        </td>
                                                        <td>
                                                            <%= customer.fullName.charAt(0).toUpperCase() + fullName.slice(1).toLowerCase(); %>
                                                        </td>
                                                        <td>
                                                            <%= customer.email %>
                                                        </td>
                                                        <td>
                                                            <%= customer.contactNo %>
                                                        </td>
                                                        <td>
                                                            <%= customer.orderCount %>
                                                        </td>
                                                        <td class="text-center">
                                                            <div class="btn-group" role="group">
                                                                <a href="/admin/manage/customers/<%= customer._id %>"
                                                                    class="btn btn-sm btn-info" data-bs-toggle="tooltip"
                                                                    data-bs-placement="top" title="View">
                                                                    <i class="fa-solid fa-eye"></i>
                                                                </a>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                    <% } %>
                                                        <% }); %>
                                                            <% if(count==5) {%>
                                                                <tr>
                                                                    <td colspan="6" class="text-center fs-5"><a
                                                                            href="/admin/manage/customers">View More</a>
                                                                    </td>
                                                                </tr>
                                                                <% } %>
                                                                    <% } else { %>
                                                                        <tr>
                                                                            <td colspan="6" class="text-center fs-5">No
                                                                                Records</td>
                                                                        </tr>
                                                                        <% } %>
                                </tbody>
                            </table>
                        </div>
                    </section>

                    <section id="manageListings" class="admin-section">
                        <h2>Manage Listings</h2>
                        <div class="table-responsive">
                            <table>
                                <thead>
                                    <tr>
                                        <th>S. No.</th>
                                        <th>Product Name</th>
                                        <th>Category</th>
                                        <th>Price</th>
                                        <th>MOQ</th>
                                        <th>Stock</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if((data.listing).length> 0) { let count = 0; %>
                                        <% data.listing.forEach((item, index)=> { %>
                                            <% count++; %>
                                                <% if(count < 5) { %>
                                                    <tr>
                                                        <td>
                                                            <%= index+1 %>
                                                        </td>
                                                        <td>
                                                            <%= item.productName %>
                                                        </td>
                                                        <td>
                                                            <%= item.subCategory %>
                                                        </td>
                                                        <td>
                                                            <%= item.price %>
                                                        </td>
                                                        <td>
                                                            <%= item.moq %>
                                                        </td>
                                                        <td>
                                                            <%= item.stock %>
                                                        </td>
                                                        <td class="text-center"><a href="/product/<%= item._id %>"
                                                                class="btn btn-sm btn-info" data-bs-toggle="tooltip"
                                                                data-bs-placement="top" title="View on browser">
                                                                <i class="fa-solid fa-eye"></i>
                                                            </a></td>
                                                    </tr>
                                                    <% } %>
                                                        <% }); %>
                                                            <% if(count==5) {%>
                                                                <tr>
                                                                    <td colspan="7" class="text-center fs-5"><a
                                                                            href="/admin/manage/products">View More</a>
                                                                    </td>
                                                                </tr>
                                                                <% } %>
                                                                    <% } else { %>
                                                                        <tr>
                                                                            <td colspan="7" class="text-center fs-5">No
                                                                                Records</td>
                                                                        </tr>
                                                                        <% } %>
                                </tbody>
                            </table>
                        </div>
                    </section>
                </main>
            </div>
    </div>

    <!-- Include Admin Sidebar -->
    <%- include("../includes/admin-sidebar.ejs"); %>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>