<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Customers - Kharidlow</title>
    <link rel="icon" type="image/x-icon" href="/assets/Kharidlow.ico">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
    <link
        href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&family=DM+Mono:wght@400;500&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="/styles/adminPage.css">
    <style>
        /* ── Page-specific only ── */

        .search-box {
            display: flex;
            align-items: center;
            gap: 8px;
            background: var(--bg4);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 7px 14px;
            transition: border-color 0.15s;
        }

        .search-box:focus-within {
            border-color: var(--accent);
        }

        .search-box i {
            color: var(--text-muted);
            font-size: 13px;
            flex-shrink: 0;
        }

        .search-box input {
            background: none;
            border: none;
            outline: none;
            color: var(--text-primary);
            font-size: 13.5px;
            font-family: 'DM Sans', sans-serif;
            width: 200px;
        }

        .search-box input::placeholder {
            color: var(--text-muted);
        }

        .wa-link {
            display: inline-flex;
            align-items: center;
            color: var(--success);
            text-decoration: none;
            font-size: 14px;
            margin-left: 6px;
            transition: opacity 0.15s;
        }

        .wa-link:hover {
            opacity: 0.75;
        }

        .table-footer {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 14px 20px;
            border-top: 1px solid var(--border);
            gap: 12px;
            flex-wrap: wrap;
        }

        .table-info {
            font-size: 12px;
            color: var(--text-muted);
        }

        .pagination {
            display: flex;
            gap: 4px;
            flex-wrap: wrap;
        }

        .page-btn {
            min-width: 30px;
            height: 30px;
            border-radius: 8px;
            background: var(--bg4);
            border: 1px solid var(--border);
            color: var(--text-secondary);
            font-size: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.15s;
            font-family: 'DM Mono', monospace;
            padding: 0 8px;
        }

        .page-btn:hover {
            border-color: var(--border-hover);
            color: var(--text-primary);
        }

        .page-btn.active {
            background: var(--accent-glow);
            color: var(--accent2);
            border-color: rgba(108, 99, 255, 0.3);
        }

        .page-btn:disabled {
            opacity: 0.3;
            cursor: not-allowed;
            pointer-events: none;
        }

        .no-data {
            padding: 60px;
            text-align: center;
            color: var(--text-muted);
            font-size: 14px;
        }

        .no-data i {
            font-size: 32px;
            margin-bottom: 12px;
            display: block;
            opacity: 0.4;
        }

        @media (max-width: 640px) {
            .search-box input {
                width: 140px;
            }

            .page-sub {
                display: none;
            }
        }

        @media (max-width: 420px) {
            .search-box input {
                width: 110px;
            }
        }
    </style>
</head>

<body>

    <!-- Mobile Sidebar Overlay -->
    <div class="sidebar-overlay" id="overlay" onclick="closeSidebar()"></div>

    <!-- ── Sidebar ── -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-logo">
            <div class="logo-icon"><img src="/assets/Kharidlow.png" alt="logo" width="45"></div>
            <div class="logo-text">Kharid<span>low</span></div>
        </div>

        <nav class="sidebar-nav">
            <div class="nav-label">Overview</div>
            <a href="/admin/manage" class="nav-link">
                <i class="fa-solid fa-chart-pie"></i> Dashboard
            </a>

            <div class="nav-label">Manage</div>
            <a href="/admin/manage/orders" class="nav-link">
                <i class="fa-solid fa-box"></i> Orders
            </a>
            <a href="/admin/manage/customers" class="nav-link active">
                <i class="fa-solid fa-users"></i> Customers
            </a>
            <a href="/admin/manage/products" class="nav-link">
                <i class="fa-solid fa-tags"></i> Products
            </a>

            <div class="nav-label">Store</div>
            <a href="/product/new" class="nav-link">
                <i class="fa-solid fa-plus-circle"></i> Add Product
            </a>
            <a href="/admin/cartanalysis" class="nav-link">
                <i class="fa-solid fa-cart-arrow-down"></i> Cart Insights
            </a>
            <a href="/" class="nav-link">
                <i class="fa-solid fa-store"></i> Store
            </a>

            <div class="nav-label">User</div>
            <a href="/admin/add-user" class="nav-link">
                <i class="fa-solid fa-user-plus"></i> Add User
            </a>
        </nav>

        <div class="sidebar-footer">
            <div class="user-card">
                <div class="avatar">AD</div>
                <div class="user-info">
                    <div class="user-name">Admin</div>
                    <div class="user-role">Super Admin</div>
                </div>
                <a href="/logout" style="color:var(--text-muted);font-size:13px;margin-left:2px;" title="Logout">
                    <i class="fa-solid fa-right-from-bracket"></i>
                </a>
            </div>
        </div>
    </aside>

    <!-- ── Main Wrapper ── -->
    <div class="main-wrap">

        <!-- Topbar -->
        <header class="topbar">
            <div class="topbar-left">
                <button class="hamburger" onclick="toggleSidebar()" aria-label="Toggle Menu">
                    <i class="fa-solid fa-bars"></i>
                </button>
                <div>
                    <div class="page-title">Manage Customers</div>
                    <div class="page-sub">View all registered customers</div>
                </div>
            </div>
            <div class="topbar-right">
                <div class="icon-btn" data-tooltip="Notifications">
                    <i class="fa-solid fa-bell"></i>
                    <span class="notif-dot"></span>
                </div>
                <div class="avatar" style="width:36px;height:36px;font-size:12px;border-radius:10px;cursor:pointer;">AD
                </div>
            </div>
        </header>

        <!-- Content -->
        <main class="content">
            <div class="section-card">

                <!-- Table Header -->
                <div class="section-head">
                    <h2><i class="fa-solid fa-users"
                            style="color:var(--accent2);margin-right:8px;font-size:14px;"></i>All Customers</h2>
                    <div class="search-box">
                        <i class="fa-solid fa-magnifying-glass"></i>
                        <input type="search" id="filterbox" placeholder="Search by name, email, contact…">
                    </div>
                </div>

                <!-- Table -->
                <div class="table-wrap">
                    <table id="customersTable">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Contact</th>
                                <th>Total Orders</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody id="tableBody">
                            <% if (customers.length> 0) { %>
                                <% customers.forEach((customer, index)=> { %>
                                    <tr data-index="<%= index %>">
                                        <td class="sno">
                                            <%= index + 1 %>
                                        </td>
                                        <td>
                                            <%= customer.fullName.charAt(0).toUpperCase() +
                                                customer.fullName.slice(1).toLowerCase() %>
                                        </td>
                                        <td class="muted">
                                            <%= customer.email %>
                                        </td>
                                        <td class="mono">
                                            <%= customer.contactNo %>
                                                <a href="https://wa.me/91<%= customer.contactNo %>" target="_blank"
                                                    class="wa-link" data-tooltip="Chat on WhatsApp">
                                                    <i class="fa-brands fa-whatsapp"></i>
                                                </a>
                                        </td>
                                        <td><span class="count-pill">
                                                <%= customer.orderCount %>
                                            </span></td>
                                        <td>
                                            <a href="/admin/manage/customers/<%= customer._id %>"
                                                class="btn-icon btn-view" data-tooltip="View Customer">
                                                <i class="fa-solid fa-eye"></i>
                                            </a>
                                        </td>
                                    </tr>
                                    <% }); %>
                                        <% } %>
                        </tbody>
                    </table>

                    <div id="noResults" class="no-data" style="display:none;">
                        <i class="fa-solid fa-user-slash"></i>
                        No customers match your search
                    </div>

                    <% if (customers.length===0) { %>
                        <div class="no-data">
                            <i class="fa-solid fa-users-slash"></i>
                            No customers found
                        </div>
                        <% } %>
                </div>

                <!-- Table Footer / Pagination -->
                <div class="table-footer">
                    <div class="table-info" id="tableInfo"></div>
                    <div class="pagination" id="pagination"></div>
                </div>

            </div>
        </main>
    </div>

    <script>
        // ── Sidebar ──
        function toggleSidebar() {
            document.getElementById('sidebar').classList.toggle('open');
            document.getElementById('overlay').classList.toggle('open');
        }
        function closeSidebar() {
            document.getElementById('sidebar').classList.remove('open');
            document.getElementById('overlay').classList.remove('open');
        }
        window.addEventListener('resize', () => { if (window.innerWidth > 900) closeSidebar(); });

        // ── Table State ──
        const PAGE_SIZE = 20;
        const allRows = Array.from(document.querySelectorAll('#tableBody tr'));
        let filteredRows = [...allRows];
        let currentPage = 1;

        allRows.forEach(row => { row._searchText = row.innerText.toLowerCase(); });

        // ── Render current page ──
        function renderPage() {
            const start = (currentPage - 1) * PAGE_SIZE;
            const end = start + PAGE_SIZE;

            allRows.forEach(row => row.style.display = 'none');
            filteredRows.slice(start, end).forEach(row => row.style.display = '');

            document.getElementById('noResults').style.display = filteredRows.length === 0 ? 'block' : 'none';

            const from = filteredRows.length === 0 ? 0 : start + 1;
            const to = Math.min(end, filteredRows.length);
            const total = filteredRows.length;
            document.getElementById('tableInfo').textContent =
                total === allRows.length
                    ? `Showing ${from}–${to} of ${total} customers`
                    : `Showing ${from}–${to} of ${total} results (filtered from ${allRows.length})`;

            renderPagination();
        }

        // ── Render pagination ──
        function renderPagination() {
            const totalPages = Math.ceil(filteredRows.length / PAGE_SIZE);
            const pag = document.getElementById('pagination');
            pag.innerHTML = '';
            if (totalPages <= 1) return;

            const prev = document.createElement('button');
            prev.className = 'page-btn';
            prev.innerHTML = '<i class="fa-solid fa-chevron-left" style="font-size:10px;"></i>';
            prev.disabled = currentPage === 1;
            prev.onclick = () => { currentPage--; renderPage(); };
            pag.appendChild(prev);

            const range = 2;
            for (let i = 1; i <= totalPages; i++) {
                if (i === 1 || i === totalPages || (i >= currentPage - range && i <= currentPage + range)) {
                    const btn = document.createElement('button');
                    btn.className = 'page-btn' + (i === currentPage ? ' active' : '');
                    btn.textContent = i;
                    btn.onclick = ((page) => () => { currentPage = page; renderPage(); })(i);
                    pag.appendChild(btn);
                } else if (i === currentPage - range - 1 || i === currentPage + range + 1) {
                    const dots = document.createElement('button');
                    dots.className = 'page-btn';
                    dots.textContent = '…';
                    dots.disabled = true;
                    pag.appendChild(dots);
                }
            }

            const next = document.createElement('button');
            next.className = 'page-btn';
            next.innerHTML = '<i class="fa-solid fa-chevron-right" style="font-size:10px;"></i>';
            next.disabled = currentPage === totalPages;
            next.onclick = () => { currentPage++; renderPage(); };
            pag.appendChild(next);
        }

        // ── Search ──
        document.getElementById('filterbox').addEventListener('input', function () {
            const q = this.value.toLowerCase().trim();
            filteredRows = q ? allRows.filter(row => row._searchText.includes(q)) : [...allRows];
            currentPage = 1;
            renderPage();
        });

        // ── Init ──
        renderPage();
    </script>
</body>

</html>