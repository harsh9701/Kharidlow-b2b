<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Orders - Kharidlow</title>
    <link rel="icon" type="image/x-icon" href="/assets/Kharidlow.ico">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/2.1.8/css/dataTables.dataTables.min.css" />
    <link rel="stylesheet" href="/styles/adminHeader.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="/styles/tableStructure.css">
    <style>
        .custom-close {
            background-color: #e2e2e2 !important;
            color: #fff !important;
            border: 1px solid transparent !important;
        }

        .custom-close:hover {
            background-color: #0056b3 !important;
            border: 1px solid #0056b3 !important;
        }

        .custom-close:focus {
            outline: none !important;
            box-shadow: 0 0 0 0.2rem rgba(0, 123, 255, 0.5) !important;
        }
    </style>

</head>

<body>

    <%- include("../includes/admin-header.ejs"); %>

        <div class="container p-30">
            <div class="row">
                <div class="col-md-12 main-datatable">
                    <div class="card_body">
                        <div class="row d-flex">
                            <div class="col-sm-4 createSegment">
                                <!-- <a class="btn dim_button create_new"><span class="glyphicon glyphicon-plus"></span>Create
                                New</a> -->
                            </div>
                            <div class="col-sm-8 add_flex">
                                <div class="form-group searchInput">
                                    <label>Search:</label>
                                    <input type="search" class="form-control" name="" id="filterbox"
                                        placeholder="Search Order">
                                </div>
                            </div>
                        </div>
                        <div class="overflow-x">
                            <table style="width: 100%;" id="filtertable"
                                class="table cust-datatable dataTable no-footer">
                                <thead>
                                    <tr>
                                        <th style="min-width: 50px;">S. No.</th>
                                        <th style="min-width: 50px;">Order Number</th>
                                        <th style="min-width: 50px;">Customer Name</th>
                                        <th style="min-width: 50px;">Date</th>
                                        <th style="min-width: 50px;">Status</th>
                                        <th style="min-width: 50px;">Total Amount</th>
                                        <th style="min-width: 50px;">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if(allOrders.length> 0) { %>
                                        <% allOrders.forEach((order, index)=> { %>
                                            <tr>
                                                <td>
                                                    <%= index+1 %>
                                                </td>
                                                <td>
                                                    <%= order.orderNumber %>
                                                </td>
                                                <td>
                                                    <%= order.userId.fullName.charAt(0).toUpperCase() + fullName.slice(1).toLowerCase(); %>
                                                </td>
                                                <td>
                                                    <%= order.createdAt.toDateString() %>
                                                </td>
                                                <td>
                                                    <% if(order.status=="pending" ) { %>
                                                        <span class="badge bg-warning">
                                                            <%= order.status %>
                                                        </span>
                                                        <% } else if(order.status=="delivered" ) { %>
                                                            <span class="badge bg-success">
                                                                <%= order.status %>
                                                            </span>
                                                            <% } else { %>
                                                                <span class="badge bg-info">
                                                                    <%= order.status %>
                                                                </span>
                                                                <% } %>
                                                </td>
                                                <td>
                                                    <%= order.grandTotal %>
                                                </td>
                                                <td style="min-width: 200px;">
                                                    <div class="btn-group" role="group">
                                                        <a href="/admin/manage/orders/<%= order._id %>"
                                                            class="btn btn-sm btn-info" data-bs-toggle="tooltip"
                                                            data-bs-placement="top" title="View">
                                                            <i class="fa-solid fa-eye"></i>
                                                        </a>
                                                        <a class="btn btn-sm btn-primary updateOrderBtn"
                                                            data-bs-toggle="tooltip" data-bs-placement="top"
                                                            title="Update" data-order-id="<%= order._id %>">
                                                            <i class="fa-solid fa-pencil"></i>
                                                        </a>
                                                        <a class="btn btn-sm btn-danger disabled" tabindex="-1"
                                                            aria-disabled="true" data-bs-toggle="tooltip"
                                                            data-bs-placement="top" title="Delete">
                                                            <i class="fa-solid fa-trash-can"></i>
                                                        </a>
                                                    </div>
                                                </td>
                                            </tr>
                                            <% }); %>
                                                <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Include Admin Sidebar -->
        <%- include("../includes/admin-sidebar.ejs"); %>

            <div class="modal fade" id="updateOrderStatusModal" tabindex="-1"
                aria-labelledby="updateOrderStatusModalLabel" aria-hidden="true">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <form id="updateOrderForm">
                            <div class="modal-header">
                                <h5 class="modal-title" id="updateOrderStatusModalLabel">Update Order Status</h5>
                                <button type="button" class="btn-close custom-close" data-bs-dismiss="modal"
                                    aria-label="Close"></button>
                            </div>
                            <div class="modal-body">
                                <div class="mb-3">
                                    <label for="orderStatus" class="form-label">Order Status</label>
                                    <select class="form-select" id="orderStatus" name="status" required>
                                        <option value="accepted">Accepted</option>
                                        <option value="dispatched">Dispatched</option>
                                        <option value="delivered">Delivered</option>
                                        <option value="canceled">Canceled</option>
                                    </select>
                                </div>
                                <!-- Conditional fields -->
                                <div class="mb-3 d-none" id="trackingInfo">
                                    <label for="trackingId" class="form-label">Tracking ID</label>
                                    <input type="text" class="form-control" id="trackingId" name="trackingId">
                                    <label for="trackingUrl" class="form-label mt-2">Tracking URL</label>
                                    <input type="url" class="form-control" id="trackingUrl" name="trackingUrl">
                                </div>
                                <div class="mb-3 d-none" id="cancelReason">
                                    <label for="reason" class="form-label">Cancellation Reason</label>
                                    <textarea class="form-control" id="reason" name="reason" rows="3"></textarea>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <input type="hidden" id="orderId" name="orderId">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                                <button type="submit" class="btn btn-primary">Update</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
            <script src="https://code.jquery.com/jquery-3.7.1.js"></script>
            <script src="https://cdn.datatables.net/2.1.8/js/dataTables.min.js"></script>

            <script>

                $(document).ready(function () {
                    let dataTable = $('#filtertable').DataTable({
                        "pageLength": 20,
                        "aoColumnDefs": [{
                            "nSortable": false,
                            "aTargets": ['nosort']
                        }],
                        columnDefs: [
                            { type: 'date-dd-mm-yyyy', aTargets: [5] }
                        ],
                        "aoColumns": [
                            null,
                            null,
                            null,
                            null,
                            null,
                            null,
                            null
                        ],
                        "order": false,
                        "bLengthChange": false,
                        "dom": '<"top">ct<"top"p><"clear">'
                    });
                    $("#filterbox").keyup(function () {
                        dataTable.search(this.value).draw();
                    });
                });

                $(document).ready(function () {
                    // Initialize Bootstrap tooltips
                    $('[data-bs-toggle="tooltip"]').tooltip();

                    // When the update button is clicked, trigger the modal
                    $('.updateOrderBtn').on('click', function (event) {
                        event.preventDefault(); // Prevent default action
                        let orderId = $(this).data('order-id'); // Get the order ID from the button
                        $('#updateOrderStatusModal').modal('show'); // Show the modal
                        $('#orderId').val(orderId); // Set the order ID in the modal form
                    });

                    // Show/hide tracking info or cancel reason based on status selection
                    $('#orderStatus').on('change', function () {
                        let selectedStatus = $(this).val();
                        if (selectedStatus === 'dispatched') {
                            $('#trackingInfo').removeClass('d-none');
                            $('#cancelReason').addClass('d-none');
                        } else if (selectedStatus === 'canceled') {
                            $('#trackingInfo').addClass('d-none');
                            $('#cancelReason').removeClass('d-none');
                        } else {
                            $('#trackingInfo').addClass('d-none');
                            $('#cancelReason').addClass('d-none');
                        }
                    });

                    // Handle the form submission via AJAX
                    $('#updateOrderForm').submit(function (e) {
                        e.preventDefault();
                        let formData = $(this).serialize(); // Serialize form data

                        $.ajax({
                            type: 'PUT',
                            url: '/admin/manage/orders/update',
                            data: formData,
                            success: function (response) {
                                // alert('Order status updated successfully!');
                                Swal.fire({
                                    icon: 'success',
                                    title: 'Order status updated successfully!',
                                    confirmButtonText: 'Close'
                                }).then(() => {
                                    $('#updateOrderStatusModal').modal('hide');
                                    location.reload();
                                });
                            },
                            error: function (err) {
                                // alert('Error updating order status.');
                                Swal.fire({
                                    icon: 'error',
                                    title: 'Error!',
                                    text: 'Error updating order status.',
                                    confirmButtonText: 'Close'
                                });
                            }
                        });
                    });
                });

            </script>
</body>

</html>