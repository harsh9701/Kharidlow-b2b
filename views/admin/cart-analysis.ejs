<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Abandoned Carts - Admin Panel</title>
    <link rel="icon" type="image/x-icon" href="/assets/Kharidlow.ico">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" />
    <link rel="stylesheet" href="/styles/adminHeader.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: Arial, sans-serif;
            background-color: #f4f6f9;
            color: #333;
        }

        .admin-container {
            max-width: 1200px;
            margin: auto;
            padding: 20px;
            background-color: #fff;
            border-radius: 8px;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        }

        h1 {
            text-align: center;
            font-size: 24px;
            color: #333;
            margin-bottom: 20px;
        }

        .table-wrapper {
            overflow-x: auto;
        }

        .admin-table {
            width: 100%;
            border-collapse: collapse;
            text-align: left;
            font-size: 16px;
        }

        .admin-table th,
        .admin-table td {
            padding: 12px 15px;
            border-bottom: 1px solid #e0e0e0;
        }

        .admin-table th {
            background-color: #6c63ff;
            color: #fff;
        }

        .admin-table tr:hover {
            background-color: #f1f1f1;
        }

        .notify-btn {
            padding: 8px 12px;
            color: #fff;
            background-color: #ff6b6b;
            border: none;
            border-radius: 5px;
            cursor: pointer;
        }

        .notify-btn:hover {
            background-color: #ff4949;
        }

        .modal-content {
            border-radius: 8px;
        }

        .table {
            transition: background-color 0.3s ease;
        }

        .table-hover tbody tr:hover {
            background-color: #f1f1f1;
        }

        .table-bordered th,
        .table-bordered td {
            border: 1px solid #e0e0e0;
        }

        .table-light {
            background-color: #6c63ff;
            color: white;
        }

        .table-light th {
            background-color: #5a53d1;
            color: #fff;
        }

        .table-light th:hover {
            background-color: #5a53d1;
        }

        /* Responsive Design */
        @media (max-width: 768px) {
            h1 {
                font-size: 20px;
            }

            .admin-table th,
            .admin-table td {
                padding: 10px 8px;
                font-size: 14px;
            }

            .notify-btn {
                padding: 6px 10px;
            }

            .modal-dialog {
                max-width: 90%;
            }
        }
    </style>
</head>

<body>
    <%- include("../includes/admin-header.ejs"); %>
        <div class="admin-container mt-3">
            <h1>Abandoned Carts</h1>
            <div class="table-wrapper">
                <table class="admin-table">
                    <thead>
                        <tr style="text-align: center;">
                            <th>Customer Name</th>
                            <th>Contact No</th>
                            <th>Email</th>
                            <th>Items in Cart</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="cart-list">
                        <% if(cartDetails.length> 0) { %>
                            <% cartDetails.forEach((item)=> { %>
                                <tr style="text-align: center;">
                                    <td>
                                        <%= item.userId.fullName %>
                                    </td>
                                    <td>
                                        <%= item.userId.contactNo %>
                                    </td>
                                    <td>
                                        <%= item.userId.email %>
                                    </td>
                                    <td>
                                        <div class="btn-group" role="group">
                                            <a href="#" class="btn btn-sm btn-info view-btn" data-bs-toggle="modal"
                                                data-bs-target="#itemModal"
                                                data-items="<%= JSON.stringify(item.items) %>">
                                                <i class="fa-solid fa-eye"></i>
                                            </a>
                                        </div>
                                    </td>
                                    <td><button class="notify-btn" onclick="notifyCustomer('<%= item.userId._id %>')">
                                            <i class="fa-regular fa-bell"></i>
                                        </button></td>
                                </tr>
                                <% }) %>
                                    <% } %>
                    </tbody>
                </table>
            </div>

            <!-- Pagination Controls -->
            <nav aria-label="Page navigation">
                <ul class="pagination justify-content-center mt-3">
                    <% const totalPages=Math.ceil(totalCarts / limit); %>
                        <% if(currentPage> 1) { %>
                            <li class="page-item">
                                <a class="page-link" href="?page=<%= currentPage - 1 %>&limit=<%= limit %>">Previous</a>
                            </li>
                            <% } %>
                                <% for(let i=1; i <=totalPages; i++) { %>
                                    <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                                        <a class="page-link" href="?page=<%= i %>&limit=<%= limit %>">
                                            <%= i %>
                                        </a>
                                    </li>
                                    <% } %>
                                        <% if(currentPage < totalPages) { %>
                                            <li class="page-item">
                                                <a class="page-link"
                                                    href="?page=<%= currentPage + 1 %>&limit=<%= limit %>">Next</a>
                                            </li>
                                            <% } %>
                </ul>
            </nav>

            <!-- Modal -->
            <div class="modal fade" id="itemModal" tabindex="-1" aria-labelledby="itemModalLabel" aria-hidden="true">
                <div class="modal-dialog modal-lg">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title" id="itemModalLabel">Cart Items</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <table class="table table-bordered table-hover" id="modalTable">
                                <thead class="table-light">
                                    <tr>
                                        <th>Product Name</th>
                                        <th>Price</th>
                                        <th>Quantity</th>
                                        <th>View</th>
                                    </tr>
                                </thead>
                                <tbody id="modalTableBody">
                                    <!-- Table rows will be dynamically added here -->
                                </tbody>
                            </table>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <%- include("../includes/admin-sidebar.ejs"); %>

            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
            <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

            <script>

                function notifyCustomer(userId) {
                    // Show confirmation dialog
                    Swal.fire({
                        title: 'Send Notification?',
                        text: "Do you want to notify this customer about their abandoned cart?",
                        icon: 'question',
                        showCancelButton: true,
                        confirmButtonColor: '#3085d6',
                        cancelButtonColor: '#d33',
                        confirmButtonText: 'Yes, send it!',
                        cancelButtonText: 'No, cancel'
                    }).then((result) => {
                        if (result.isConfirmed) {
                            // If user confirms, hit the API
                            $.ajax({
                                url: `/admin/abandoned-cart-reminder/${userId}`,
                                method: 'POST',
                                success: function (response) {
                                    Swal.fire({
                                        icon: 'success',
                                        title: 'Notification Sent',
                                        text: response.message || 'The customer has been notified successfully!',
                                        showConfirmButton: false,
                                        timer: 3000
                                    });
                                },
                                error: function (error) {
                                    Swal.fire({
                                        icon: 'error',
                                        title: 'Notification Failed',
                                        text: error.responseJSON?.message || 'An error occurred. Please try again.',
                                        showConfirmButton: true
                                    });
                                }
                            });
                        }
                    });
                }


                document.addEventListener('DOMContentLoaded', function () {
                    const modalTableBody = document.getElementById('modalTableBody');

                    document.querySelectorAll('.view-btn').forEach(button => {
                        button.addEventListener('click', function () {
                            const items = JSON.parse(this.getAttribute('data-items'));
                            modalTableBody.innerHTML = ''; // Clear any previous content

                            if (items.length > 0) {
                                items.forEach(item => {
                                    const row = document.createElement('tr');
                                    row.innerHTML = `
                                        <td>${item.productId.productName}</td>
                                        <td>&#8377;${item.productId.price}</td>
                                        <td>${item.quantity}</td>
                                        <td><a href="/product/${item.productId._id}"
                                                            class="btn btn-sm btn-info" data-bs-toggle="tooltip"
                                                            data-bs-placement="top" title="View on browser">
                                                            <i class="fa-solid fa-eye"></i>
                                                        </a></td>
                                    `;
                                    modalTableBody.appendChild(row);
                                });
                            } else {
                                const emptyRow = document.createElement('tr');
                                emptyRow.innerHTML = '<td colspan="3" class="text-center">No items in cart</td>';
                                modalTableBody.appendChild(emptyRow);
                            }
                        });
                    });
                });

            </script>


</body>

</html>