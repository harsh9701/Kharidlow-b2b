<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Products - Kharidlow</title>
    <link rel="icon" type="image/x-icon" href="/assets/Kharidlow.ico">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/2.1.8/css/dataTables.dataTables.min.css" />
    <link rel="stylesheet" href="/styles/adminHeader.css">
    <link rel="stylesheet" href="/styles/tableStructure.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>

<style>
    #loadingSpinner {
        display: none;
    }
</style>

<body>

    <%- include("../includes/admin-header.ejs"); %>

        <div class="container p-30">
            <div class="row">
                <div class="col-md-12 main-datatable">
                    <div class="card_body">
                        <div class="row d-flex">
                            <div class="col-sm-4 createSegment">
                                <a class="btn dim_button create_new"><a href="/product/new"
                                        class="d-flex justify-content-start flex-row mb-3 mx-4"
                                        style="text-decoration: none;"><i class="fa-solid fa-shirt fs-2"></i><i
                                            class="fa-solid fa-plus fs-6"></i></a></a>
                            </div>
                            <div class="col-sm-8 add_flex">
                                <div class="form-group searchInput">
                                    <label for="email">Search:</label>
                                    <input type="search" class="form-control" name="" id="filterbox"
                                        placeholder="Search Order">
                                </div>
                            </div>
                        </div>
                        <div class="overflow-x">
                            <table style="width: 100%;" id="filtertable"
                                class="table cust-datatable dataTable no-footer">
                                <thead>
                                    <tr>
                                        <th style="min-width: 50px;">S. No.</th>
                                        <th style="min-width: 50px;">Product Name</th>
                                        <th style="min-width: 50px;">SKU</th>
                                        <th style="min-width: 50px;">Category</th>
                                        <th style="min-width: 50px;">Price</th>
                                        <th style="min-width: 50px;">MOQ</th>
                                        <th style="min-width: 50px;">Stock</th>
                                        <th style="min-width: 50px;">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if(products.length> 0) { %>
                                        <% products.forEach((product, index)=> { %>
                                            <tr>
                                                <td>
                                                    <%= index+1 %>
                                                </td>
                                                <td>
                                                    <%= product.productName %>
                                                </td>
                                                <td>
                                                    <%= product.sku %>
                                                </td>
                                                <td>
                                                    <%= product.subCategory %>
                                                </td>
                                                <td>&#8377;<%= product.price %>
                                                </td>
                                                <td>
                                                    <%= product.moq %>
                                                </td>
                                                <td>
                                                    <%= product.stock %>
                                                </td>
                                                <td style="min-width: 200px;">
                                                    <div class="btn-group" role="group">
                                                        <a href="/product/<%= product._id %>"
                                                            class="btn btn-sm btn-info" data-bs-toggle="tooltip"
                                                            data-bs-placement="top" title="View on browser">
                                                            <i class="fa-solid fa-eye"></i>
                                                        </a>
                                                        <a href="/admin/manage/products/<%= product._id %>"
                                                            class="btn btn-sm btn-primary" data-bs-toggle="tooltip"
                                                            data-bs-placement="top" title="Update">
                                                            <i class="fa-solid fa-pencil"></i>
                                                        </a>
                                                        <a href="javascript:void(0);" class="btn btn-sm btn-danger"
                                                            onclick="deleteProduct('<%= product._id %>')"
                                                            data-bs-toggle="tooltip" data-bs-placement="top"
                                                            title="Delete">
                                                            <i class="fa-solid fa-trash-can"></i>
                                                        </a>
                                                    </div>
                                                </td>
                                            </tr>
                                            <% }); %>
                                                <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div id="loadingSpinner"
            class="d-none position-fixed top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center"
            style="background: rgba(0, 0, 0, 0.5); z-index: 1050;">
            <div class="spinner-border text-light" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>

        <!-- Include Admin Sidebar -->
        <%- include("../includes/admin-sidebar.ejs"); %>

            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
            <script src="https://code.jquery.com/jquery-3.7.1.js"></script>
            <script src="https://cdn.datatables.net/2.1.8/js/dataTables.min.js"></script>

            <script>
                $(document).ready(function () {
                    let dataTable = $('#filtertable').DataTable({
                        "pageLength": 20,
                        "aoColumnDefs": [{
                            "nSortable": false,
                            "aTargets": ['nosort']
                        }],
                        columnDefs: [
                            { type: 'date-dd-mm-yyyy', aTargets: [5] }
                        ],
                        "aoColumns": [
                            null,
                            null,
                            null,
                            null,
                            null,
                            null,
                            null,
                            null
                        ],
                        "order": false,
                        "bLengthChange": false,
                        "dom": '<"top">ct<"top"p><"clear">'
                    });
                    $("#filterbox").keyup(function () {
                        dataTable.search(this.value).draw();
                    });
                });

                $(document).ready(function () {
                    // Initialize Bootstrap tooltips
                    $('[data-bs-toggle="tooltip"]').tooltip();
                });

                function showLoader() {
                    $("#loadingSpinner").removeClass('d-none').show();
                }

                function hideLoader() {
                    $("#loadingSpinner").hide();
                }

                function deleteProduct(productId) {
                    Swal.fire({
                        title: 'Are you sure?',
                        text: "You won't be able to revert this!",
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonColor: '#3085d6',
                        cancelButtonColor: '#d33',
                        confirmButtonText: 'Yes, delete it!'
                    }).then((result) => {
                        if (result.isConfirmed) {
                            showLoader();
                            $.ajax({
                                url: `/admin/delete/product/${productId}`,
                                type: 'DELETE',
                                success: function (response) {
                                    hideLoader();
                                    if (response.success) {
                                        Swal.fire(
                                            'Deleted!',
                                            'Your product has been deleted.',
                                            'success'
                                        ).then(() => {
                                            location.reload(); // Reload the page
                                        });
                                    } else {
                                        Swal.fire(
                                            'Error!',
                                            response.message,
                                            'error'
                                        );
                                    }
                                },
                                error: function (xhr, status, error) {
                                    hideLoader();
                                    console.error('Error deleting product:', error);
                                    Swal.fire(
                                        'Error!',
                                        'An error occurred while deleting the product.',
                                        'error'
                                    );
                                }
                            });
                        }
                    });
                }
            </script>
</body>

</html>