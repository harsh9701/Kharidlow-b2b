<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Products - Kharidlow</title>
    <link rel="icon" type="image/x-icon" href="/assets/Kharidlow.ico">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
    <link
        href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&family=DM+Mono:wght@400;500&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="/styles/adminPage.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        /* ── Page-specific only ── */

        .search-box {
            display: flex;
            align-items: center;
            gap: 8px;
            background: var(--bg4);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 7px 14px;
            transition: border-color 0.15s;
        }

        .search-box:focus-within {
            border-color: var(--accent);
        }

        .search-box i {
            color: var(--text-muted);
            font-size: 13px;
            flex-shrink: 0;
        }

        .search-box input {
            background: none;
            border: none;
            outline: none;
            color: var(--text-primary);
            font-size: 13.5px;
            font-family: 'DM Sans', sans-serif;
            width: 200px;
        }

        .search-box input::placeholder {
            color: var(--text-muted);
        }

        /* ── Delete selected button ── */
        .btn-delete-selected {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            padding: 7px 14px;
            border-radius: 10px;
            background: rgba(248, 113, 113, 0.1);
            border: 1px solid rgba(248, 113, 113, 0.25);
            color: var(--danger);
            font-size: 13px;
            font-weight: 500;
            font-family: 'DM Sans', sans-serif;
            cursor: pointer;
            transition: all 0.15s;
        }

        .btn-delete-selected:hover {
            background: rgba(248, 113, 113, 0.18);
            border-color: rgba(248, 113, 113, 0.4);
        }

        /* ── Checkbox ── */
        input[type="checkbox"] {
            width: 15px;
            height: 15px;
            accent-color: var(--accent);
            cursor: pointer;
        }

        /* ── Table ── */
        .table-wrap {
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            min-width: 700px;
        }

        thead th {
            background: var(--bg4);
            padding: 11px 14px;
            text-align: left;
            font-size: 11px;
            font-weight: 600;
            color: var(--text-muted);
            letter-spacing: 0.6px;
            text-transform: uppercase;
            white-space: nowrap;
        }

        tbody tr {
            border-bottom: 1px solid var(--border);
            transition: background 0.12s;
        }

        tbody tr:last-child {
            border-bottom: none;
        }

        tbody tr:hover {
            background: rgba(255, 255, 255, 0.025);
        }

        tbody tr.selected {
            background: rgba(108, 99, 255, 0.07);
        }

        tbody td {
            padding: 12px 14px;
            font-size: 13px;
            color: var(--text-primary);
            white-space: nowrap;
        }

        .product-name {
            font-weight: 500;
            max-width: 200px;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .mono {
            font-family: 'DM Mono', monospace;
            font-size: 12px;
            color: var(--text-secondary);
        }

        .sno {
            color: var(--text-muted);
            font-size: 12px;
        }

        .cat-pill {
            background: rgba(96, 165, 250, 0.1);
            color: var(--info);
            padding: 2px 9px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600;
        }

        /* ── Action buttons ── */
        .btn-group {
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .btn-icon {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 30px;
            height: 30px;
            border-radius: 8px;
            background: var(--bg4);
            border: 1px solid var(--border);
            color: var(--text-secondary);
            text-decoration: none;
            font-size: 13px;
            cursor: pointer;
            transition: all 0.15s;
            font-family: 'DM Sans', sans-serif;
        }

        .btn-icon:hover {
            background: var(--accent-glow);
            color: var(--accent2);
            border-color: rgba(108, 99, 255, 0.3);
        }

        .btn-icon.btn-view:hover {
            background: rgba(96, 165, 250, 0.12);
            color: var(--info);
            border-color: rgba(96, 165, 250, 0.3);
        }

        .btn-icon.btn-edit:hover {
            background: rgba(108, 99, 255, 0.15);
            color: var(--accent2);
            border-color: rgba(108, 99, 255, 0.3);
        }

        .btn-icon.btn-del:hover {
            background: rgba(248, 113, 113, 0.12);
            color: var(--danger);
            border-color: rgba(248, 113, 113, 0.3);
        }

        /* ── Table footer / pagination ── */
        .table-footer {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 14px 16px;
            border-top: 1px solid var(--border);
            gap: 10px;
            flex-wrap: wrap;
        }

        .table-info {
            font-size: 12px;
            color: var(--text-muted);
        }

        .pagination {
            display: flex;
            gap: 4px;
            flex-wrap: wrap;
        }

        .page-btn {
            min-width: 30px;
            height: 30px;
            border-radius: 8px;
            background: var(--bg4);
            border: 1px solid var(--border);
            color: var(--text-secondary);
            font-size: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.15s;
            font-family: 'DM Mono', monospace;
            padding: 0 8px;
        }

        .page-btn:hover {
            border-color: var(--border-hover);
            color: var(--text-primary);
        }

        .page-btn.active {
            background: var(--accent-glow);
            color: var(--accent2);
            border-color: rgba(108, 99, 255, 0.3);
        }

        .page-btn:disabled {
            opacity: 0.3;
            cursor: not-allowed;
            pointer-events: none;
        }

        /* ── Loading spinner ── */
        .spinner-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.55);
            z-index: 300;
            align-items: center;
            justify-content: center;
        }

        .spinner-overlay.show {
            display: flex;
        }

        .spinner {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            border: 3px solid var(--border-hover);
            border-top-color: var(--accent2);
            animation: spin 0.7s linear infinite;
        }

        @keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        .no-data {
            padding: 60px;
            text-align: center;
            color: var(--text-muted);
            font-size: 14px;
        }

        .no-data i {
            font-size: 32px;
            margin-bottom: 12px;
            display: block;
            opacity: 0.4;
        }

        /* ── Responsive ── */
        @media (max-width: 900px) {
            .content {
                padding: 20px 16px;
            }

            .topbar {
                padding: 0 16px;
            }

            .search-box input {
                width: 150px;
            }
        }

        @media (max-width: 640px) {
            .content {
                padding: 16px 12px;
            }

            .topbar {
                height: 56px;
            }

            .page-sub {
                display: none;
            }

            .search-box input {
                width: 120px;
            }

            .section-head {
                flex-wrap: wrap;
                gap: 10px;
            }

            .table-footer {
                flex-direction: column;
                align-items: flex-start;
            }
        }

        @media (max-width: 420px) {
            .topbar {
                padding: 0 12px;
            }

            .icon-btn {
                width: 32px;
                height: 32px;
            }

            .search-box input {
                width: 100px;
            }
        }
    </style>
</head>

<body>

    <!-- Loading Spinner -->
    <div class="spinner-overlay" id="loadingSpinner">
        <div class="spinner"></div>
    </div>

    <!-- Mobile Sidebar Overlay -->
    <div class="sidebar-overlay" id="overlay" onclick="closeSidebar()"></div>

    <!-- ── Sidebar ── -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-logo">
            <div class="logo-icon"><img src="/assets/Kharidlow.png" alt="logo" width="45"></div>
            <div class="logo-text">Kharid<span>low</span></div>
        </div>

        <nav class="sidebar-nav">
            <div class="nav-label">Overview</div>
            <a href="/admin/manage" class="nav-link">
                <i class="fa-solid fa-chart-pie"></i> Dashboard
            </a>

            <div class="nav-label">Manage</div>
            <a href="/admin/manage/orders" class="nav-link">
                <i class="fa-solid fa-box"></i> Orders
            </a>
            <a href="/admin/manage/customers" class="nav-link">
                <i class="fa-solid fa-users"></i> Customers
            </a>
            <a href="/admin/manage/products" class="nav-link active">
                <i class="fa-solid fa-tags"></i> Products
            </a>

            <div class="nav-label">Store</div>
            <a href="/product/new" class="nav-link">
                <i class="fa-solid fa-plus-circle"></i> Add Product
            </a>
            <a href="/admin/cartanalysis" class="nav-link">
                <i class="fa-solid fa-cart-arrow-down"></i> Cart Insights
            </a>
            <a href="/" class="nav-link">
                <i class="fa-solid fa-store"></i> Store
            </a>

            <div class="nav-label">User</div>
            <a href="/admin/add-user" class="nav-link">
                <i class="fa-solid fa-user-plus"></i> Add User
            </a>
        </nav>

        <div class="sidebar-footer">
            <div class="user-card">
                <div class="avatar">AD</div>
                <div class="user-info">
                    <div class="user-name">Admin</div>
                    <div class="user-role">Super Admin</div>
                </div>
                <a href="/logout" style="color:var(--text-muted);font-size:13px;margin-left:2px;" title="Logout">
                    <i class="fa-solid fa-right-from-bracket"></i>
                </a>
            </div>
        </div>
    </aside>

    <!-- ── Main Wrapper ── -->
    <div class="main-wrap">

        <!-- Topbar -->
        <header class="topbar">
            <div class="topbar-left">
                <button class="hamburger" onclick="toggleSidebar()" aria-label="Toggle Menu">
                    <i class="fa-solid fa-bars"></i>
                </button>
                <div>
                    <div class="page-title">Manage Products</div>
                    <div class="page-sub">View, edit and delete products</div>
                </div>
            </div>
            <div class="topbar-right">
                <a href="/product/new" class="icon-btn" data-tooltip="Add New Product">
                    <i class="fa-solid fa-plus"></i>
                </a>
                <div class="icon-btn" data-tooltip="Notifications">
                    <i class="fa-solid fa-bell"></i>
                    <span class="notif-dot"></span>
                </div>
                <div class="avatar" style="width:36px;height:36px;font-size:12px;border-radius:10px;cursor:pointer;">AD
                </div>
            </div>
        </header>

        <!-- Content -->
        <main class="content">
            <div class="section-card">

                <!-- Table Header -->
                <div class="section-head">
                    <div style="display:flex;align-items:center;gap:10px;">
                        <h2><i class="fa-solid fa-tags"
                                style="color:var(--accent2);margin-right:8px;font-size:14px;"></i>All Products</h2>
                        <button class="btn-delete-selected" id="deleteSelectedBtn"
                            data-tooltip="Delete selected products">
                            <i class="fa-solid fa-trash-can"></i> Delete Selected
                        </button>
                    </div>
                    <div class="search-box">
                        <i class="fa-solid fa-magnifying-glass"></i>
                        <input type="search" id="filterbox" placeholder="Search products…">
                    </div>
                </div>

                <!-- Table -->
                <div class="table-wrap">
                    <table id="productsTable">
                        <thead>
                            <tr>
                                <th><input type="checkbox" id="selectAll" data-tooltip="Select all"></th>
                                <th>#</th>
                                <th>Product Name</th>
                                <th>Created At</th>
                                <th>SKU</th>
                                <th>Category</th>
                                <th>Price</th>
                                <th>MOQ</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="tableBody">
                            <% if (products.length> 0) { %>
                                <% products.forEach((product, index)=> { %>
                                    <tr data-id="<%= product._id %>">
                                        <td><input type="checkbox" class="product-checkbox" value="<%= product._id %>">
                                        </td>
                                        <td class="sno">
                                            <%= index + 1 %>
                                        </td>
                                        <td class="product-name">
                                            <%= product.productName %>
                                        </td>
                                        <td class="mono">
                                            <%= new Date(product.createdAt).toLocaleDateString('en-US', { day: '2-digit'
                                                , month: 'short' , year: 'numeric' }) %>
                                        </td>
                                        <td class="mono">
                                            <%= product.sku %>
                                        </td>
                                        <td><span class="cat-pill">
                                                <%= product.subCategory %>
                                            </span></td>
                                        <td class="mono">&#8377;<%= product.price %>
                                        </td>
                                        <td class="mono">
                                            <%= product.moq %>
                                        </td>
                                        <td>
                                            <div class="btn-group">
                                                <a href="/product/<%= product._id %>" class="btn-icon btn-view"
                                                    data-tooltip="View on site" target="_blank">
                                                    <i class="fa-solid fa-eye"></i>
                                                </a>
                                                <a href="/admin/manage/products/<%= product._id %>"
                                                    class="btn-icon btn-edit" data-tooltip="Edit product">
                                                    <i class="fa-solid fa-pencil"></i>
                                                </a>
                                                <button class="btn-icon btn-del" data-tooltip="Delete product"
                                                    onclick="deleteProduct('<%= product._id %>')">
                                                    <i class="fa-solid fa-trash-can"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                    <% }); %>
                                        <% } %>
                        </tbody>
                    </table>

                    <div id="noResults" class="no-data" style="display:none;">
                        <i class="fa-solid fa-box-open"></i>
                        No products match your search
                    </div>

                    <% if (products.length===0) { %>
                        <div class="no-data">
                            <i class="fa-solid fa-tags"></i>
                            No products found
                        </div>
                        <% } %>
                </div>

                <!-- Table Footer -->
                <div class="table-footer">
                    <div class="table-info" id="tableInfo"></div>
                    <div class="pagination" id="pagination"></div>
                </div>

            </div>
        </main>
    </div>

    <script>
        // ── Sidebar ──
        function toggleSidebar() {
            document.getElementById('sidebar').classList.toggle('open');
            document.getElementById('overlay').classList.toggle('open');
        }
        function closeSidebar() {
            document.getElementById('sidebar').classList.remove('open');
            document.getElementById('overlay').classList.remove('open');
        }
        window.addEventListener('resize', () => { if (window.innerWidth > 900) closeSidebar(); });

        // ── Loader ──
        function showLoader() { document.getElementById('loadingSpinner').classList.add('show'); }
        function hideLoader() { document.getElementById('loadingSpinner').classList.remove('show'); }

        // ── Swal theme ──
        const swalDark = { background: '#1e2028', color: '#f0f0f4', confirmButtonColor: '#6c63ff', cancelButtonColor: '#f87171' };

        // ── Table State ──
        const PAGE_SIZE = 20;
        const allRows = Array.from(document.querySelectorAll('#tableBody tr'));
        let filteredRows = [...allRows];
        let currentPage = 1;

        allRows.forEach(row => { row._searchText = row.innerText.toLowerCase(); });

        function renderPage() {
            if (allRows.length === 0) return;
            const start = (currentPage - 1) * PAGE_SIZE;
            const end = start + PAGE_SIZE;

            allRows.forEach(row => row.style.display = 'none');
            filteredRows.slice(start, end).forEach(row => row.style.display = '');

            document.getElementById('noResults').style.display = filteredRows.length === 0 ? 'block' : 'none';

            const from = filteredRows.length === 0 ? 0 : start + 1;
            const to = Math.min(end, filteredRows.length);
            const total = filteredRows.length;
            document.getElementById('tableInfo').textContent =
                total === allRows.length
                    ? `Showing ${from}–${to} of ${total} products`
                    : `Showing ${from}–${to} of ${total} results (filtered from ${allRows.length})`;

            renderPagination();

            // Sync selectAll state
            const visibleChecks = filteredRows.slice(start, end).map(r => r.querySelector('.product-checkbox'));
            document.getElementById('selectAll').checked = visibleChecks.length > 0 && visibleChecks.every(c => c.checked);
        }

        function renderPagination() {
            const totalPages = Math.ceil(filteredRows.length / PAGE_SIZE);
            const pag = document.getElementById('pagination');
            pag.innerHTML = '';
            if (totalPages <= 1) return;

            const prev = document.createElement('button');
            prev.className = 'page-btn';
            prev.innerHTML = '<i class="fa-solid fa-chevron-left" style="font-size:10px;"></i>';
            prev.disabled = currentPage === 1;
            prev.onclick = () => { currentPage--; renderPage(); };
            pag.appendChild(prev);

            const range = 2;
            for (let i = 1; i <= totalPages; i++) {
                if (i === 1 || i === totalPages || (i >= currentPage - range && i <= currentPage + range)) {
                    const btn = document.createElement('button');
                    btn.className = 'page-btn' + (i === currentPage ? ' active' : '');
                    btn.textContent = i;
                    btn.onclick = ((page) => () => { currentPage = page; renderPage(); })(i);
                    pag.appendChild(btn);
                } else if (i === currentPage - range - 1 || i === currentPage + range + 1) {
                    const dots = document.createElement('button');
                    dots.className = 'page-btn';
                    dots.textContent = '…';
                    dots.disabled = true;
                    pag.appendChild(dots);
                }
            }

            const next = document.createElement('button');
            next.className = 'page-btn';
            next.innerHTML = '<i class="fa-solid fa-chevron-right" style="font-size:10px;"></i>';
            next.disabled = currentPage === totalPages;
            next.onclick = () => { currentPage++; renderPage(); };
            pag.appendChild(next);
        }

        // ── Search ──
        document.getElementById('filterbox').addEventListener('input', function () {
            const q = this.value.toLowerCase().trim();
            filteredRows = q ? allRows.filter(row => row._searchText.includes(q)) : [...allRows];
            currentPage = 1;
            renderPage();
        });

        // ── Select All ──
        document.getElementById('selectAll').addEventListener('change', function () {
            const start = (currentPage - 1) * PAGE_SIZE;
            const end = start + PAGE_SIZE;
            filteredRows.slice(start, end).forEach(row => {
                const cb = row.querySelector('.product-checkbox');
                if (cb) cb.checked = this.checked;
                row.classList.toggle('selected', this.checked);
            });
        });

        // ── Individual checkbox → highlight row ──
        document.getElementById('tableBody').addEventListener('change', function (e) {
            if (e.target.classList.contains('product-checkbox')) {
                e.target.closest('tr').classList.toggle('selected', e.target.checked);
            }
        });

        // ── Single Delete ──
        function deleteProduct(productId) {
            Swal.fire({
                title: 'Delete this product?',
                text: "This action cannot be undone.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Yes, delete it!',
                cancelButtonText: 'Cancel',
                ...swalDark
            }).then((result) => {
                if (result.isConfirmed) {
                    showLoader();
                    fetch(`/admin/delete/product/${productId}`, { method: 'DELETE' })
                        .then(res => res.json())
                        .then(response => {
                            hideLoader();
                            if (response.success) {
                                Swal.fire({ icon: 'success', title: 'Deleted!', text: 'Product has been deleted.', ...swalDark })
                                    .then(() => location.reload());
                            } else {
                                Swal.fire({ icon: 'error', title: 'Error!', text: response.message, ...swalDark });
                            }
                        })
                        .catch(() => {
                            hideLoader();
                            Swal.fire({ icon: 'error', title: 'Error!', text: 'An error occurred while deleting.', ...swalDark });
                        });
                }
            });
        }

        // ── Bulk Delete ──
        document.getElementById('deleteSelectedBtn').addEventListener('click', function () {
            const selected = Array.from(document.querySelectorAll('.product-checkbox:checked')).map(cb => cb.value);

            if (selected.length === 0) {
                Swal.fire({ icon: 'info', title: 'No products selected', text: 'Please select at least one product to delete.', ...swalDark });
                return;
            }

            Swal.fire({
                title: 'Delete selected products?',
                text: `You are about to delete ${selected.length} product(s). This cannot be undone.`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Yes, delete them!',
                cancelButtonText: 'Cancel',
                ...swalDark
            }).then((result) => {
                if (result.isConfirmed) {
                    showLoader();
                    fetch('/admin/delete/products', {
                        method: 'DELETE',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ productIds: selected })
                    })
                        .then(res => res.json())
                        .then(response => {
                            hideLoader();
                            if (response.success) {
                                Swal.fire({ icon: 'success', title: 'Deleted!', text: 'Selected products have been deleted.', ...swalDark })
                                    .then(() => location.reload());
                            } else {
                                Swal.fire({ icon: 'error', title: 'Error!', text: response.message, ...swalDark });
                            }
                        })
                        .catch(() => {
                            hideLoader();
                            Swal.fire({ icon: 'error', title: 'Error!', text: 'An error occurred while deleting.', ...swalDark });
                        });
                }
            });
        });

        // ── Init ──
        renderPage();
    </script>
</body>

</html>