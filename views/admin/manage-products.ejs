<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Products - Kharidlow</title>
    <link rel="icon" type="image/x-icon" href="/assets/Kharidlow.ico">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/2.1.8/css/dataTables.dataTables.min.css" />
    <link rel="stylesheet" href="/styles/adminHeader.css">
    <link rel="stylesheet" href="/styles/tableStructure.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>

<style>
    #loadingSpinner {
        display: none;
    }
</style>

<body>

    <%- include("../includes/admin-header.ejs"); %>

        <div class="container p-30">
            <div class="row">
                <div class="col-md-12 main-datatable">
                    <div class="card_body">
                        <div class="row d-flex">
                            <div class="col-sm-4 createSegment">
                                <!-- <a class="btn dim_button create_new"><a href="/product/new"
                                        class="d-flex justify-content-start flex-row mb-3 mx-4"
                                        style="text-decoration: none;"><i class="fa-solid fa-shirt fs-2"></i><i
                                            class="fa-solid fa-plus fs-6"></i></a></a> -->
                                <button class="btn btn-danger" id="deleteSelectedBtn" data-bs-toggle="tooltip"
                                    title="Multiple Delete"><i class="fa-solid fa-trash-can"></i></button>
                            </div>
                            <div class="col-sm-8 add_flex">
                                <div class="form-group searchInput">
                                    <label for="filterbox">Search:</label>
                                    <input type="search" class="form-control" name="" id="filterbox"
                                        placeholder="Search Order">
                                </div>
                            </div>
                        </div>
                        <div class="overflow-x">
                            <table style="width: 100%;" id="filtertable"
                                class="table cust-datatable dataTable no-footer">
                                <thead>
                                    <tr>
                                        <th><input type="checkbox" id="selectAll"></th> <!-- Select All Checkbox -->
                                        <th>S.No.</th>
                                        <th>Product Name</th>
                                        <th>Created At</th>
                                        <th>SKU</th>
                                        <th>Category</th>
                                        <th>Price</th>
                                        <th>MOQ</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (products.length> 0) { %>
                                        <% products.forEach((product, index)=> { %>
                                            <tr>
                                                <td>
                                                    <input type="checkbox" class="product-checkbox"
                                                        value="<%= product._id %>">
                                                </td>
                                                <td>
                                                    <%= index + 1 %>
                                                </td>
                                                <td>
                                                    <%= product.productName %>
                                                </td>
                                                <td>
                                                    <%= new Date(product.createdAt).toLocaleDateString('en-US', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                                                </td>
                                                <td>
                                                    <%= product.sku %>
                                                </td>
                                                <td>
                                                    <%= product.subCategory %>
                                                </td>
                                                <td>&#8377;<%= product.price %>
                                                </td>
                                                <td>
                                                    <%= product.moq %>
                                                </td>
                                                <td style="min-width: 200px;">
                                                    <div class="btn-group" role="group">
                                                        <a href="/product/<%= product._id %>"
                                                            class="btn btn-sm btn-info" data-bs-toggle="tooltip"
                                                            title="View on browser" target="_blank">
                                                            <i class="fa-solid fa-eye"></i>
                                                        </a>
                                                        <a href="/admin/manage/products/<%= product._id %>"
                                                            class="btn btn-sm btn-primary" data-bs-toggle="tooltip"
                                                            title="Update" target="_blank">
                                                            <i class="fa-solid fa-pencil"></i>
                                                        </a>
                                                        <a href="javascript:void(0);" class="btn btn-sm btn-danger"
                                                            onclick="deleteProduct('<%= product._id %>')"
                                                            data-bs-toggle="tooltip" title="Delete">
                                                            <i class="fa-solid fa-trash-can"></i>
                                                        </a>
                                                    </div>
                                                </td>
                                            </tr>
                                            <% }); %>
                                                <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div id="loadingSpinner"
            class="d-none position-fixed top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center"
            style="background: rgba(0, 0, 0, 0.5); z-index: 1050;">
            <div class="spinner-border text-light" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>

        <!-- Include Admin Sidebar -->
        <%- include("../includes/admin-sidebar.ejs"); %>

            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
            <script src="https://code.jquery.com/jquery-3.7.1.js"></script>
            <script src="https://cdn.datatables.net/2.1.8/js/dataTables.min.js"></script>

            <script>
                $(document).ready(function () {
                    let dataTable = $('#filtertable').DataTable({
                        "pageLength": 20,
                        "aoColumnDefs": [{
                            "nSortable": false,
                            "aTargets": ['nosort']
                        }],
                        columnDefs: [
                            { type: 'date-dd-mm-yyyy', aTargets: [5] },
                            { targets: [0], orderable: false }
                        ],
                        "aoColumns": [
                            null,
                            null,
                            null,
                            null,
                            null,
                            null,
                            null,
                            null,
                            null
                        ],
                        "order": false,
                        "bLengthChange": false,
                        "dom": '<"top">ct<"top"p><"clear">'
                    });
                    $("#filterbox").keyup(function () {
                        dataTable.search(this.value).draw();
                    });
                });

                $(document).ready(function () {
                    // Initialize Bootstrap tooltips
                    $('[data-bs-toggle="tooltip"]').tooltip();
                });

                function showLoader() {
                    $("#loadingSpinner").removeClass('d-none').show();
                }

                function hideLoader() {
                    $("#loadingSpinner").hide();
                }

                // Single product delete
                function deleteProduct(productId) {
                    Swal.fire({
                        title: 'Are you sure?',
                        text: "You won't be able to revert this!",
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonColor: '#3085d6',
                        cancelButtonColor: '#d33',
                        confirmButtonText: 'Yes, delete it!'
                    }).then((result) => {
                        if (result.isConfirmed) {
                            showLoader();
                            $.ajax({
                                url: `/admin/delete/product/${productId}`,
                                type: 'DELETE',
                                success: function (response) {
                                    hideLoader();
                                    if (response.success) {
                                        Swal.fire(
                                            'Deleted!',
                                            'Your product has been deleted.',
                                            'success'
                                        ).then(() => {
                                            location.reload(); // Reload the page
                                        });
                                    } else {
                                        Swal.fire(
                                            'Error!',
                                            response.message,
                                            'error'
                                        );
                                    }
                                },
                                error: function (xhr, status, error) {
                                    hideLoader();
                                    console.error('Error deleting product:', error);
                                    Swal.fire(
                                        'Error!',
                                        'An error occurred while deleting the product.',
                                        'error'
                                    );
                                }
                            });
                        }
                    });
                }

                // Multiple Product Delete
                $(document).ready(function () {
                    // Select all checkboxes
                    $('#selectAll').change(function () {
                        $('.product-checkbox').prop('checked', $(this).prop('checked'));
                    });

                    // Handle "Delete Selected" button click
                    $('#deleteSelectedBtn').click(function () {
                        const selectedProducts = $('.product-checkbox:checked')
                            .map(function () {
                                return this.value; // Get the _id of selected products
                            })
                            .get();

                        if (selectedProducts.length === 0) {
                            Swal.fire('No Products Selected', 'Please select products to delete.', 'info');
                            return;
                        }

                        Swal.fire({
                            title: 'Are you sure?',
                            text: `You are about to delete ${selectedProducts.length} product(s). This action cannot be undone.`,
                            icon: 'warning',
                            showCancelButton: true,
                            confirmButtonColor: '#3085d6',
                            cancelButtonColor: '#d33',
                            confirmButtonText: 'Yes, delete them!'
                        }).then((result) => {
                            if (result.isConfirmed) {
                                showLoader();
                                $.ajax({
                                    url: '/admin/delete/products', // Backend endpoint for bulk deletion
                                    type: 'DELETE',
                                    contentType: 'application/json',
                                    data: JSON.stringify({ productIds: selectedProducts }),
                                    success: function (response) {
                                        hideLoader();
                                        if (response.success) {
                                            Swal.fire('Deleted!', 'The selected products have been deleted.', 'success').then(() => {
                                                location.reload();
                                            });
                                        } else {
                                            Swal.fire('Error!', response.message, 'error');
                                        }
                                    },
                                    error: function (xhr, status, error) {
                                        hideLoader();
                                        console.error('Error deleting products:', error);
                                        Swal.fire('Error!', 'An error occurred while deleting the products.', 'error');
                                    }
                                });
                            }
                        });
                    });
                });
            </script>
</body>

</html>