<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>View Order - KharidLow</title>
    <link rel="icon" type="image/x-icon" href="/assets/Kharidlow.ico">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" />
    <link rel="stylesheet" href="/styles/adminHeader.css">
    <link rel="stylesheet" href="/styles/viewOrderAdmin.css">
</head>

<body>
    <%- include("../partials/admin-header.ejs"); %>
        <div class="container order-container">
            <!-- Order Information -->
            <div class="order-info text-center">
                <div class="order-number">Order No. #<%= order.orderNumber %>
                </div>
                <div class="order-date">Order Date: <%= order.createdAt.toDateString() %>
                </div>
                <div class="fullName">Customer <%= order.userId.fullName %>
                </div>
                <div class="fullName">Status:
                    <% if(order.status=="delivered" ) { %>
                        <span class="badge rounded-pill text-bg-success fs-6">
                            <%= order.status %>
                        </span>
                        <%} else if(order.status=="pending" ) {%>
                            <span class="badge rounded-pill text-bg-warning fs-6">
                                <%= order.status %>
                            </span>
                            <%} else {%>
                                <span class="badge rounded-pill text-bg-info fs-6">
                                    <%= order.status %>
                                </span>
                                <%} %>
                </div>
            </div>

            <hr class="hr-line">

            <!-- Items List -->
            <div class="order-items text-center mb-4">
                <h3>Items Ordered</h3>
                <hr class="hr-line">
                <div class="items-list">
                    <% order.orderItems.forEach(item=> { %>
                        <div class="item-card">
                            <img src="/uploads/<%= item.productId.mainImage %>" alt="<%= item.productName %>"
                                class="item-image img-thumbnail" data-bs-toggle="modal" data-bs-target="#imageModal"
                                onclick="openImageModal('/uploads/<%= item.productId.mainImage %>', '<%= item.productName %>')">
                            <div class="item-details d-flex flex-column">
                                <div>
                                    <span class="badge badge-product fs-5 my-1">
                                        <%= item.productName %>
                                    </span>
                                </div>
                                <div>
                                    <span class="badge badge-info text-bg-info my-1">Quantity: <%= item.quantity %>
                                    </span>
                                    <span class="badge badge-info text-bg-info my-1">Price: &#8377; <%= item.price %>
                                    </span>
                                </div>
                            </div>
                        </div>
                        <% }) %>
                </div>
            </div>

            <hr class="hr-line">

            <!-- Total -->
            <div class="order-info text-center">
                <div class="order-total">Total: &#8377; <%= order.grandTotal %>
                </div>
                <div class="address">Delivery Address: <br>
                    <%= order.shippingAddress.flatNo %>, <%= order.shippingAddress.streetNo %>,
                            <%= order.shippingAddress.area %>, <%= order.shippingAddress.state %>,
                                    <%= order.shippingAddress.pincode %>
                </div>
            </div>
        </div>

        <!-- Image Modal -->
        <div class="modal fade" id="imageModal" tabindex="-1" aria-labelledby="imageModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="imageModalLabel">Product Image</h5>
                        <button type="button" class="btn-close custom-close" data-bs-dismiss="modal"
                            aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <img id="modalImage" src="" class="img-fluid" alt="Product Image">
                    </div>
                </div>
            </div>
        </div>

        <div class="offcanvas offcanvas-end bg-dark text-light" data-bs-scroll="true" tabindex="-1"
            id="offcanvasWithBothOptions" aria-labelledby="offcanvasWithBothOptionsLabel">
            <div class="container">
                <div class="offcanvas-header">
                    <img src="/assets/KharidLow.png" alt="" width="50">
                    <h4 class="offcanvas-title mx-2" id="offcanvasWithBothOptionsLabel">KharidLow</h4>
                    <button type="button" class="btn-close btn-dark" data-bs-dismiss="offcanvas"
                        aria-label="Close"></button>
                </div>
                <div class="offcanvas-body d-flex flex-column">
                    <a href="/admin/manage/orders" class="sidebar-item d-flex align-items-center my-2">
                        <i class="fa-solid fa-box mx-2"></i>
                        <span>Manage Order</span>
                    </a>
                    <a href="/admin/manage/customers" class="sidebar-item d-flex align-items-center my-2">
                        <i class="fa-solid fa-users mx-2"></i>
                        <span>Manage Customer</span>
                    </a>
                    <a href="/admin/manage/products" class="sidebar-item d-flex align-items-center my-2">
                        <i class="fa-solid fa-rectangle-list mx-2"></i>
                        <span>Manage Products</span>
                    </a>
                    <a href="/admin/manage" class="sidebar-item d-flex align-items-center my-2">
                        <i class="fa-solid fa-chart-line mx-2"></i>
                        <span>Dashboard</span>
                    </a>
                </div>
            </div>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
        <script>
            function openImageModal(imageSrc, productName) {
                document.getElementById('modalImage').src = imageSrc;
                document.getElementById('imageModalLabel').innerText = productName;
            }
        </script>

</body>

</html>