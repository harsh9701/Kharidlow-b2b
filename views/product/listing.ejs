<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Product Listing - Kharidlow</title>
    <link rel="icon" type="image/x-icon" href="/assets/Kharidlow.ico">
    <link rel="stylesheet" href="/styles/style.css">
    <link rel="stylesheet" href="/styles/navbar.css">
    <link rel="stylesheet" href="/styles/footer.css">
    <link rel="stylesheet" href="/styles/listing.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/sweetalert/2.1.2/sweetalert.min.js"></script>
</head>

<body>

    <!-- include navbar -->
    <%- include("../partials/navbar.ejs") %>

        <!-- Main Container -->
        <div class="container mt-4">
            <div class="row">

                <!-- Sidebar Filters -->
                <aside class="col-lg-3 col-md-4">
                    <div class="filter-sidebar">
                        <!-- <h5>Categories</h5>
                        <ul class="list-unstyled">
                            <li><a href="#">Clothing Accessories</a></li>
                            <li><a href="#">Socks</a></li>
                            <li><a href="#">Belts</a></li>
                             Add more categories as needed
                        </ul> -->

                        <h5 class="mt-4">Filter by Price</h5>
                        <form>
                            <div class="mb-3">
                                <label for="min-price" class="form-label">Min Price</label>
                                <input type="number" class="form-control" id="min-price" placeholder="Min">
                            </div>
                            <div class="mb-3">
                                <label for="max-price" class="form-label">Max Price</label>
                                <input type="number" class="form-control" id="max-price" placeholder="Max">
                            </div>
                            <button type="submit" class="btn btn-primary w-100">Apply</button>
                        </form>
                    </div>
                </aside>

                <!-- Product Listing Grid -->
                <div class="col-lg-9 col-md-8">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h2>Clothing Accessories</h2>
                        <select class="form-select w-auto">
                            <option>Default Sorting</option>
                            <option>Price: Low to High</option>
                            <option>Price: High to Low</option>
                            <option>Newest</option>
                        </select>
                    </div>

                    <!-- Product Grid -->
                    <div id="product-list" class="row">
                        <% products.forEach(product=> { %>
                            <div class="col-lg-4 col-sm-6 col-6 mb-4">
                                <div class="card product-card h-100">
                                    <a href="/product/<%= product._id %>"><img src="/uploads/<%= product.mainImage %>" class="card-img-top"
                                        alt="Product Image"></a>
                                    <div class="card-body d-flex flex-column">
                                        <h5 class="card-title">
                                            <%= product.productName %>
                                        </h5>
                                        <div class="d-flex justify-content-between">
                                            <p class="card-text">Price: <%= product.price %>
                                            </p>
                                            <p class="card-text">MOQ: <%= product.moq %>
                                            </p>
                                        </div>
                                        <button class="btn add-to-cart-btn mt-auto" data-product-id="<%= product._id %>"
                                            data-moq="<%= product.moq %>">Add to cart</button>
                                    </div>
                                </div>
                            </div>
                            <% }); %>
                    </div>

                    <!-- Pagination -->
                    <nav class="mt-4">
                        <ul id="pagination-controls" class="pagination justify-content-center">
                            <!-- Previous Button -->
                            <li class="page-item <%= (currentPage === 1) ? 'disabled' : '' %>">
                                <a class="page-link"
                                    href="/product?page=<%= currentPage - 1 %>&pageSize=24">Previous</a>
                            </li>

                            <% const totalPages=Math.ceil(totalProducts / 24); const maxPagesToShow=2; let
                                startPage=Math.max(currentPage - 2, 1); let endPage=Math.min(currentPage + 2,
                                totalPages); if (endPage - startPage < maxPagesToShow - 1) { if (startPage===1) {
                                endPage=Math.min(startPage + maxPagesToShow - 1, totalPages); } else if
                                (endPage===totalPages) { startPage=Math.max(endPage - maxPagesToShow + 1, 1); } } for
                                (let i=startPage; i <=endPage; i++) { %>
                                <li class="page-item <%= (i === currentPage) ? 'active' : '' %>">
                                    <a class="page-link" href="/product?page=<%= i %>&pageSize=24">
                                        <%= i %>
                                    </a>
                                </li>
                                <% } %>

                                    <!-- Max Page Indicator -->
                                    <li class="page-item disabled">
                                        <span class="page-link">of <%= totalPages %></span>
                                    </li>

                                    <!-- Next Button -->
                                    <li class="page-item <%= (currentPage === totalPages) ? 'disabled' : '' %>">
                                        <a class="page-link"
                                            href="/product?page=<%= currentPage + 1 %>&pageSize=24">Next</a>
                                    </li>
                        </ul>
                    </nav>

                </div>
            </div>
        </div>

        <!-- include footer -->
        <%- include("../partials/footer.ejs") %>

            <!-- Bootstrap 5 JS -->
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/js/bootstrap.bundle.min.js"></script>
            <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
            <script>
                $(document).ready(function () {
                    $('.add-to-cart-btn').on('click', function (event) {
                        event.preventDefault();

                        const productId = $(this).data('product-id');
                        const moq = $(this).data('moq');

                        $.ajax({
                            url: '/user/cart',
                            method: 'POST',
                            contentType: 'application/json',
                            data: JSON.stringify({ productId: productId, moq: moq }),
                            success: function (response) {
                                if (response.success) {
                                    swal("Fantastic!", "Product added to cart successfully!", "success");
                                } else {
                                    if (response.reason) {
                                        swal("Oops!", "Please login!", "error").then(() => {
                                            window.location.href = '/user/login';
                                        });;
                                    } else {
                                        swal("Oops!", "Something went wrong!", "error");
                                    }
                                }
                            },
                            error: function (xhr, status, error) {
                                swal("Oops!", error, "error");
                            }
                        });
                    });
                });
            </script>

</body>

</html>