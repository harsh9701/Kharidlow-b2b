<!DOCTYPE html>
<html lang="en">

<head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-SNMCFJBC49"></script>
    <script>
        window.dataLayer = window.dataLayer || [];
        function gtag() { dataLayer.push(arguments); }
        gtag('js', new Date());

        gtag('config', 'G-SNMCFJBC49');
    </script>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= productDetails.productName %> - Kharidlow
    </title>
    <link rel="icon" type="image/x-icon" href="/assets/Kharidlow.ico">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
    <link rel="stylesheet" href="/styles/product.css">
    <link rel="stylesheet" href="/styles/rating.css">
    <link rel="stylesheet" href="/styles/navbar.css">
    <link rel="stylesheet" href="/styles/footer.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/sweetalert/2.1.2/sweetalert.min.js"></script>
    <!-- Meta Pixel Code -->
    <script>
        !function (f, b, e, v, n, t, s) {
            if (f.fbq) return; n = f.fbq = function () {
                n.callMethod ?
                    n.callMethod.apply(n, arguments) : n.queue.push(arguments)
            };
            if (!f._fbq) f._fbq = n; n.push = n; n.loaded = !0; n.version = '2.0';
            n.queue = []; t = b.createElement(e); t.async = !0;
            t.src = v; s = b.getElementsByTagName(e)[0];
            s.parentNode.insertBefore(t, s)
        }(window, document, 'script',
            'https://connect.facebook.net/en_US/fbevents.js');
        fbq('init', '979296231081207');
        fbq('track', 'PageView');
    </script>
    <noscript><img height="1" width="1" style="display:none"
            src="https://www.facebook.com/tr?id=979296231081207&ev=PageView&noscript=1" /></noscript>
    <!-- End Meta Pixel Code -->
</head>

<body>

    <!-- include navbar -->
    <%- include("../includes/navbar.ejs") %>

        <div class="content-container">
            <div class="container my-2">
                <div class="row product-details">
                    <div class="col-md-6">
                        <!-- Product Image -->
                        <img id="mainImage" src="<%= productDetails.mainImage %>" alt="Product Image"
                            class="product-img">
                        <% if((productDetails.productImages).length> 0){ %>
                            <div class="gallery-thumbnails">
                                <img src="<%= productDetails.mainImage %>" alt="Image" class="thumbnail active"
                                    onclick="changeImage(this)">
                                <% productDetails.productImages.forEach((image)=> { %>
                                    <img src="<%= image %>" alt="<%= image %>" class="thumbnail"
                                        onclick="changeImage(this)">
                                    <% }) %>
                            </div>
                            <% } %>
                    </div>
                    <div class="col-md-6">
                        <!-- Product Info -->
                        <h1 class="product-title">
                            <%= productDetails.productName %>
                        </h1>
                        <span class="category-badge">
                            <%= productDetails.subCategory %>
                        </span>
                        <p class="product-price"><strong>&#8377;<%= productDetails.price %>
                                    <% if(productDetails.taxType=="inclusive" ) { %> <span
                                            style="font-size: 14px;">(Inc.
                                            GST@<%= productDetails.taxRate %>%)</span>
                                        <% } else { %> <span style="font-size: 14px;">(Excl. GST@<%=
                                                    productDetails.taxRate %>%)</span>
                                            <% } %></strong></p>

                        <!-- Quantity Controls -->
                        <div class="quantity-control my-3">
                            <span type="button" id="decreaseQty"><i class="fa-solid fa-minus"></i></span>
                            <!-- <button class="btn btn-outline-secondary" id="decreaseQty">-</button> -->
                            <input type="number" id="productQty" class="form-control quantity-input"
                                value="<%= productDetails.moq %>" min="<%= productDetails.moq %>">
                            <!-- <button class="btn btn-outline-secondary" id="increaseQty">+</button> -->
                            <span type="button" id="increaseQty"><i class="fa-solid fa-plus"></i></span>
                        </div>

                        <!-- Add to Cart Button -->
                        <button class="btn btn-primary btn-lg add-to-cart-btn"
                            data-product-id="<%= productDetails._id %>"><i class="fas fa-shopping-cart"></i>
                            <span class="btn-text">Add to cart</span>
                            <span class="spinner-border spinner-border-sm d-none ms-2" role="status"></span>
                        </button>

                        <!-- Product Description -->
                        <div class="product-description">
                            <h3 class="description-title">Product Description</h3>
                            <p class="description-text">
                                <%= productDetails.description %>
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Review Section -->
                <section class="reviews-section mt-4">
                    <h2 class="section-title">Customer Reviews</h2>
                    <div class="review-list">
                        <% if((productDetails.reviews).length> 0) { %>
                            <% productDetails.reviews.forEach((review)=> { %>
                                <div class="review-card">
                                    <h6 class="reviewer-name">
                                        <%= review.user.fullName %>
                                    </h6>
                                    <div class="review-stars mb-2">
                                        <% for(let i=0; i<review.rating; i++) { %>
                                            <i class="fas fa-star"></i>
                                            <% } %>
                                                <span>(<%= review.rating %>)</span>
                                    </div>
                                    <p class="review-comment">
                                        <%= review.comment %>
                                    </p>
                                </div>
                                <% }) %>
                                    <% } else { %>
                                        <div>No reviews</div>
                                        <% } %>
                    </div>

                    <!-- Add a Review -->
                    <hr class="divider-line">
                    <div class="review-form-section my-4">
                        <h5>Leave a Review</h5>
                        <form id="reviewForm">
                            <!-- Star Rating Input -->
                            <fieldset class="starability-slot">
                                <input type="radio" id="no-rate" class="input-no-rate" name="rating" value="0" checked
                                    aria-label="No rating." />
                                <input type="radio" id="first-rate1" name="rating" value="1" />
                                <label for="first-rate1" title="Terrible">1 star</label>
                                <input type="radio" id="first-rate2" name="rating" value="2" />
                                <label for="first-rate2" title="Not good">2 stars</label>
                                <input type="radio" id="first-rate3" name="rating" value="3" />
                                <label for="first-rate3" title="Average">3 stars</label>
                                <input type="radio" id="first-rate4" name="rating" value="4" />
                                <label for="first-rate4" title="Very good">4 stars</label>
                                <input type="radio" id="first-rate5" name="rating" value="5" />
                                <label for="first-rate5" title="Amazing">5 stars</label>
                            </fieldset>

                            <!-- Review Text -->
                            <textarea class="form-control mb-2" name="comment" rows="3"
                                placeholder="Share your experience with this product..."></textarea>

                            <button type="submit" class="btn btn-primary review-btn"><i class="fas fa-paper-plane"></i>
                                Submit Review</button>
                        </form>
                    </div>
                </section>
            </div>

            <!-- Suggested Products Section -->
            <% if(suggestedProducts.length> 0) { %>
                <section class="suggested-products mt-5">
                    <h4 class="text-center">Suggested Products</h4>
                    <div class="suggested-products-container">
                        <div class="row">
                            <% suggestedProducts.forEach((product)=> { %>
                                <div class="col-6 col-sm-4 col-md-4 col-lg-3 mb-3">
                                    <div class="card">
                                        <div class="card-img-container">
                                            <a href="/product/<%= product._id %>"><img src="<%= product.mainImage %>"
                                                    class="card-img-top" alt="<%= product.productName %>"></a>
                                        </div>
                                        <div class="card-body">
                                            <h5 class="card-title">
                                                <%= product.productName %>
                                            </h5>
                                            <div class="d-flex justify-content-between">
                                                <p class="card-text"><span class="price">Price: </span>&#8377; <%=
                                                        product.price %>
                                                        <p class="card-text">MOQ: <%= product.moq %>
                                            </div>
                                            <button class="btn btn-primary add-to-cart-btn-card"
                                                data-product-id="<%= product._id %>" data-moq="<%= product.moq %>">Add
                                                to
                                                Cart</button>
                                        </div>
                                    </div>
                                </div>
                                <% }) %>
                        </div>
                    </div>
                </section>
                <% } %>

                    <!-- Retailers Choice Products Section -->
                    <% if(retailersChoiceProducts.length> 0) { %>
                        <section class="suggested-products mt-2">
                            <h4 class="text-center">Retailers’ Top Picks</h4>
                            <div class="retailers-products-container">
                                <div class="row">
                                    <% retailersChoiceProducts.forEach((product)=> { %>
                                        <div class="col-6 col-sm-4 col-md-4 col-lg-3 mb-3">
                                            <div class="card">
                                                <div class="card-img-container">
                                                    <a href="/product/<%= product._id %>"><img
                                                            src="<%= product.mainImage %>" class="card-img-top"
                                                            alt="<%= product.productName %>"></a>
                                                </div>
                                                <div class="card-body">
                                                    <h5 class="card-title">
                                                        <%= product.productName %>
                                                    </h5>
                                                    <div class="d-flex justify-content-between">
                                                        <p class="card-text"><span class="price">Price: </span>&#8377;
                                                            <%= product.price %>
                                                                <p class="card-text">MOQ: <%= product.moq %>
                                                    </div>
                                                    <button class="btn btn-primary add-to-cart-btn-card"
                                                        data-product-id="<%= product._id %>"
                                                        data-moq="<%= product.moq %>">Add
                                                        to
                                                        Cart</button>
                                                </div>
                                            </div>
                                        </div>
                                        <% }) %>
                                </div>
                            </div>
                        </section>
                        <% } %>
        </div>

        <!-- include footer -->
        <%- include("../includes/footer.ejs") %>

            <!-- Bootstrap JS -->
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
            <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
            <script>
                // Quantity control logic
                const decreaseQty = document.getElementById('decreaseQty');
                const increaseQty = document.getElementById('increaseQty');
                const productQty = document.getElementById('productQty');
                const minQty = parseInt(productQty.min); // Get the minimum quantity

                decreaseQty.addEventListener('click', () => {
                    let currentQty = parseInt(productQty.value);
                    if (currentQty > minQty) {
                        productQty.value = currentQty - minQty;
                    }
                });

                increaseQty.addEventListener('click', () => {
                    let currentQty = parseInt(productQty.value);
                    productQty.value = currentQty + minQty;
                });

                // Add to Cart logic with AJAX
                $('.add-to-cart-btn').on('click', function (event) {
                    event.preventDefault();

                    const $btn = $(this);
                    const $btnText = $btn.find('.btn-text');
                    const $loader = $btn.find('.spinner-border');

                    const productId = $(this).data('product-id');
                    const quantity = $('#productQty').val();

                    if (quantity < minQty) {
                        swal("Oops!", "Quantity cannot be below the minimum order quantity.", "error");
                        $('#productQty').val(minQty);
                        return;
                    }

                    // Disable button & show loader
                    $btn.prop('disabled', true);
                    $btnText.text('Adding...');
                    $loader.removeClass('d-none');

                    $.ajax({
                        url: '/user/cart',
                        method: 'POST',
                        contentType: 'application/json',
                        data: JSON.stringify({ productId: productId, moq: quantity }),
                        success: function (response) {
                            if (response.success) {
                                swal("Fantastic!", "Product added to cart successfully!", "success");
                                document.querySelectorAll('.cartCount').forEach(el => {
                                    el.innerText = response.cart.items.length;
                                });
                                resetButton($btn, $btnText, $loader);
                            } else {
                                if (response.reason) {
                                    swal("Oops!", "Please login!", "error").then(() => {
                                        window.location.href = '/user/login';
                                    });
                                } else {
                                    swal("Oops!", "Something went wrong!", "error");
                                }
                                resetButton($btn, $btnText, $loader);
                            }
                        },
                        error: function (xhr, status, error) {
                            swal("Oops!", "An error occurred while adding to cart.", "error");
                        }
                    });
                });

                function resetButton($btn, $btnText, $loader) {
                    $btn.prop('disabled', false);
                    $btnText.text('Add to cart');
                    $loader.addClass('d-none');
                    $btn.removeClass('btn-success');
                }

                $('#reviewForm').on('submit', function (event) {
                    event.preventDefault();

                    const rating = $('input[name="rating"]:checked').val();
                    const comment = $('textarea[name="comment"]').val();

                    console.log(rating);

                    if (rating == 0) {
                        swal("Oops!", "Please select a star rating!", "warning");
                        return;
                    }

                    if (!comment) {
                        swal("Oops!", "Please write a review!", "warning");
                        return;
                    }

                    // Perform AJAX to submit the review
                    $.ajax({
                        url: '/product/review',
                        method: 'POST',
                        contentType: 'application/json',
                        data: JSON.stringify({ rating: rating, comment: comment, productId: '<%= productDetails._id %>' }),
                        success: function (response) {
                            if (response.success) {
                                swal("Thank you!", "Your review has been submitted!", "success");
                            } else {
                                console.log(response);
                                swal("Oops!", response.message, "error");
                            }
                        },
                        error: function () {
                            swal("Oops!", "An error occurred while submitting the review.", "error");
                        }
                    });
                });

                $('.add-to-cart-btn-card').on('click', function (event) {
                    event.preventDefault();

                    const productId = $(this).data('product-id');
                    const moq = $(this).data('moq');

                    $.ajax({
                        url: '/user/cart',
                        method: 'POST',
                        contentType: 'application/json',
                        data: JSON.stringify({ productId: productId, moq: moq }),
                        success: function (response) {
                            if (response.success) {
                                swal("Fantastic!", "Product added to cart successfully!", "success");
                            } else {
                                if (response.reason) {
                                    swal("Oops!", "Please login!", "error").then(() => {
                                        window.location.href = '/user/login';
                                    });;
                                } else {
                                    swal("Oops!", "Something went wrong!", "error");
                                }
                            }
                        },
                        error: function (xhr, status, error) {
                            swal("Oops!", error, "error");
                        }
                    });
                });

                // Image gallery
                function changeImage(element) {
                    document.getElementById('mainImage').src = element.src;

                    // Update active state
                    document.querySelectorAll('.thumbnail').forEach(thumb => {
                        thumb.classList.remove('active');
                    });
                    element.classList.add('active');
                }

                // Smooth scroll
                document.querySelectorAll('a[href^="#"]').forEach(anchor => {
                    anchor.addEventListener('click', function (e) {
                        e.preventDefault();
                        document.querySelector(this.getAttribute('href')).scrollIntoView({
                            behavior: 'smooth'
                        });
                    });
                });

            </script>
</body>

</html>