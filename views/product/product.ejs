<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Product - Kharidlow</title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <link rel="stylesheet" href="/styles/style.css">
    <link rel="stylesheet" href="/styles/navbar.css">
    <link rel="stylesheet" href="/styles/footer.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/sweetalert/2.1.2/sweetalert.min.js"></script>
</head>

<body>

    <!-- Include Navbar -->
    <%- include("../partials/navbar.ejs") %>

        <div class="container my-5">
            <div class="row">
                <div class="col-md-6">
                    <img src="/uploads/<%= productDetails.mainImage %>" alt="Product Image" class="img-fluid" />
                </div>
                <div class="col-md-6">
                    <h2 class="product-title">
                        <%= productDetails.productName %>
                    </h2>
                    <p class="text-muted">Category: <span class="badge badge-info">
                            <%= productDetails.subCategory %>
                        </span></p>
                    <p class="product-price">&#8377; <%= productDetails.price %>
                    </p>
                    <p class="product-description">
                        <%= productDetails.description %>
                    </p>
                    <div class="d-flex align-items-center">
                        <input type="number" id="moq" class="form-control w-25 me-2" value="<%= productDetails.moq %>"
                            min="<%= productDetails.moq %>" />
                        <button class="btn btn-success add-to-cart-btn" data-product-id="<%= productDetails._id %>">Add to Cart</button>
                    </div>
                </div>
            </div>

            <hr class="my-5">

            <h3>Suggested Products</h3>
            <div class="row">
                <% if (suggestedProducts.length> 0) { %>
                    <% suggestedProducts.forEach((item)=> { %>
                        <div class="col-md-4 mb-4">
                            <div class="card">
                                <img src="/uploads/<%= item.mainImage %>" class="card-img-top"
                                    alt="Suggested Product 1">
                                <div class="card-body">
                                    <h5 class="card-title">
                                        <%= item.productName %>
                                    </h5>
                                    <p class="card-text">&#8377; <%= item.price %>
                                    </p>
                                    <a href="/product/<%= item._id %>" class="btn btn-primary">View Product</a>
                                </div>
                            </div>
                        </div>
                        <% }); %>
                            <% } %>
            </div>
        </div>

        <!-- Include Footer -->
        <%- include("../partials/footer.ejs") %>

            <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
            <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.6/dist/umd/popper.min.js"></script>
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/js/bootstrap.bundle.min.js"></script>
            <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
            <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
            <script>
                $(document).ready(function () {
                    $('.add-to-cart-btn').on('click', function (event) {
                        event.preventDefault();

                        const productId = $(this).data('product-id');
                        const moq = $('#moq').val();

                        $.ajax({
                            url: '/user/cart',
                            method: 'POST',
                            contentType: 'application/json',
                            data: JSON.stringify({ productId: productId, moq: moq }),
                            success: function (response) {
                                if (response.success) {
                                    swal("Fantastic!", "Product added to cart successfully!", "success");
                                } else {
                                    if (response.reason) {
                                        swal("Oops!", "Please login!", "error").then(() => {
                                            window.location.href = '/user/login';
                                        });;
                                    } else {
                                        swal("Oops!", "Something went wrong!", "error");
                                    }
                                }
                            },
                            error: function (xhr, status, error) {
                                swal("Oops!", error, "error");
                            }
                        });
                    });
                });
            </script>
</body>

</html>