<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Product Listing - Kharidlow</title>
    <link rel="icon" type="image/x-icon" href="/assets/Kharidlow.ico">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/sweetalert/2.1.2/sweetalert.min.js"></script>
    <link rel="stylesheet" href="/styles/navbar.css">
    <link rel="stylesheet" href="/styles/footer.css">
    <link rel="stylesheet" href="/styles/listing.css">
    <!-- Meta Pixel Code -->
    <script>
        !function (f, b, e, v, n, t, s) {
            if (f.fbq) return; n = f.fbq = function () {
                n.callMethod ?
                    n.callMethod.apply(n, arguments) : n.queue.push(arguments)
            };
            if (!f._fbq) f._fbq = n; n.push = n; n.loaded = !0; n.version = '2.0';
            n.queue = []; t = b.createElement(e); t.async = !0;
            t.src = v; s = b.getElementsByTagName(e)[0];
            s.parentNode.insertBefore(t, s)
        }(window, document, 'script',
            'https://connect.facebook.net/en_US/fbevents.js');
        fbq('init', '979296231081207');
        fbq('track', 'PageView');
    </script>
    <noscript><img height="1" width="1" style="display:none"
            src="https://www.facebook.com/tr?id=979296231081207&ev=PageView&noscript=1" /></noscript>
    <!-- End Meta Pixel Code -->
</head>

<body>

    <!-- include navbar -->
    <%- include("../includes/navbar.ejs") %>

        <!-- Header Section -->
        <div class="products-header">
            <div class="container">
                <div class="text-center">
                    <h1>
                        <%= categories.name %> Items
                    </h1>
                </div>
            </div>
        </div>

        <!-- Main Container -->
        <div class="container mt-2">
            <div class="row">

                <!-- Mobile Filter Toggle -->
                <div class="col-12 d-lg-none">
                    <div class="mobile-filter-toggle">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h5 class="mb-0"><i class="fas fa-filter me-2"></i>Filters</h5>
                            <button class="btn btn-outline-secondary btn-sm" id="toggleFilters">
                                <i class="fas fa-sliders-h me-2"></i>Show Filters
                            </button>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <small class="text-muted">Category: <span id="selectedCategoryMobile">All
                                    Products</span></small>
                            <small class="text-muted" id="activePriceFilterMobile"></small>
                        </div>
                    </div>
                </div>

                <!-- Sidebar Filters -->
                <aside class="col-lg-3 col-md-4">
                    <div class="filters-container" id="filtersContainer">
                        <div class="filter-header">
                            <i class="fas fa-filter me-2"></i>Filter Products
                        </div>

                        <!-- Category Filter -->
                        <div class="filter-section">
                            <h5><i class="fas fa-tags me-2"></i>Categories</h5>
                            <div class="scrollable-category-list">
                                <ul class="category-list">
                                    <li>
                                        <a href="/category/<%= categories._id %>" class="category-link">
                                            <i class="fas fa-th-large"></i>
                                            All <%= categories.name %> items
                                        </a>
                                    </li>
                                    <% if(categories && categories.subcategories.length> 0) { %>
                                        <% categories.subcategories.forEach((category)=> { %>
                                            <li>
                                                <a href="/category/<%= categories._id %>?category=<%= encodeURIComponent(category.name) %>"
                                                    class="category-link">
                                                    <i class="fa-solid fa-location-arrow"></i>
                                                    <%= category.name %>
                                                </a>
                                            </li>
                                            <% }) %>
                                                <% } %>
                                </ul>
                            </div>
                        </div>

                        <!-- Price Filter -->
                        <div class="filter-section">
                            <h5>Price Range</h5>
                            <div class="price-inputs">
                                <input type="number" class="price-input" id="minPrice" value="<%= minPrice %>"
                                    placeholder="Min ₹" min="0">
                                <input type="number" class="price-input" id="maxPrice" value="<%= maxPrice %>"
                                    placeholder="Max ₹" min="0">
                            </div>
                            <!-- <div class="price-presets">
                                <span class="price-preset" data-min="0" data-max="500">Under ₹500</span>
                                <span class="price-preset" data-min="500" data-max="1000">₹500-1K</span>
                                <span class="price-preset" data-min="1000" data-max="2000">₹1K-2K</span>
                                <span class="price-preset" data-min="2000" data-max="5000">₹2K-5K</span>
                                <span class="price-preset" data-min="5000" data-max="">₹5K+</span>
                            </div> -->
                            <button type="button" class="btn filter-btn w-100 mb-2" id="applyPriceFilter">
                                <i class="fas fa-check me-2"></i>Apply Filter
                            </button>
                            <div class="text-center">
                                <a href="#" class="clear-filters" id="clearPriceFilter">
                                    <i class="fas fa-times me-1"></i>Clear Price Filter
                                </a>
                            </div>
                        </div>

                        <!-- Clear All Filters -->
                        <div class="filter-section">
                            <button type="button" class="btn btn-outline-secondary w-100" id="clearAllFilters">
                                <i class="fas fa-refresh me-2"></i>Clear All Filters
                            </button>
                        </div>
                    </div>
                </aside>

                <!-- Product Listing Grid -->
                <div class="col-lg-9 col-md-8">
                    <!-- Product Grid -->
                    <div id="product-list" class="row">
                        <% if(products && products.length> 0) { %>
                            <% products.forEach(product=> { %>
                                <div class="col-lg-4 col-sm-6 col-6 mb-4">
                                    <div class="card product-card h-100">
                                        <a href="/product/<%= product._id %>"><img src="<%= product.mainImage %>"
                                                class="card-img-top" alt="Product Image"></a>
                                        <div class="card-body d-flex flex-column">
                                            <h5 class="card-title">
                                                <%= product.productName %>
                                            </h5>
                                            <div class="d-flex justify-content-between">
                                                <p class="card-text">Price: &#8377;<%= product.price %>
                                                </p>
                                                <p class="card-text">MOQ: <%= product.moq %>
                                                </p>
                                            </div>
                                            <button class="btn add-to-cart-btn mt-auto"
                                                data-product-id="<%= product._id %>" data-moq="<%= product.moq %>">Add
                                                to cart</button>
                                        </div>
                                    </div>
                                </div>
                                <% }); %>
                                    <% } else { %>
                                        <div class="alert alert-primary fs-4 text-center" role="alert">
                                            No products available right now
                                        </div>
                                        <% } %>
                    </div>

                    <!-- Pagination -->
                    <nav class="mt-4">
                        <ul id="pagination-controls" class="pagination justify-content-center">
                            <!-- Previous Button -->
                            <li class="page-item <%= (currentPage === 1) ? 'disabled' : '' %>">
                                <a class="page-link"
                                    href="/category/<%= categories._id %>?page=<%= currentPage - 1 %>&pageSize=48&category=<%= encodeURIComponent(selectedCategory) %>&minPrice=<%= minPrice || '' %>&maxPrice=<%= maxPrice || '' %>">Previous</a>
                            </li>

                            <% const totalPages=Math.ceil(totalProducts / 48); const maxPagesToShow=2; let
                                startPage=Math.max(currentPage - 2, 1); let endPage=Math.min(currentPage + 2,
                                totalPages); if (endPage - startPage < maxPagesToShow - 1) { if (startPage===1) {
                                endPage=Math.min(startPage + maxPagesToShow - 1, totalPages); } else if
                                (endPage===totalPages) { startPage=Math.max(endPage - maxPagesToShow + 1, 1); } } for
                                (let i=startPage; i <=endPage; i++) { %>
                                <li class="page-item <%= (i === currentPage) ? 'active' : '' %>">
                                    <a class="page-link"
                                        href="/category/<%= categories._id %>?page=<%= i %>&pageSize=48&category=<%= encodeURIComponent(selectedCategory) %>&minPrice=<%= minPrice || '' %>&maxPrice=<%= maxPrice || '' %>">
                                        <%= i %>
                                    </a>
                                </li>
                                <% } %>

                                    <!-- Max Page Indicator -->
                                    <li class="page-item disabled">
                                        <span class="page-link">of <%= totalPages %></span>
                                    </li>

                                    <!-- Next Button -->
                                    <li class="page-item <%= (currentPage === totalPages) ? 'disabled' : '' %>">
                                        <a class="page-link"
                                            href="/category/<%= categories._id %>?page=<%= currentPage + 1 %>&pageSize=48&category=<%= encodeURIComponent(selectedCategory) %>&minPrice=<%= minPrice || '' %>&maxPrice=<%= maxPrice || '' %>">Next</a>
                                    </li>
                        </ul>
                    </nav>


                </div>
            </div>
        </div>

        <!-- include footer -->
        <%- include("../includes/footer.ejs") %>

            <!-- Bootstrap 5 JS -->
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/js/bootstrap.bundle.min.js"></script>
            <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
            <script>
                $(document).ready(function () {
                    // Mobile filter toggle
                    $('#toggleFilters').on('click', function () {
                        $('#filtersContainer').toggleClass('show');
                        const isVisible = $('#filtersContainer').hasClass('show');
                        $(this).html(isVisible ? '<i class="fas fa-times me-2"></i>Hide Filters' : '<i class="fas fa-sliders-h me-2"></i>Show Filters');
                    });

                    //Add to cart
                    $('.add-to-cart-btn').on('click', function (event) {
                        event.preventDefault();

                        const productId = $(this).data('product-id');
                        const moq = $(this).data('moq');

                        $.ajax({
                            url: '/user/cart',
                            method: 'POST',
                            contentType: 'application/json',
                            data: JSON.stringify({ productId: productId, moq: moq }),
                            success: function (response) {
                                if (response.success) {
                                    swal("Fantastic!", "Product added to cart successfully!", "success");
                                } else {
                                    if (response.reason) {
                                        swal("Oops!", "Please login!", "error").then(() => {
                                            window.location.href = '/user/login';
                                        });;
                                    } else {
                                        swal("Oops!", "Something went wrong!", "error");
                                    }
                                }
                            },
                            error: function (xhr, status, error) {
                                swal("Oops!", error, "error");
                            }
                        });
                    });
                });

                function isValidPriceInput(value) {
                    // Must not be empty, must be a number, must be >= 0, must not start with a dot
                    const pattern = /^[0-9]\d*(\.\d{1,2})?$/;
                    return pattern.test(value) && parseFloat(value) >= 0;
                }

                // throw an error when negative value recevied in price filter
                $('#minPrice').on('change', function () {
                    const value = $(this).val();
                    if (!isValidPriceInput(value)) {
                        swal("Oops!", "Price should be positive", "error");
                        $(this).val('');
                    } else {
                        checkPriceRange(); // check min vs max
                    }
                });

                $('#maxPrice').on('change', function () {
                    const value = $(this).val();
                    if (!isValidPriceInput(value)) {
                        swal("Oops!", "Price should be positive", "error");
                        $(this).val('');
                    } else {
                        checkPriceRange(); // check min vs max
                    }
                });

                // Function to check if minPrice > maxPrice
                function checkPriceRange() {
                    const min = parseFloat($('#minPrice').val());
                    const max = parseFloat($('#maxPrice').val());

                    if (!isNaN(min) && !isNaN(max) && min > max) {
                        swal("Invalid Range", "Min Price should not be greater than Max Price", "error");
                        // Optionally clear both inputs or only one
                        $('#minPrice').val('');
                        $('#maxPrice').val('');
                    }
                }

                // Function to get the query parameter value by name
                function getParameterByName(name) {
                    const url = window.location.href;
                    name = name.replace(/[\[\]]/g, "\\$&");
                    const regex = new RegExp("[?&]" + name + "(=([^&#]*)|&|#|$)"),
                        results = regex.exec(url);
                    if (!results) return null;
                    if (!results[2]) return '';
                    return decodeURIComponent(results[2].replace(/\+/g, " "));
                }

                // Get the category parameter from the URL
                const category = getParameterByName('category');
                const minPrice = getParameterByName('minPrice');
                const maxPrice = getParameterByName('maxPrice');

                // Update category display and active state
                if (category) {
                    $('#selectedCategoryMobile').text(category);
                    $('.category-link').each(function () {
                        if ($(this).attr('href').includes(`category=${encodeURIComponent(category)}`)) {
                            $(this).addClass('active');
                        }
                    });
                } else {
                    $('#selectedCategoryMobile').text('All Products');
                    $('.category-link[href="/product"]').addClass('active');
                }

                // Update price inputs with URL values
                if (minPrice) {
                    $('#minPrice').val(minPrice);
                }
                if (maxPrice) {
                    $('#maxPrice').val(maxPrice);
                }

                // Update active filters display
                function updateActiveFilters() {
                    let filters = [];
                    if (category) filters.push(`Category: ${category}`);
                    if (minPrice || maxPrice) {
                        let priceFilter = 'Price: ';
                        if (minPrice && maxPrice) {
                            priceFilter += `₹${minPrice} - ₹${maxPrice}`;
                        } else if (minPrice) {
                            priceFilter += `₹${minPrice}+`;
                        } else if (maxPrice) {
                            priceFilter += `Up to ₹${maxPrice}`;
                        }
                        filters.push(priceFilter);
                    }

                    const filterText = filters.length > 0 ? `Active: ${filters.join(', ')}` : '';
                    $('#activeFilters').text(filterText);
                    $('#activePriceFilterMobile').text(filters.find(f => f.includes('Price:')) || '');
                }

                // Apply Price Filter
                $('#applyPriceFilter').on('click', function () {
                    const min = $('#minPrice').val();
                    const max = $('#maxPrice').val();

                    const url = new URL(window.location.href);
                    if (min !== '') {
                        url.searchParams.set('minPrice', min);
                    } else {
                        url.searchParams.delete('minPrice');
                    }
                    if (max !== '') {
                        url.searchParams.set('maxPrice', max);
                    } else {
                        url.searchParams.delete('maxPrice');
                    }

                    window.location.href = url.toString();
                });

                // Clear Price Filter
                $('#clearPriceFilter').on('click', function (e) {
                    e.preventDefault();

                    const url = new URL(window.location.href);
                    url.searchParams.delete('minPrice');
                    url.searchParams.delete('maxPrice');

                    window.location.href = url.toString();
                });

                // Clear All Filters
                $('#clearAllFilters').on('click', function () {
                    const url = new URL(window.location.href);

                    // Optional: Add any filter keys you might use
                    const filterKeys = ['category', 'minPrice', 'maxPrice'];
                    filterKeys.forEach(key => url.searchParams.delete(key));

                    window.location.href = url.pathname; // Removes all params, loads base URL
                });

                updateActiveFilters();

            </script>

</body>

</html>