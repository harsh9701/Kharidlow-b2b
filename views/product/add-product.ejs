<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Product - Kharidlow</title>
    <link rel="icon" type="image/x-icon" href="/assets/Kharidlow.ico">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
    <link
        href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&family=DM+Mono:wght@400;500&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="/styles/adminPage.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        /* ── Page-specific only ── */

        .form-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            align-items: start;
        }

        .form-full {
            grid-column: 1 / -1;
        }

        /* ── Shared card ── */
        .view-card {
            background: var(--bg3);
            border: 1px solid var(--border);
            border-radius: 14px;
            overflow: hidden;
        }

        .view-card-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 15px 20px;
            border-bottom: 1px solid var(--border);
            gap: 12px;
        }

        .view-card-head h3 {
            font-size: 13.5px;
            font-weight: 600;
            color: var(--text-primary);
            display: flex;
            align-items: center;
            gap: 8px;
            margin: 0;
        }

        .view-card-head h3 i {
            color: var(--accent2);
            font-size: 13px;
        }

        .view-card-body {
            padding: 20px;
            display: flex;
            flex-direction: column;
            gap: 14px;
        }

        /* ── Progress bar ── */
        .progress-wrap {
            height: 3px;
            background: var(--bg4);
            border-radius: 2px;
            overflow: hidden;
            margin-bottom: 20px;
        }

        .progress-bar {
            height: 100%;
            width: 0%;
            background: linear-gradient(90deg, var(--accent), var(--accent2));
            transition: width 0.3s ease;
            border-radius: 2px;
        }

        /* ── Form elements ── */
        .form-group {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .form-label {
            font-size: 11.5px;
            font-weight: 500;
            color: var(--text-secondary);
            letter-spacing: 0.3px;
            text-transform: uppercase;
        }

        .form-input,
        .form-select,
        .form-textarea {
            background: var(--bg4);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 9px 14px;
            color: var(--text-primary);
            font-size: 13.5px;
            font-family: 'DM Sans', sans-serif;
            transition: border-color 0.15s;
            outline: none;
            width: 100%;
        }

        .form-input:focus,
        .form-select:focus,
        .form-textarea:focus {
            border-color: var(--accent);
        }

        .form-input.valid {
            border-color: var(--success);
        }

        .form-input.invalid {
            border-color: var(--danger);
        }

        .form-select option {
            background: var(--bg4);
            color: var(--text-primary);
        }

        .form-textarea {
            resize: vertical;
            min-height: 90px;
        }

        .form-select:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .form-hint {
            font-size: 11.5px;
            color: var(--text-muted);
        }

        .form-error {
            font-size: 11.5px;
            color: var(--danger);
            display: none;
        }

        .form-error.show {
            display: block;
        }

        /* ── Two-col row inside card ── */
        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 14px;
        }

        /* ── Image upload area ── */
        .img-upload-area {
            border: 1.5px dashed var(--border-hover);
            border-radius: 12px;
            padding: 24px;
            text-align: center;
            cursor: pointer;
            transition: border-color 0.15s, background 0.15s;
            background: var(--bg4);
        }

        .img-upload-area:hover {
            border-color: var(--accent);
            background: var(--accent-glow);
        }

        .img-upload-area i {
            font-size: 26px;
            color: var(--text-muted);
            margin-bottom: 8px;
        }

        .img-upload-area p {
            font-size: 13px;
            color: var(--text-muted);
            margin: 0;
        }

        /* ── Image previews ── */
        .main-preview-wrap {
            position: relative;
            border-radius: 10px;
            overflow: hidden;
            border: 1px solid var(--border);
            display: none;
        }

        .main-preview-wrap img {
            width: 100%;
            display: block;
            max-height: 220px;
            object-fit: cover;
        }

        .main-preview-wrap .clear-btn {
            position: absolute;
            top: 8px;
            right: 8px;
            width: 26px;
            height: 26px;
            border-radius: 7px;
            background: rgba(248, 113, 113, 0.85);
            border: none;
            color: #fff;
            font-size: 11px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .add-previews {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-top: 4px;
        }

        .add-preview-item {
            position: relative;
            width: 76px;
            height: 76px;
            border-radius: 8px;
            overflow: hidden;
            border: 1px solid var(--border);
        }

        .add-preview-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        /* ── Submit ── */
        .form-actions {
            display: flex;
            gap: 10px;
            padding: 16px 20px;
            border-top: 1px solid var(--border);
        }

        .btn-submit {
            flex: 1;
            padding: 10px 20px;
            border-radius: 10px;
            background: var(--accent);
            border: none;
            color: #fff;
            font-size: 14px;
            font-weight: 500;
            font-family: 'DM Sans', sans-serif;
            cursor: pointer;
            transition: background 0.15s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .btn-submit:hover {
            background: #5a52e0;
        }

        .btn-submit:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

        .btn-reset {
            padding: 10px 18px;
            border-radius: 10px;
            background: var(--bg4);
            border: 1px solid var(--border);
            color: var(--text-secondary);
            font-size: 14px;
            font-weight: 500;
            font-family: 'DM Sans', sans-serif;
            cursor: pointer;
            transition: all 0.15s;
        }

        .btn-reset:hover {
            border-color: var(--border-hover);
            color: var(--text-primary);
        }

        /* ── Loader ── */
        .spinner-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.55);
            z-index: 300;
            align-items: center;
            justify-content: center;
        }

        .spinner-overlay.show {
            display: flex;
        }

        .spinner {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            border: 3px solid var(--border-hover);
            border-top-color: var(--accent2);
            animation: spin 0.7s linear infinite;
        }

        @keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        /* ── Responsive ── */
        @media (max-width: 900px) {
            .form-grid {
                grid-template-columns: 1fr;
            }

            .form-full {
                grid-column: 1;
            }

            .page-sub {
                display: none;
            }
        }

        @media (max-width: 640px) {
            .form-row {
                grid-template-columns: 1fr;
            }

            .content {
                padding: 16px 12px;
            }

            .topbar {
                height: 56px;
                padding: 0 16px;
            }
        }

        @media (max-width: 420px) {
            .topbar {
                padding: 0 12px;
            }

            .icon-btn {
                width: 32px;
                height: 32px;
            }
        }
    </style>
</head>

<body>

    <!-- Loading Spinner -->
    <div class="spinner-overlay" id="loadingSpinner">
        <div class="spinner"></div>
    </div>

    <!-- Mobile Sidebar Overlay -->
    <div class="sidebar-overlay" id="overlay" onclick="closeSidebar()"></div>

    <!-- ── Sidebar ── -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-logo">
            <div class="logo-icon"><img src="/assets/Kharidlow.png" alt="logo" width="45"></div>
            <div class="logo-text">Kharid<span>low</span></div>
        </div>

        <nav class="sidebar-nav">
            <div class="nav-label">Overview</div>
            <a href="/admin/manage" class="nav-link">
                <i class="fa-solid fa-chart-pie"></i> Dashboard
            </a>

            <div class="nav-label">Manage</div>
            <a href="/admin/manage/orders" class="nav-link">
                <i class="fa-solid fa-box"></i> Orders
            </a>
            <a href="/admin/manage/customers" class="nav-link">
                <i class="fa-solid fa-users"></i> Customers
            </a>
            <a href="/admin/manage/products" class="nav-link">
                <i class="fa-solid fa-tags"></i> Products
            </a>

            <div class="nav-label">Store</div>
            <a href="/product/new" class="nav-link active">
                <i class="fa-solid fa-plus-circle"></i> Add Product
            </a>
            <a href="/admin/cartanalysis" class="nav-link">
                <i class="fa-solid fa-cart-arrow-down"></i> Cart Insights
            </a>
            <a href="/" class="nav-link">
                <i class="fa-solid fa-store"></i> Store
            </a>

            <div class="nav-label">User</div>
            <a href="/admin/add-user" class="nav-link">
                <i class="fa-solid fa-user-plus"></i> Add User
            </a>
        </nav>

        <div class="sidebar-footer">
            <div class="user-card">
                <div class="avatar">AD</div>
                <div class="user-info">
                    <div class="user-name">Admin</div>
                    <div class="user-role">Super Admin</div>
                </div>
                <a href="/logout" style="color:var(--text-muted);font-size:13px;margin-left:2px;" title="Logout">
                    <i class="fa-solid fa-right-from-bracket"></i>
                </a>
            </div>
        </div>
    </aside>

    <!-- ── Main Wrapper ── -->
    <div class="main-wrap">

        <!-- Topbar -->
        <header class="topbar">
            <div class="topbar-left">
                <button class="hamburger" onclick="toggleSidebar()" aria-label="Toggle Menu">
                    <i class="fa-solid fa-bars"></i>
                </button>
                <div>
                    <div class="page-title">Add Product</div>
                    <div class="page-sub">Create a new product listing</div>
                </div>
            </div>
            <div class="topbar-right">
                <a href="/admin/manage/products" class="icon-btn" data-tooltip="Back to Products">
                    <i class="fa-solid fa-arrow-left"></i>
                </a>
                <div class="icon-btn" data-tooltip="Notifications">
                    <i class="fa-solid fa-bell"></i>
                    <span class="notif-dot"></span>
                </div>
                <div class="avatar" style="width:36px;height:36px;font-size:12px;border-radius:10px;cursor:pointer;">AD
                </div>
            </div>
        </header>

        <!-- Content -->
        <main class="content">

            <!-- Progress bar -->
            <div class="progress-wrap">
                <div class="progress-bar" id="progressBar"></div>
            </div>

            <form id="addProductForm" enctype="multipart/form-data">
                <div class="form-grid">

                    <!-- ── Left col ── -->
                    <div style="display:flex;flex-direction:column;gap:20px;">

                        <!-- Basic Info -->
                        <div class="view-card">
                            <div class="view-card-head">
                                <h3><i class="fa-solid fa-circle-info"></i> Basic Information</h3>
                            </div>
                            <div class="view-card-body">
                                <div class="form-group">
                                    <label class="form-label">Product Name</label>
                                    <input type="text" class="form-input" id="productName" name="productName"
                                        placeholder="Enter product name" required>
                                </div>
                                <div class="form-row">
                                    <div class="form-group">
                                        <label class="form-label">Category</label>
                                        <select class="form-select" id="category" name="category" required>
                                            <option value="">Select category</option>
                                        </select>
                                    </div>
                                    <div class="form-group">
                                        <label class="form-label">Sub Category</label>
                                        <select class="form-select" id="subCategory" name="subCategory" required
                                            disabled>
                                            <option value="">Select sub category</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Description</label>
                                    <textarea class="form-textarea" id="description" name="description"
                                        placeholder="Enter detailed product description" required></textarea>
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Tags <span class="form-hint"
                                            style="text-transform:none;">(comma separated)</span></label>
                                    <input type="text" class="form-input" id="tags" name="tags"
                                        placeholder="e.g. electronics, mobile, accessories">
                                </div>
                            </div>
                        </div>

                        <!-- Pricing & Inventory -->
                        <div class="view-card">
                            <div class="view-card-head">
                                <h3><i class="fa-solid fa-chart-line"></i> Pricing &amp; Inventory</h3>
                            </div>
                            <div class="view-card-body">
                                <div class="form-row">
                                    <div class="form-group">
                                        <label class="form-label">Price (₹)</label>
                                        <input type="number" class="form-input" id="price" name="price" placeholder="0"
                                            required min="0" step="0.01">
                                    </div>
                                    <div class="form-group">
                                        <label class="form-label">Stock Quantity</label>
                                        <input type="number" class="form-input" id="stock" name="stock" placeholder="0"
                                            min="0">
                                    </div>
                                </div>
                                <div class="form-row">
                                    <div class="form-group">
                                        <label class="form-label">SKU</label>
                                        <input type="text" class="form-input" id="sku" name="sku"
                                            placeholder="Enter SKU" required>
                                    </div>
                                    <div class="form-group">
                                        <label class="form-label">MOQ</label>
                                        <input type="number" class="form-input" id="moq" name="moq" placeholder="1"
                                            required min="1">
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>

                    <!-- ── Right col ── -->
                    <div style="display:flex;flex-direction:column;gap:20px;">

                        <!-- Tax & Dispatch -->
                        <div class="view-card">
                            <div class="view-card-head">
                                <h3><i class="fa-solid fa-calculator"></i> Tax &amp; Dispatch</h3>
                            </div>
                            <div class="view-card-body">
                                <div class="form-row">
                                    <div class="form-group">
                                        <label class="form-label">Tax Rate</label>
                                        <select class="form-select" id="taxRate" name="taxRate" required>
                                            <option value="">Select rate</option>
                                            <option value="0">0%</option>
                                            <option value="5" selected>5%</option>
                                            <option value="12">12%</option>
                                            <option value="18">18%</option>
                                        </select>
                                    </div>
                                    <div class="form-group">
                                        <label class="form-label">Tax Type</label>
                                        <select class="form-select" id="taxType" name="taxType" required>
                                            <option value="">Select type</option>
                                            <option value="exclusive">Exclusive</option>
                                            <option value="inclusive" selected>Inclusive</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Same Day Dispatch</label>
                                    <select class="form-select" id="sameDayDispatch" name="sameDayDispatch" required>
                                        <option value="">Select option</option>
                                        <option value="yes">Yes</option>
                                        <option value="no" selected>No</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <!-- Main Image -->
                        <div class="view-card">
                            <div class="view-card-head">
                                <h3><i class="fa-solid fa-image"></i> Main Image</h3>
                            </div>
                            <div class="view-card-body">
                                <div class="main-preview-wrap" id="mainPreviewWrap">
                                    <img id="mainPreviewImg" src="" alt="Preview">
                                    <button type="button" class="clear-btn" onclick="clearMainImage()"
                                        data-tooltip="Remove">
                                        <i class="fa-solid fa-xmark"></i>
                                    </button>
                                </div>
                                <div class="img-upload-area" id="mainUploadArea"
                                    onclick="document.getElementById('productImage').click();">
                                    <i class="fa-solid fa-camera"></i>
                                    <p>Click to upload main image</p>
                                    <span class="form-hint">.jpg, .jpeg, .png, .webp</span>
                                </div>
                                <input type="file" id="productImage" name="productImage" accept=".jpg,.jpeg,.png,.webp"
                                    style="display:none;" required>
                                <span class="form-error" id="mainImgError">Invalid format. Use .jpg, .jpeg, .png or
                                    .webp</span>
                            </div>
                        </div>

                        <!-- Additional Images -->
                        <div class="view-card">
                            <div class="view-card-head">
                                <h3><i class="fa-solid fa-images"></i> Additional Images</h3>
                                <span style="font-size:11px;color:var(--text-muted);">Max 5</span>
                            </div>
                            <div class="view-card-body">
                                <div class="add-previews" id="addPreviews"></div>
                                <div class="img-upload-area"
                                    onclick="document.getElementById('additionalImages').click();">
                                    <i class="fa-solid fa-plus"></i>
                                    <p>Click to upload additional images</p>
                                </div>
                                <input type="file" id="additionalImages" name="additionalImages"
                                    accept=".jpg,.jpeg,.png,.webp" multiple style="display:none;">
                                <span class="form-error" id="addImgError">You can upload a maximum of 5 images.</span>
                            </div>
                        </div>

                        <!-- Submit actions inside last card -->
                        <div class="view-card">
                            <div class="form-actions">
                                <button type="button" class="btn-reset" onclick="resetForm()">
                                    <i class="fa-solid fa-rotate-left"></i> Reset
                                </button>
                                <button type="submit" class="btn-submit" id="submitBtn">
                                    <i class="fa-solid fa-plus"></i>
                                    <span id="btnText">Add Product</span>
                                </button>
                            </div>
                        </div>

                    </div>

                </div>
            </form>
        </main>
    </div>

    <script>
        // ── Sidebar ──
        function toggleSidebar() {
            document.getElementById('sidebar').classList.toggle('open');
            document.getElementById('overlay').classList.toggle('open');
        }
        function closeSidebar() {
            document.getElementById('sidebar').classList.remove('open');
            document.getElementById('overlay').classList.remove('open');
        }
        window.addEventListener('resize', () => { if (window.innerWidth > 900) closeSidebar(); });

        // ── Loader ──
        function showLoader() { document.getElementById('loadingSpinner').classList.add('show'); }
        function hideLoader() { document.getElementById('loadingSpinner').classList.remove('show'); }

        // ── Swal theme ──
        const swalDark = { background: '#1e2028', color: '#f0f0f4', confirmButtonColor: '#6c63ff' };

        // ── Progress bar ──
        function updateProgress() {
            const fields = document.querySelectorAll('#addProductForm input[required], #addProductForm select[required], #addProductForm textarea[required]');
            let filled = 0;
            fields.forEach(f => { if (f.value.trim() !== '') filled++; });
            document.getElementById('progressBar').style.width = ((filled / fields.length) * 100) + '%';
        }

        document.getElementById('addProductForm').addEventListener('input', updateProgress);
        document.getElementById('addProductForm').addEventListener('change', updateProgress);

        // ── Fetch categories ──
        function fetchCategories() {
            fetch('/product/category')
                .then(res => res.json())
                .then(categories => {
                    const sel = document.getElementById('category');
                    categories.forEach(cat => {
                        const opt = document.createElement('option');
                        opt.value = cat._id;
                        opt.textContent = cat.name;
                        sel.appendChild(opt);
                    });
                })
                .catch(() => Swal.fire({ icon: 'error', title: 'Error', text: 'Failed to load categories.', ...swalDark }));
        }

        // ── Fetch sub-categories ──
        document.getElementById('category').addEventListener('change', function () {
            const subSel = document.getElementById('subCategory');
            subSel.innerHTML = '<option value="">Loading…</option>';
            subSel.disabled = true;

            if (!this.value) {
                subSel.innerHTML = '<option value="">Select sub category</option>';
                return;
            }

            fetch(`/product/category/${this.value}/subCateorgy`)
                .then(res => res.json())
                .then(subs => {
                    subSel.innerHTML = '<option value="">Select sub category</option>';
                    subs.forEach(sub => {
                        const opt = document.createElement('option');
                        opt.value = sub.name;
                        opt.textContent = sub.name;
                        subSel.appendChild(opt);
                    });
                    subSel.disabled = false;
                })
                .catch(() => {
                    subSel.innerHTML = '<option value="">Error loading</option>';
                });
        });

        // ── Main image preview ──
        document.getElementById('productImage').addEventListener('change', function () {
            const file = this.files[0];
            const allowed = /\.(jpg|jpeg|png|webp)$/i;
            const errEl = document.getElementById('mainImgError');

            if (!file || !allowed.test(file.name)) {
                errEl.classList.add('show');
                this.value = '';
                return;
            }
            errEl.classList.remove('show');

            const reader = new FileReader();
            reader.onload = e => {
                document.getElementById('mainPreviewImg').src = e.target.result;
                document.getElementById('mainPreviewWrap').style.display = 'block';
                document.getElementById('mainUploadArea').style.display = 'none';
            };
            reader.readAsDataURL(file);
        });

        function clearMainImage() {
            document.getElementById('productImage').value = '';
            document.getElementById('mainPreviewWrap').style.display = 'none';
            document.getElementById('mainUploadArea').style.display = 'block';
        }

        // ── Additional images preview ──
        document.getElementById('additionalImages').addEventListener('change', function () {
            const errEl = document.getElementById('addImgError');
            const container = document.getElementById('addPreviews');
            container.innerHTML = '';

            if (this.files.length > 5) {
                errEl.classList.add('show');
                this.value = '';
                return;
            }
            errEl.classList.remove('show');

            Array.from(this.files).forEach(file => {
                const reader = new FileReader();
                reader.onload = e => {
                    const div = document.createElement('div');
                    div.className = 'add-preview-item';
                    div.innerHTML = `<img src="${e.target.result}" alt="preview">`;
                    container.appendChild(div);
                };
                reader.readAsDataURL(file);
            });
        });

        // ── Reset form ──
        function resetForm() {
            document.getElementById('addProductForm').reset();
            document.getElementById('addPreviews').innerHTML = '';
            clearMainImage();
            document.getElementById('subCategory').innerHTML = '<option value="">Select sub category</option>';
            document.getElementById('subCategory').disabled = true;
            document.getElementById('progressBar').style.width = '0%';
        }

        // ── Submit ──
        document.getElementById('addProductForm').addEventListener('submit', function (e) {
            e.preventDefault();
            const btn = document.getElementById('submitBtn');
            const btnText = document.getElementById('btnText');

            btn.disabled = true;
            btnText.textContent = 'Adding…';
            showLoader();

            const formData = new FormData(this);

            fetch('/product/new', {
                method: 'POST',
                body: formData
            })
                .then(res => res.json())
                .then(response => {
                    hideLoader();
                    btn.disabled = false;
                    btnText.textContent = 'Add Product';

                    if (response.success !== false) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Product Added!',
                            text: 'Product has been added successfully.',
                            confirmButtonText: 'OK',
                            ...swalDark
                        }).then(() => resetForm());
                    } else {
                        Swal.fire({ icon: 'error', title: 'Error', text: response.message || 'Failed to add product.', ...swalDark });
                    }
                })
                .catch(() => {
                    hideLoader();
                    btn.disabled = false;
                    btnText.textContent = 'Add Product';
                    Swal.fire({ icon: 'error', title: 'Error', text: 'An unexpected error occurred.', ...swalDark });
                });
        });

        // ── Init ──
        fetchCategories();
        updateProgress();
    </script>
</body>

</html>