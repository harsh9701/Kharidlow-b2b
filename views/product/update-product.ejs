<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Update Product - KharidLow</title>
    <link rel="icon" type="image/x-icon" href="/assets/Kharidlow.ico">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" />
    <link rel="stylesheet" href="/styles/adminHeader.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-SNMCFJBC49"></script>
    <script>
        window.dataLayer = window.dataLayer || [];
        function gtag() { dataLayer.push(arguments); }
        gtag('js', new Date());

        gtag('config', 'G-SNMCFJBC49');
    </script>
    <style>
        body {
            background-color: #fff9f9db;
        }

        .main-container {
            max-width: 900px;
            margin: auto;
            padding: 20px;
            border: 1px solid #ddd;
            border-radius: 8px;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            background-color: #fff;
        }

        .image-preview {
            width: 180px;
            height: 180px;
            object-fit: cover;
            border-radius: 50%;
            border: 2px solid #ccc;
            position: relative;
            margin: 0 auto;
        }

        .change-image {
            position: absolute;
            top: 399px;
            left: 50%;
            transform: translate(-50%, -50%);
            /* Adjust position */
            background-color: blue;
            color: white;
            border: none;
            border-radius: 50%;
            cursor: pointer;
            width: 30px;
            height: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .main-image-container {
            text-align: center;
            margin-bottom: 20px;
        }

        .additional-images {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
        }

        .image-list-item {
            position: relative;
            width: calc(25% - 10px);
        }

        .remove-image {
            background-color: #e40c0c;
            color: #fff;
            border: none;
            border-radius: 50%;
            position: absolute;
            top: 8px;
            left: 125px;
        }

        #loadingSpinner {
            display: none;
        }

        @media (max-width: 768px) {
            .image-list-item {
                width: calc(50% - 10px);
                /* 2 images in a row on smaller screens */
            }

            .main-container {
                margin: 20px;
            }

            .change-image {
                top: 388px;
                left: 50%;
            }
        }

        @media (max-width: 480px) {
            .image-preview {
                width: 120px;
                height: 120px;
            }

            .remove-image {
                font-size: 0.8rem;
                top: 8px;
                left: 100px;
            }

            .image-list-item {
                text-align: center;
                width: calc(50% - 10px);
            }

            .change-image {
                top: 323px;
                left: 50%;
                font-size: 0.8rem;
                width: 23px;
                height: 23px;
            }
        }
    </style>
</head>

<body>
    <%- include("../includes/admin-header.ejs"); %>
        <div class="main-container my-4">
            <h1 class="text-center mb-4">Update Product</h1>

            <form id="updateProductForm" enctype="multipart/form-data">
                <!-- Main Image Section -->
                <div class="main-image-container mb-4">
                    <% if (product.mainImage) { %>
                        <img src="<%= product.mainImage %>" alt="Main Image" class="image-preview">
                        <input type="file" id="mainImage" name="mainImage" style="display:none;"
                            onchange="updateMainImage(event)">
                        <button type="button" class="change-image"
                            onclick="document.getElementById('mainImage').click();">✎</button>
                        <% } %>
                </div>

                <div class="mb-3">
                    <label for="productName" class="form-label">Product Name</label>
                    <input type="text" class="form-control" id="productName" name="productName"
                        value="<%= product.productName %>" required>
                </div>

                <div class="mb-3">
                    <label for="description" class="form-label">Description</label>
                    <textarea class="form-control" id="description" name="description" rows="4"
                        required><%= product.description %></textarea>
                </div>

                <div class="mb-3">
                    <label for="price" class="form-label">Price</label>
                    <input type="number" class="form-control" id="price" name="price" value="<%= product.price %>"
                        required>
                </div>

                <div class="mb-3">
                    <label for="stock" class="form-label">Stock</label>
                    <input type="number" class="form-control" id="stock" name="stock" value="<%= product.stock %>"
                        required>
                </div>

                <div class="mb-3">
                    <label for="moq" class="form-label">Minimum Order Quantity (MOQ)</label>
                    <input type="number" class="form-control" id="moq" name="moq" value="<%= product.moq %>" required>
                </div>

                <div class="mb-3">
                    <label for="discount" class="form-label">Discount (%)</label>
                    <input type="number" class="form-control" id="discount" name="discount"
                        value="<%= product.discount %>" required>
                </div>

                <div class="mb-3">
                    <label for="taxType" class="form-label">Tax Type</label>
                    <select class="form-select" id="taxType" name="taxType" required>
                        <option value="inclusive" <%=product.taxType==='inclusive' ? 'selected' : '' %>>Inclusive
                        </option>
                        <option value="exclusive" <%=product.taxType==='exclusive' ? 'selected' : '' %>>Exclusive
                        </option>
                    </select>
                </div>

                <div class="mb-3">
                    <label for="taxRate" class="form-label">Tax Rate (%)</label>
                    <input type="number" class="form-control" id="taxRate" name="taxRate" value="<%= product.taxRate %>"
                        required>
                </div>

                <div class="mb-3">
                    <label for="tags" class="form-label">Tags (comma separated)</label>
                    <input type="text" class="form-control" id="tags" name="tags"
                        value="<%= product.tags.join(', ') %>">
                </div>

                <div class="mb-3">
                    <label for="productImages" class="form-label">Additional Product Images</label>
                    <input type="file" class="form-control" id="productImages" name="productImages" multiple
                        onchange="checkImageLimit(this)" accept="image/*">
                    <small class="text-muted">You can upload up to 5 images.</small>

                    <div class="additional-images mt-2">
                        <% if (product.productImages.length> 0) { %>
                            <% product.productImages.forEach(image=> { %>
                                <div class="image-list-item" data-image="<%= image %>">
                                    <img src="<%= image %>" alt="Product Image" class="image-preview">
                                    <button type="button" class="remove-image"
                                        onclick="removeProductImage('<%= image %>')">
                                        <i class="fa-regular fa-trash-can"></i>
                                    </button>
                                </div>
                                <% }); %>
                                    <% } else { %>
                                        <p>No additional images uploaded.</p>
                                        <% } %>
                    </div>
                </div>

                <div class="text-center mt-4">
                    <button type="submit" class="btn btn-primary">Update Product</button>
                    <a href="/admin/manage/products" class="btn btn-secondary">Back to Products</a>
                </div>
            </form>
        </div>

        <div id="loadingSpinner"
            class="d-none position-fixed top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center"
            style="background: rgba(0, 0, 0, 0.5); z-index: 1050;">
            <div class="spinner-border text-light" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>

        <!-- Include Admin Sidebar -->
        <%- include("../includes/admin-sidebar.ejs"); %>

            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
            <script src="https://code.jquery.com/jquery-3.7.1.js"></script>

            <script>

                const maxImagesAllowed = 5;
                let existingImagesCount = "<%= product.productImages.length %>";

                function checkImageLimit(input) {
                    const selectedFiles = input.files.length;
                    const totalImagesCount = Number(existingImagesCount) + Number(selectedFiles);

                    if (totalImagesCount > maxImagesAllowed) {
                        Swal.fire({
                            icon: 'warning',
                            title: 'Image Upload Limit',
                            text: `You can only upload ${maxImagesAllowed - existingImagesCount} more images.`,
                            confirmButtonText: 'OK',
                            timer: 4000 // Optional: Auto-close after 4 seconds
                        });

                        input.value = '';  // Clear the file input to prevent the excess images from being uploaded
                    }
                }

                function updateMainImage(event) {
                    const file = event.target.files[0];
                    if (file) {
                        const reader = new FileReader();
                        reader.onload = function (e) {
                            document.querySelector('.image-preview').src = e.target.result; // Update the image preview
                        }
                        reader.readAsDataURL(file); // Read the image as a data URL
                    }
                }

                function showLoader() {
                    $("#loadingSpinner").removeClass('d-none').show();
                }

                function hideLoader() {
                    $("#loadingSpinner").hide();
                }

                function removeProductImage(image) {
                    const productId = "<%= product._id %>"; // Replace with your actual product ID

                    // SweetAlert confirmation dialog
                    Swal.fire({
                        title: 'Are you sure?',
                        text: "You won't be able to revert this!",
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonColor: '#3085d6',
                        cancelButtonColor: '#d33',
                        confirmButtonText: 'Yes, delete it!',
                        cancelButtonText: 'Cancel'
                    }).then((result) => {
                        if (result.isConfirmed) {
                            showLoader();
                            $.ajax({
                                url: `/admin/delete/productimage/${productId}`,
                                type: 'DELETE',
                                data: JSON.stringify({ imageName: image }),
                                contentType: 'application/json',
                                success: function (response) {
                                    hideLoader();
                                    if (response.success) {
                                        Swal.fire(
                                            'Deleted!',
                                            'Your image has been deleted.',
                                            'success'
                                        ).then(() => {
                                            location.reload(); // Reload the page
                                        });;

                                        // Remove the image element from the DOM & hide Spinner
                                        // $(`[data-image="${image}"]`).remove();
                                    } else {
                                        Swal.fire(
                                            'Error!',
                                            response.message,
                                            'error'
                                        );
                                    }
                                },
                                error: function (xhr, status, error) {
                                    hideLoader();
                                    console.error('Error deleting image:', error);
                                    Swal.fire(
                                        'Error!',
                                        'An error occurred while deleting the image.',
                                        'error'
                                    );
                                }
                            });
                        }
                    });
                }

                $(document).ready(function () {
                    $('#updateProductForm').on('submit', function (event) {
                        event.preventDefault();

                        let formData = new FormData(this);

                        showLoader();
                        $.ajax({
                            url: '/admin/update/product/<%= product._id %>',
                            type: 'PUT',
                            data: formData,
                            processData: false,
                            contentType: false,
                            success: function (response) {
                                hideLoader();
                                Swal.fire({
                                    icon: 'success',
                                    title: 'Product Updated',
                                    text: 'Product updated successfully!',
                                    confirmButtonText: 'OK',
                                    timer: 4000 // Optional: Auto-close after 4 seconds
                                }).then(() => {
                                    window.location.href = '/admin/manage/products';
                                });
                            },
                            error: function (xhr, status, error) {
                                hideLoader();
                                Swal.fire({
                                    icon: 'error',
                                    title: 'Error',
                                    text: 'An error occurred while updating the product. Please try again.',
                                    confirmButtonText: 'OK'
                                });
                            }
                        });
                    });
                });


                function updateMainImage(event) {
                    const file = event.target.files[0];
                    if (file) {
                        const reader = new FileReader();
                        reader.onload = function (e) {
                            document.querySelector('.image-preview').src = e.target.result; // Update the image preview
                        }
                        reader.readAsDataURL(file); // Read the image as a data URL
                    }
                }
            </script>
</body>

</html>