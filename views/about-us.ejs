    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>About Us - KharidLow</title>
    <link rel="icon" type="image/x-icon" href="assets/Kharidlow.ico" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
    <link rel="stylesheet" href="/styles/style.css" />
    <link rel="stylesheet" href="/styles/navbar.css" />
    <link rel="stylesheet" href="/styles/footer.css" />
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Nunito:ital,wght@0,200..1000;1,200..1000&display=swap');

        :root {
            --primary-color: #6241e6;
            --secondary-color: #856cea;
            --light-purple: #abbdff86;
            --dark-color: #07081b;
            --text-color: #343a40;
            --bg-light: #f8f9fa;
            --box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
            --border-radius: 10px;
            --transition: all 0.3s ease;
        }

        body {
            font-family: "Nunito", sans-serif;
            font-optical-sizing: auto;
            font-weight: 400;
            font-style: normal;
        }

        .title-style {
            font-size: 2rem;
            font-weight: 700;
            color: var(--text-color);
            margin-bottom: 30px;
            position: relative;
            text-align: center;
            padding-bottom: 15px;
        }

        .title-style::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 80px;
            height: 4px;
            background-color: var(--primary-color);
            border-radius: 2px;
        }

        /* About Us Section */
        .about-us-section {
            padding: 60px 0;
            background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
            position: relative;
            overflow: hidden;
        }

        .about-us-section::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><circle cx="20" cy="20" r="2" fill="%236241e6" opacity="0.1"/><circle cx="80" cy="80" r="2" fill="%23856cea" opacity="0.1"/><circle cx="40" cy="60" r="1.5" fill="%236241e6" opacity="0.1"/><circle cx="60" cy="40" r="1.5" fill="%23856cea" opacity="0.1"/></svg>');
            pointer-events: none;
        }

        .about-content {
            position: relative;
            z-index: 1;
        }

        .about-intro {
            text-align: center;
            margin-bottom: 50px;
        }

        .about-intro p {
            font-size: 1.2rem;
            color: var(--text-color);
            line-height: 1.8;
            max-width: 800px;
            margin: 0 auto;
        }

        .about-cards-container {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 30px;
            margin-top: 40px;
        }

        .about-card {
            background: white;
            border-radius: var(--border-radius);
            padding: 30px;
            box-shadow: var(--box-shadow);
            transition: var(--transition);
            position: relative;
            overflow: hidden;
        }

        .about-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 4px;
            background: linear-gradient(90deg, var(--primary-color), var(--secondary-color));
        }

        .about-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(98, 65, 230, 0.2);
        }

        .about-card-icon {
            width: 60px;
            height: 60px;
            background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 20px;
            transition: var(--transition);
        }

        .about-card:hover .about-card-icon {
            transform: scale(1.1);
        }

        .about-card-icon i {
            font-size: 24px;
            color: white;
        }

        .about-card h4 {
            color: var(--dark-color);
            font-weight: 700;
            margin-bottom: 15px;
            font-size: 1.3rem;
        }

        .about-card p {
            color: var(--text-color);
            line-height: 1.6;
            margin: 0;
        }

        .stats-section {
            background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
            color: white;
            padding: 50px 0;
            margin-top: 30px;
            border-radius: var(--border-radius);
        }

        .stats-container {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 30px;
            text-align: center;
        }

        .stat-item {
            padding: 20px;
        }

        .stat-number {
            font-size: 3rem;
            font-weight: 900;
            margin-bottom: 10px;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
        }

        .stat-label {
            font-size: 1.1rem;
            font-weight: 600;
            opacity: 0.9;
        }

        .values-section {
            margin-top: 50px;
            text-align: center;
        }

        .values-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 25px;
            margin-top: 30px;
        }

        .value-item {
            background: var(--light-purple);
            padding: 25px;
            border-radius: var(--border-radius);
            transition: var(--transition);
        }

        .value-item:hover {
            background: var(--secondary-color);
            color: white;
            transform: translateY(-3px);
        }

        .value-icon {
            font-size: 2.5rem;
            color: var(--primary-color);
            margin-bottom: 15px;
        }

        .value-item:hover .value-icon {
            color: white;
        }

        .value-item h5 {
            font-weight: 700;
            margin-bottom: 10px;
        }

        /* Responsive Design */
        @media (max-width: 768px) {
            .about-us-section {
                padding: 40px 0;
            }

            .title-style {
                font-size: 1.6rem;
                margin-bottom: 20px;
            }

            .about-intro p {
                font-size: 1.1rem;
                padding: 0 15px;
            }

            .about-cards-container {
                grid-template-columns: 1fr;
                gap: 20px;
            }

            .about-card {
                padding: 20px;
            }

            .stats-section {
                padding: 30px 0;
                margin-top: 20px;
            }

            .stat-number {
                font-size: 2.5rem;
            }

            .stats-container {
                grid-template-columns: repeat(2, 1fr);
                gap: 20px;
            }

            .values-grid {
                grid-template-columns: 1fr;
                gap: 15px;
            }

            .value-item {
                padding: 20px;
            }
        }

        @media (max-width: 576px) {
            .about-us-section {
                padding: 30px 0;
            }

            .title-style {
                font-size: 1.4rem;
            }

            .about-intro p {
                font-size: 1rem;
            }

            .stats-container {
                grid-template-columns: 1fr;
            }

            .stat-number {
                font-size: 2rem;
            }

            .value-icon {
                font-size: 2rem;
            }
        }
    </style>
</head>

<body>
    <%- include("includes/navbar.ejs") %>
        <!-- About Us Section -->
        <section class="about-us-section">
            <div class="container">
                <div class="about-content">
                    <h2 class="title-style">About KharidLow</h2>

                    <div class="about-intro">
                        <p>Welcome to KharidLow, your trusted B2B marketplace connecting businesses across India. We
                            specialize in providing quality products at wholesale prices, making business procurement
                            simple, efficient, and cost-effective.</p>
                    </div>

                    <div class="about-cards-container">
                        <div class="about-card">
                            <div class="about-card-icon">
                                <i class="fas fa-handshake"></i>
                            </div>
                            <h4>Who We Are</h4>
                            <p>A dedicated team of professionals committed to revolutionizing B2B commerce in India. We
                                understand the unique challenges businesses face and provide tailored solutions to meet
                                your
                                procurement needs.</p>
                        </div>

                        <div class="about-card">
                            <div class="about-card-icon">
                                <i class="fas fa-bullseye"></i>
                            </div>
                            <h4>Our Mission</h4>
                            <p>To create a seamless B2B marketplace that empowers businesses of all sizes to grow and
                                succeed. We bridge the gap between suppliers and buyers, ensuring quality products reach
                                you
                                at competitive prices.</p>
                        </div>

                        <div class="about-card">
                            <div class="about-card-icon">
                                <i class="fas fa-star"></i>
                            </div>
                            <h4>Why Choose Us</h4>
                            <p>With our extensive product range, reliable delivery network, and customer-first approach,
                                we
                                make B2B procurement hassle-free. From fashion to stationery, we've got your business
                                covered.</p>
                        </div>
                    </div>

                    <div class="stats-section">
                        <div class="container">
                            <div class="stats-container">
                                <div class="stat-item">
                                    <div class="stat-number">210+</div>
                                    <div class="stat-label">Happy Customers</div>
                                </div>
                                <div class="stat-item">
                                    <div class="stat-number">500+</div>
                                    <div class="stat-label">Products</div>
                                </div>
                                <div class="stat-item">
                                    <div class="stat-number">54+</div>
                                    <div class="stat-label">Cities Served</div>
                                </div>
                                <div class="stat-item">
                                    <div class="stat-number">97%</div>
                                    <div class="stat-label">Satisfaction Rate</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="values-section">
                        <h3 class="title-style">Our Core Values</h3>
                        <div class="values-grid">
                            <div class="value-item">
                                <div class="value-icon">
                                    <i class="fas fa-shield-alt"></i>
                                </div>
                                <h5>Trust & Reliability</h5>
                                <p>Building lasting relationships through consistent quality and dependable service.</p>
                            </div>
                            <div class="value-item">
                                <div class="value-icon">
                                    <i class="fas fa-rocket"></i>
                                </div>
                                <h5>Innovation</h5>
                                <p>Continuously improving our platform to provide the best B2B experience.</p>
                            </div>
                            <div class="value-item">
                                <div class="value-icon">
                                    <i class="fas fa-users"></i>
                                </div>
                                <h5>Customer Focus</h5>
                                <p>Your success is our priority. We're here to support your business growth.</p>
                            </div>
                            <div class="value-item">
                                <div class="value-icon">
                                    <i class="fas fa-leaf"></i>
                                </div>
                                <h5>Sustainability</h5>
                                <p>Committed to responsible business practices for a better future.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <%- include("includes/footer.ejs") %>

            <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>