<!-- Mobile Search Overlay -->
<div class="mobile-search-overlay" id="mobileSearchOverlay">
    <form action="/search" class="mobile-search-form" role="search">
        <div class="input-group">
            <input class="form-control mobile-search-input" type="search" name="searchTerm"
                placeholder="Search for products..." aria-label="Search">
            <button class="btn mobile-search-btn" type="submit">
                <i class="fa-solid fa-magnifying-glass"></i>
            </button>
            <button type="button" class="btn mobile-search-close" id="mobileSearchClose">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>
    </form>
</div>

<!-- Add this script at the end of your body tag -->
<script>
    document.addEventListener('DOMContentLoaded', function () {
        const searchToggle = document.getElementById('bottom-search-toggle');
        const searchOverlay = document.getElementById('mobileSearchOverlay');
        const searchClose = document.getElementById('mobileSearchClose');

        searchToggle.addEventListener('click', function (e) {
            e.preventDefault();
            searchOverlay.classList.add('active');
            document.querySelector('.mobile-search-input').focus();
        });

        searchClose.addEventListener('click', function () {
            searchOverlay.classList.remove('active');
        });
    });
</script>