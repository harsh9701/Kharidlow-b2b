<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Account - Kharidlow</title>
    <link rel="icon" type="image/x-icon" href="/assets/Kharidlow.ico">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" />
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <link rel="stylesheet" href="/styles/navbar.css">
    <link rel="stylesheet" href="/styles/footer.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/sweetalert/2.1.2/sweetalert.min.js"></script>
    <style>
        .account-container {
            padding: 20px;
        }

        .nav-tabs {
            border-bottom: 2px solid #dee2e6;
        }

        .nav-tabs .nav-item {
            margin-bottom: -2px;
        }

        .nav-tabs .nav-link {
            border: 1px solid transparent;
            border-top-left-radius: 0.25rem;
            border-top-right-radius: 0.25rem;
            color: #495057 !important;
        }

        .nav-tabs .nav-link.active {
            color: #007bff !important;
            background-color: #fff !important;
            border-color: #dee2e6 #dee2e6 #fff !important;
        }

        .nav-tabs .nav-link.active:hover {
            color: #007bff !important;
        }

        .nav-tabs .nav-link:hover {
            color: #fff !important;
        }

        @media (max-width: 576px) {
            .nav-tabs {
                flex-direction: column;
                /* Stack tabs vertically */
                align-items: stretch;
                /* Ensure tabs take full width */
            }

            .nav-tabs .nav-item {
                width: 100%;
                /* Make each tab take full width */
            }

            .nav-tabs .nav-link {
                text-align: center;
                /* Center text in each tab */
                border-bottom: 1px solid #dee2e6;
                /* Add a bottom border for visual separation */
                border-top: none;
                /* Remove top border */
                margin-bottom: 0;
                /* Reset margin */
            }

            .nav-tabs .nav-link.active {
                border-bottom: none;
                /* Remove bottom border from active tab */
            }
        }
    </style>
</head>

<body>

    <!-- Include Navbar -->
    <%- include("../includes/navbar.ejs") %>

        <div class="container account-container my-2">
            <!-- Tabbed Navigation -->
            <ul class="nav nav-tabs flex-column flex-sm-row" id="accountTabs" role="tablist">
                <li class="nav-item">
                    <a class="nav-link active" id="orders-tab" data-toggle="tab" href="#orders" role="tab"
                        aria-controls="orders" aria-selected="true">Recent Orders</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" id="addresses-tab" data-toggle="tab" href="#addresses" role="tab"
                        aria-controls="addresses" aria-selected="false">Manage Addresses</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" id="password-tab" data-toggle="tab" href="#password" role="tab"
                        aria-controls="password" aria-selected="false">Update Password</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" id="contact-tab" data-toggle="tab" href="#contact" role="tab"
                        aria-controls="contact" aria-selected="false">Contact Us</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" id="settings-tab" data-toggle="tab" href="#settings" role="tab"
                        aria-controls="settings" aria-selected="false">Account Settings</a>
                </li>
            </ul>


            <!-- Tabbed Content -->
            <div class="tab-content mt-4" id="accountTabsContent">

                <!-- Recent Orders Tab -->
                <div class="tab-pane fade show active" id="orders" role="tabpanel" aria-labelledby="orders-tab">
                    <h3 class="section-title">Recent Orders</h3>
                    <div class="table-responsive">
                        <table class="table table-bordered table-striped">
                            <thead>
                                <tr>
                                    <th>Order ID</th>
                                    <th>Date</th>
                                    <th>Status</th>
                                    <th>Total</th>
                                    <th>Details</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if(orders && orders.length> 0) { let count = 0; %>
                                    <% orders.forEach(order=> { %>
                                        <% count++; if(count <=3) { %>
                                            <tr>
                                                <td>#<%= order.orderNumber %>
                                                </td>
                                                <td>
                                                    <%= order.createdAt.toDateString(); %>
                                                </td>
                                                <td>
                                                    <%= order.status %>
                                                </td>
                                                <td>&#8377; <%= order.grandTotal %>
                                                </td>
                                                <td><a href="/order/12345" class="btn btn-primary btn-sm">View</a></td>
                                            </tr>
                                            <% }; %>
                                                <% }); %>
                                                <% if(count == 4) { %>
                                                    <tr>
                                                        <td colspan="5" class="text-center">
                                                            <a href="/user/orders">See More Orders</a>
                                                        </td>
                                                    </tr>
                                                <% } %>
                                                    <% } else { %>
                                                        <tr>
                                                            <td colspan="5" class="text-center">No Orders</td>
                                                        </tr>
                                                        <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Manage Addresses Tab -->
                <div class="tab-pane fade" id="addresses" role="tabpanel" aria-labelledby="addresses-tab">
                    <h3 class="section-title">Manage Addresses</h3>
                    <% if(userAddress.length> 0 && userAddress){ %>
                        <% userAddress.forEach((address, index)=> { %>
                            <p>Address: <%= index+1 %> -- <%= address.flatNo %>
                                        <%= address.streetNo %>
                                            <%= address.area %>
                                                <%= address.state %>
                                                    <%= address.pincode %>
                            </p>
                            <% }) %>
                                <% } else { %>
                                    <p>No Address Saved</p>
                                    <% } %>
                                        <button class="btn btn-outline-success" data-toggle="modal"
                                            data-target="#addAddressModal">Add New
                                            Address</button>
                </div>

                <!-- Add Address Modal -->
                <div class="modal fade" id="addAddressModal" tabindex="-1" aria-labelledby="addAddressModalLabel"
                    aria-hidden="true">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title" id="addAddressModalLabel">Add New Address</h5>
                                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                    <span aria-hidden="true">&times;</span>
                                </button>
                            </div>
                            <div class="modal-body">
                                <form>
                                    <div class="form-group">
                                        <label for="addressLine">Address Line</label>
                                        <input type="text" class="form-control" id="addressLine"
                                            placeholder="Enter your address" required>
                                    </div>
                                    <div class="form-group">
                                        <label for="city">City</label>
                                        <input type="text" class="form-control" id="city" placeholder="City" required>
                                    </div>
                                    <div class="form-group">
                                        <label for="state">State</label>
                                        <input type="text" class="form-control" id="state" placeholder="State" required>
                                    </div>
                                    <div class="form-group">
                                        <label for="zipcode">Zip Code</label>
                                        <input type="text" class="form-control" id="zipcode" placeholder="Zip Code"
                                            required>
                                    </div>
                                    <button type="submit" class="btn btn-success">Save Address</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Update Password Tab -->
                <div class="tab-pane fade" id="password" role="tabpanel" aria-labelledby="password-tab">
                    <h3 class="section-title">Update Password</h3>
                    <form id="updatePasswordForm">
                        <div class="form-group">
                            <label for="currentPassword">Current Password</label>
                            <input type="password" class="form-control" id="currentPassword" name="currentPassword"
                                placeholder="Enter current password" required>
                        </div>
                        <div class="form-group">
                            <label for="newPassword">New Password</label>
                            <input type="password" class="form-control" id="newPassword" name="newPassword"
                                placeholder="Enter new password" required>
                        </div>
                        <div class="form-group">
                            <label for="confirmPassword">Confirm New Password</label>
                            <input type="password" class="form-control" id="confirmPassword" name="confirmPassword"
                                placeholder="Confirm new password" required>
                        </div>
                        <button type="submit" class="btn btn-primary">Update Password</button>
                    </form>
                </div>

                <!-- Contact Us Tab -->
                <div class="tab-pane fade" id="contact" role="tabpanel" aria-labelledby="contact-tab">
                    <h3 class="section-title">Contact Us</h3>
                    <form>
                        <div class="form-group">
                            <label for="contactEmail">Email</label>
                            <input type="email" class="form-control" id="contactEmail" placeholder="Enter your email"
                                required>
                        </div>
                        <div class="form-group">
                            <label for="contactMessage">Message</label>
                            <textarea class="form-control" id="contactMessage" rows="4" placeholder="Write your message"
                                required></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary">Submit</button>
                    </form>
                </div>

                <!-- Account Settings Tab -->
                <div class="tab-pane fade" id="settings" role="tabpanel" aria-labelledby="settings-tab">
                    <h3 class="section-title">Account Settings</h3>
                    <p>Manage your account settings such as notification preferences, privacy settings, etc.</p>
                </div>

            </div>
        </div>

        <!-- Include Footer -->
        <%- include("../includes/footer.ejs") %>

            <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
            <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.6/dist/umd/popper.min.js"></script>
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/js/bootstrap.bundle.min.js"></script>
            <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
            <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
            <script>
                $('#updatePasswordForm').submit(function (event) {
                    event.preventDefault(); // Prevent the form from submitting normally

                    // Get the form data
                    let currentPassword = $('#currentPassword').val();
                    let newPassword = $('#newPassword').val();
                    let confirmPassword = $('#confirmPassword').val();

                    // Perform validation before sending the request
                    if (newPassword !== confirmPassword) {
                        swal("Oops!", "The new password confirmation doesn’t match.", "error");
                        return;
                    }

                    // Prepare the data object to be sent
                    let data = {
                        currentPassword: currentPassword,
                        newPassword: newPassword
                    };

                    // Send the PUT request using jQuery's ajax method
                    $.ajax({
                        url: '/user/updatepassword',  // Replace with your actual API endpoint
                        type: 'PUT',
                        contentType: 'application/json',
                        data: JSON.stringify(data),
                        success: function (response) {
                            swal("Awesome!", "Password updated successfully", "success");
                            $('#currentPassword').val('');
                            $('#newPassword').val('');
                            $('#confirmPassword').val('');

                        },
                        error: function (jqXHR, textStatus, errorThrown) {
                            const response = JSON.parse(jqXHR.responseText);
                            const message = response.message || "An unexpected error occurred.";
                            swal("Oops!", message, "error");
                        }
                    });
                });
            </script>
</body>

</html>