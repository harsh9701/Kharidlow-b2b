<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Your Cart - Kharidlow</title>
    <link rel="icon" type="image/x-icon" href="/assets/Kharidlow.ico">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" />
    <link rel="stylesheet" href="/styles/navbar.css">
    <link rel="stylesheet" href="/styles/footer.css">
    <link rel="stylesheet" href="/styles/cart.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>

<body>

    <!-- include navbar -->
    <%- include("../includes/navbar.ejs") %>

        <div class="container cart-container mt-3 mb-3">
            <h2 class="text-center cart-title">Your Shopping Cart</h2>

            <div class="row">
                <!-- Cart Items Section -->
                <% if(items && items.length> 0) { %>
                    <div class="col-lg-8 col-md-7">
                        <% items.forEach(item=> { %>
                            <div class="cart-item">
                                <img src="<%= item.productId.mainImage %>" alt="Product Image">
                                <div class="item-details">
                                    <span class="d-flex justify-content-between align-items-center">
                                        <h5 class="item-title">
                                            <%= item.productId.productName %>
                                        </h5>
                                        <form class="remove-form" action="/user/cart/remove/<%= item.productId._id %>"
                                            method="POST">
                                            <button type="button" class="btn btn-danger remove-btn"><i
                                                    class="fas fa-trash"></i></button>
                                        </form>
                                    </span>
                                    <p class="item-price">&#8377; <span class="item-price-value">
                                            <%= item.productId.price %>
                                        </span></p>
                                    <div class="quantity-control d-flex align-items-center">
                                        <label for="quantity" class="mr-2 quantity">Qty: &nbsp; </label>
                                        <span type="button" class="decrement-btn"><i
                                                class="fa-solid fa-minus"></i></span>
                                        <input type="number" class="form-control mx-2 quantity-input"
                                            value="<%= item.quantity %>" min="<%= item.productId.moq %>"
                                            data-price="<%= item.productId.price %>"
                                            data-moq="<%= item.productId.moq %>" inputmode="numeric" pattern="[0-9]*"
                                            style="width: 60px;">
                                        <span type="button" class="increment-btn"><i
                                                class="fa-solid fa-plus"></i></span>
                                        <input type="hidden" class="form-control ml-2 product-id"
                                            data-product-id="<%= item.productId._id %>">
                                    </div>
                                </div>

                            </div>
                            <% }); %>
                    </div>
                    <% } else { %>
                        <div class="text-center">
                            <div class="alert alert-primary text-center col-lg-12" style="margin-bottom: 52px;"
                                role="alert">
                                <h3 style="font-weight: 400;">Your cart is empty!</h3>
                            </div>
                            <a href="/product" class="icon-cart">
                                <img src="/assets/shopping-cart-svgrepo-com.svg" alt="">
                                <h5>Shop Now</h5>
                            </a>
                        </div>
                        <% } %>

                            <!-- Cart Summary Section -->
                            <% if(items && items.length> 0) { %>
                                <div class="col-lg-4 col-md-5">
                                    <div class="cart-summary">
                                        <h4 class="text-center">Order Summary</h4>
                                        <h5><strong>Total:</strong> &#8377; <span id="total">0.00</span></h5>
                                    </div>
                                    <form action="/user/order/summary" method="POST">
                                        <input type="hidden" name="cartData" id="cartData">
                                        <button type="submit" class="btn checkout-btn">Proceed to confirm</button>
                                    </form>
                                    <% } %>
                                </div>
            </div>
        </div>

        <!-- include footer -->
        <%- include("../includes/footer.ejs") %>

            <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
            <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.6/dist/umd/popper.min.js"></script>
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
            <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
            <script>
                $(document).ready(function () {

                    function updateCartSummary() {
                        let subtotal = 0;
                        let cartData = [];

                        $('.quantity-input').each(function () {
                            const quantity = parseInt($(this).val());
                            const price = parseFloat($(this).data('price'));
                            const productId = $(this).siblings('.product-id').data('product-id');

                            subtotal += quantity * price;

                            cartData.push({
                                productId: productId,
                                quantity: quantity,
                                price: price
                            });
                        });

                        const total = subtotal;

                        // Update the displayed values
                        $('#subtotal').text(subtotal.toFixed(2));
                        $('#total').text(total.toFixed(2));

                        // Store the cart data as JSON in the hidden input
                        $('#cartData').val(JSON.stringify(cartData));
                    }

                    // Initial update
                    updateCartSummary();

                    // Add event listeners to quantity inputs
                    $('.quantity-input').on('input', function () {
                        updateCartSummary();
                    });

                    // SweetAlert for remove button
                    $('.remove-btn').on('click', function (e) {
                        e.preventDefault();
                        const form = $(this).closest('.remove-form');

                        Swal.fire({
                            title: 'Are you sure?',
                            text: "You won't be able to revert this!",
                            icon: 'warning',
                            showCancelButton: true,
                            confirmButtonColor: '#d33',
                            cancelButtonColor: '#3085d6',
                            confirmButtonText: 'Yes, delete it!'
                        }).then((result) => {
                            if (result.isConfirmed) {
                                form.submit();
                            }
                        });
                    });

                    // Increment/Decrement functionality
                    document.querySelectorAll('.quantity-control').forEach(control => {
                        const quantityInput = control.querySelector('.quantity-input');
                        const minQty = parseInt(quantityInput.getAttribute('min'));

                        // Decrement button functionality
                        control.querySelector('.decrement-btn').addEventListener('click', () => {
                            let currentQty = parseInt(quantityInput.value);
                            if (currentQty > minQty) {
                                quantityInput.value = currentQty - 1;
                                updateCartSummary();  // Update totals after decrementing
                            } else {
                                Swal.fire({
                                    title: `Quantity cannot be less than ${minQty}`,
                                    icon: 'warning'
                                });
                            }
                        });

                        // Increment button functionality
                        control.querySelector('.increment-btn').addEventListener('click', () => {
                            let currentQty = parseInt(quantityInput.value);
                            quantityInput.value = currentQty + 1;
                            updateCartSummary();  // Update totals after incrementing
                        });

                        // Ensure manual input does not go below minimum quantity
                        quantityInput.addEventListener('input', function () {
                            let currentQty = parseInt(this.value);
                            if (currentQty < minQty || isNaN(currentQty)) {
                                this.value = minQty;  // Reset to minimum quantity if invalid input
                                Swal.fire({
                                    title: `Quantity cannot be less than ${minQty}`,
                                    icon: 'warning'
                                });
                            }
                            updateCartSummary();  // Update totals after manual input
                        });
                    });

                });

            </script>
</body>

</html>