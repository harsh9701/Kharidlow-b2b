<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="keywords"
        content="b2b marketplace, b2b portals, free b2b marketplace, business to business marketplace, us b2b marketplace, india b2b marketplace, b2b india, b2b marketplace for services, b2b portals in india, free b2b portals in india, sourcing b2b, all b2b portals in india">
    <title>KharidLow - B2B Marketplace</title>
    <link rel="icon" type="image/x-icon" href="assets/Kharidlow.ico">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" />
    <link rel="stylesheet" href="/styles/style.css">
    <link rel="stylesheet" href="/styles/navbar.css">
    <link rel="stylesheet" href="/styles/footer.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/sweetalert/2.1.2/sweetalert.min.js"></script>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-SNMCFJBC49"></script>
    <script>
        window.dataLayer = window.dataLayer || [];
        function gtag() { dataLayer.push(arguments); }
        gtag('js', new Date());

        gtag('config', 'G-SNMCFJBC49');
    </script>
</head>

<body>

    <!-- include navbar -->
    <%- include("includes/navbar.ejs") %>

        <!-- Hero Section -->
        <!-- <section class="hero text-white text-center">
            <div class="container">
                <h1 class="display-4">Welcome to Kharid Low</h1>
                <p class="lead">Your One-Stop B2B Marketplace for Bulk Orders</p>
                <a href="#products" class="btn btn-light btn-lg mt-3">Explore Products</a>
            </div>
        </section> -->

        <!-- Sliding Banner -->
        <div id="bannerCarousel" class="carousel slide" data-bs-ride="carousel">
            <div class="carousel-inner">
                <div class="carousel-item">
                    <img src="https://res.cloudinary.com/dfx61hywd/image/upload/v1736419667/new-arrival_l6w9oz.jpg"
                        class="d-block w-100" alt="Banner 2">
                </div>
                <div class="carousel-item">
                    <img src="https://res.cloudinary.com/dfx61hywd/image/upload/v1733126314/WhatsApp_Image_2024-11-29_at_14.27.21_b8f9859a_kummjx.jpg"
                        class="d-block w-100" alt="Banner 2">
                </div>
                <div class="carousel-item">
                    <img src="https://res.cloudinary.com/dfx61hywd/image/upload/v1733126314/WhatsApp_Image_2024-11-29_at_14.28.44_12c80114_bbndtn.jpg"
                        class="d-block w-100" alt="Banner 3">
                </div>
                <div class="carousel-item active">
                    <img src="https://res.cloudinary.com/dfx61hywd/image/upload/v1738152186/promotion_2_qrbetp.jpg"
                        class="d-block w-100" alt="Banner 3">
                </div>
                <div class="carousel-item">
                    <img src="https://res.cloudinary.com/dfx61hywd/image/upload/v1738152186/promotion_1_f7lenw.jpg"
                        class="d-block w-100" alt="Banner 3">
                </div>
            </div>
            <button class="carousel-control-prev" type="button" data-bs-target="#bannerCarousel" data-bs-slide="prev">
                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#bannerCarousel" data-bs-slide="next">
                <span class="carousel-control-next-icon" aria-hidden="true"></span>
            </button>
        </div>

        <!-- Shop by Category -->
        <div class="category-scroll text-center">
            <h2 class="my-2 title-style">Shop By Category</h2>
            <div class="category-card-main">
                <% if(category.length> 0){ %>
                    <% category.forEach((item)=> { %>
                        <a href="/category/<%= item._id %>" class="category-text">
                            <div class="category-card">
                                <img src="<%= item.img %>" class="card-img-top" alt="<%= item.img %>">
                                <h5 class="card-title">
                                    <%= item.name %>
                                </h5>
                            </div>
                        </a>
                        <% }) %>
                            <% } %>
            </div>
        </div>

        <!-- Youtube video section -->
        <section class="product-videos-section py-2">
            <div class="container">
                <h2 class="text-center title-style">Explore Our Products in Action</h2>
                <div class="videos-scroll-container">
                    <!-- Video Card 1 -->
                    <div class="video-card">
                        <iframe
                            src="https://www.youtube.com/embed/YGc4ryTnFX8?si=bPzoPoB0xZwdZecw&start=31&autoplay=1&mute=1"
                            title="YouTube video player 1"
                            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                            referrerpolicy="strict-origin-when-cross-origin" allowfullscreen>
                        </iframe>
                    </div>
                    <!-- Video Card 2 -->
                    <div class="video-card">
                        <iframe src="https://www.youtube.com/embed/MrJhlU_LC38?si=eneTfs0io_qAq4qc&amp;start=5"
                            title="YouTube video player 2"
                            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                            referrerpolicy="strict-origin-when-cross-origin" allowfullscreen>
                        </iframe>
                    </div>
                    <!-- Video Card 3 -->
                    <div class="video-card">
                        <iframe src="https://www.youtube.com/embed/bZHri1d6d8I?si=dSCDHSrsAO3Siw7d&amp;start=32"
                            title="YouTube video player 3"
                            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                            referrerpolicy="strict-origin-when-cross-origin" allowfullscreen>
                        </iframe>
                    </div>
                    <!-- Add more videos as needed -->
                </div>
            </div>
        </section>

        <!-- T-shirt Products Carousel -->
        <section id="tshirt-products" class="text-center my-5">
            <div class="container tshirt-product">
                <h2 class="title-style">Best Selling</h2>
                <div id="tshirtCarousel" class="carousel slide" data-bs-ride="carousel">
                    <div class="carousel-inner">
                        <div class="carousel-item active">
                            <a
                                href="https://www.kharidlow.com/category/66fe842dc94255633c708a24?category=Men%27s%20Upper%20Wear">
                                <img src="https://res.cloudinary.com/dfx61hywd/image/upload/v1737533574/tshirt-1_oqlsjy.jpg"
                                    class="d-block w-100" alt="Graphic T-shirt">
                            </a>
                        </div>
                        <div class="carousel-item">
                            <a
                                href="https://www.kharidlow.com/category/66fe840cc94255633c708a22?category=Women%27s%20Bottom%20Wear">
                                <img src="https://res.cloudinary.com/dfx61hywd/image/upload/v1736061733/IMG-20250104-WA0005_mvrl5s.jpg"
                                    class="d-block w-100" alt="Plain White T-shirt">
                            </a>
                        </div>
                        <div class="carousel-item">
                            <a
                                href="https://www.kharidlow.com/category/66fe842dc94255633c708a24?category=Men%27s%20Upper%20Wear">
                                <img src="https://res.cloudinary.com/dfx61hywd/image/upload/v1736061734/IMG-20250104-WA0006_loi49d.jpg"
                                    class="d-block w-100" alt="Plain White T-shirt">
                            </a>
                        </div>
                        <div class="carousel-item">
                            <a
                                href="https://www.kharidlow.com/category/66fe842dc94255633c708a24?category=Men%27s%20Upper%20Wear">
                                <img src="https://res.cloudinary.com/dfx61hywd/image/upload/v1737533574/tshirt-2_orjugl.jpg"
                                    class="d-block w-100" alt="Plain White T-shirt">
                            </a>
                        </div>
                        <div class="carousel-item">
                            <a
                                href="https://www.kharidlow.com/category/66fe842dc94255633c708a24?category=Men%27s%20Upper%20Wear">
                                <img src="https://res.cloudinary.com/dfx61hywd/image/upload/v1737533574/tshirt-3_yxnyao.jpg"
                                    class="d-block w-100" alt="Plain White T-shirt">
                            </a>
                        </div>
                    </div>
                    <!-- Carousel Controls -->
                    <button class="carousel-control-prev" type="button" data-bs-target="#tshirtCarousel"
                        data-bs-slide="prev">
                        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#tshirtCarousel"
                        data-bs-slide="next">
                        <span class="carousel-control-next-icon" aria-hidden="true"></span>
                    </button>
                </div>
            </div>
        </section>

        <!-- Featured Products Section -->
        <% if(recentProducts.length> 0) { %>
            <section class="container my-3">
                <h2 class="text-center title-style">Fresh on the Shelves</h2>
                <section class="container recent-products mt-1">
                    <div class="recent-products-container">
                        <div class="row">
                            <% recentProducts.forEach((product)=> { %>
                                <div class="col-6 col-md-4 col-lg-3 mb-3">
                                    <div class="card recent-product-card">
                                        <div class="card-img-container">
                                            <a href="/product/<%= product._id %>"><img src="<%= product.mainImage %>"
                                                    class="recent-card-img" alt="<%= product.productName %>"></a>
                                        </div>
                                        <div class="card-body">
                                            <h5 class="recent-card-title">
                                                <%= product.productName %>
                                            </h5>
                                            <div class="d-flex justify-content-between">
                                                <p class="card-text"><span class="price">Price: </span>&#8377;<%=
                                                        product.price %>
                                                        <p class="card-text">MOQ: <%= product.moq %>
                                            </div>
                                            <button class="btn btn-primary add-to-cart-btn-card"
                                                data-product-id="<%= product._id %>" data-moq="<%= product.moq %>">Add
                                                to Cart</button>
                                        </div>
                                    </div>
                                </div>
                                <% }) %>
                        </div>
                    </div>
                </section>
            </section>
            <% } %>

                <!-- How it works section -->
                <section class="how-it-works text-center my-5">
                    <div class="container">
                        <h2 class="title-style">How It Works</h2>
                        <div class="row how-it-works-row">
                            <div class="col-md-3">
                                <div class="step">
                                    <h3>Step 1</h3>
                                    <p>Browse Products</p>
                                    <p>Explore a wide range of products categorized by your needs.</p>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="step">
                                    <h3>Step 2</h3>
                                    <p>Select Your Quantity</p>
                                    <p>Choose the quantity based on your requirements and the minimum order quantities
                                        (MOQ).</p>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="step">
                                    <h3>Step 3</h3>
                                    <p>Add to Cart</p>
                                    <p>Once you’ve selected your products, simply add them to your cart for easy
                                        checkout.</p>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="step">
                                    <h3>Step 4</h3>
                                    <p>Checkout</p>
                                    <p>Review your order, enter shipping details, and complete your purchase with
                                        entering OTP.</p>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="step">
                                    <h3>Step 5</h3>
                                    <p>Order Confirmation</p>
                                    <p>Once your order is received, our executive will call you to confirm the details,
                                        and we will then dispatch your order promptly.</p>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="step">
                                    <h3>Step 6</h3>
                                    <p>Track Your Order</p>
                                    <p>After placing your order, receive tracking information to monitor your shipment
                                        status.</p>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="step">
                                    <h3>Step 7</h3>
                                    <p>Receive and Review</p>
                                    <p>Once your order arrives, inspect the products and share your feedback with us!
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Under 99 Products Section -->
                <% if(under99Products.length> 0) { %>
                    <div class="under99-scroll text-center">
                        <h2 class="my-2 title-style">Explore Under 99</h2>
                        <div class="under99-card-main">
                            <% under99Products.forEach((product)=> { %>
                                <div class="col-6 col-md-4 col-lg-3 mb-3 under99-product-card">
                                    <div class="card recent-product-card">
                                        <div class="card-img-container">
                                            <a href="/product/<%= product._id %>"><img src="<%= product.mainImage %>"
                                                    class="recent-card-img" alt="<%= product.productName %>"></a>
                                        </div>
                                        <div class="card-body">
                                            <h5 class="recent-card-title">
                                                <%= product.productName %>
                                            </h5>
                                            <div class="d-flex justify-content-between">
                                                <p class="card-text"><span class="price">Price: </span>&#8377;
                                                    <%= product.price %>
                                                        <p class="card-text">MOQ: <%= product.moq %>
                                            </div>
                                            <button class="btn btn-primary add-to-cart-btn-card"
                                                data-product-id="<%= product._id %>" data-moq="<%= product.moq %>">Add
                                                to Cart</button>
                                        </div>
                                    </div>
                                </div>
                                <% }) %>
                                    <div class="col-6 col-md-4 col-lg-3 mb-3 under99-product-card">
                                        <div class="card recent-product-card text-center see-all-products-card">
                                            <div
                                                class="card-body d-flex flex-column justify-content-center align-items-center">
                                                <a href="/product" class="see-all-link">
                                                    <div class="see-all-icon mb-2">
                                                        <!-- Optional: Add an icon to represent 'See All' (e.g., Font Awesome icon) -->
                                                        <i class="fas fa-arrow-right fa-2x"></i>
                                                    </div>
                                                    <h5 class="see-all-text">See All Products</h5>
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                        </div>
                    </div>
                    <% } %>

                        <!-- Join now section -->
                        <section class="cta-section text-white text-center py-5">
                            <div class="container">
                                <h1>Ready to Boost Your Business?</h1>
                                <h5>Sign up now and get exclusive access to B2B deals</h5>
                                <a href="/user/register" class="btn btn-light btn-lg join-now-btn">Join Now</a>
                            </div>
                        </section>

                        <!-- Services Section -->
                        <section id="services" class="bg-light py-5">
                            <div class="container text-center">
                                <h2 class="title-style">Our Services</h2>
                                <p>Direct B2B sourcing with seamless transactions.</p>
                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="service-box p-4">
                                            <h3>Bulk Ordering</h3>
                                            <p>Place orders with Minimum Order Quantities (MOQs) directly</p>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="service-box p-4">
                                            <h3>Free Shipping</h3>
                                            <p>Enjoy free shipping on all orders, ensuring a seamless and cost-effective
                                                shopping experience.</p>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="service-box p-4">
                                            <h3>Pan India Delivery</h3>
                                            <p>We offer reliable delivery across India, no matter where you are located.
                                            </p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </section>

                        <!-- Location Map Section -->
                        <section id="location" class="map-section py-3">
                            <div class="container text-center">
                                <h2 class="title-style">Visit Us at Our Kharidlow Location</h2>
                                <div class="map-container">
                                    <iframe
                                        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3500.8645869112993!2d77.28503897529028!3d28.66377297564777!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x390cfb7b4203613d%3A0x7481a96ff79df021!2sNitvi%20Fashion%20Pvt%20Ltd!5e0!3m2!1sen!2sin!4v1729495998502!5m2!1sen!2sin"
                                        allowfullscreen="" loading="lazy"></iframe>
                                </div>
                            </div>
                        </section>

                        <!-- include footer -->
                        <%- include("includes/footer.ejs") %>

                            <!-- Bootstrap JS -->
                            <script
                                src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
                            <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
                            <script>
                                $('.add-to-cart-btn-card').on('click', function (event) {
                                    event.preventDefault();

                                    const productId = $(this).data('product-id');
                                    const moq = $(this).data('moq');

                                    $.ajax({
                                        url: '/user/cart',
                                        method: 'POST',
                                        contentType: 'application/json',
                                        data: JSON.stringify({ productId: productId, moq: moq }),
                                        success: function (response) {
                                            if (response.success) {
                                                swal("Fantastic!", "Product added to cart successfully!", "success");
                                            } else {
                                                if (response.reason) {
                                                    swal("Oops!", "Please login!", "error").then(() => {
                                                        window.location.href = '/user/login';
                                                    });;
                                                } else {
                                                    swal("Oops!", "Something went wrong!", "error");
                                                }
                                            }
                                        },
                                        error: function (xhr, status, error) {
                                            swal("Oops!", error, "error");
                                        }
                                    });
                                });
                            </script>
</body>

</html>