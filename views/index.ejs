<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KharidLow - B2B Marketplace</title>
    <link rel="icon" type="image/x-icon" href="assets/Kharidlow.ico">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" />
    <link rel="stylesheet" href="/styles/style.css">
    <link rel="stylesheet" href="/styles/navbar.css">
    <link rel="stylesheet" href="/styles/footer.css">
</head>

<body>

    <!-- include navbar -->
    <%- include("includes/navbar.ejs") %>

        <!-- Hero Section -->
        <!-- <section class="hero text-white text-center">
            <div class="container">
                <h1 class="display-4">Welcome to Kharid Low</h1>
                <p class="lead">Your One-Stop B2B Marketplace for Bulk Orders</p>
                <a href="#products" class="btn btn-light btn-lg mt-3">Explore Products</a>
            </div>
        </section> -->

        <!-- Sliding Banner -->
        <div id="bannerCarousel" class="carousel slide" data-bs-ride="carousel">
            <div class="carousel-inner">
                <div class="carousel-item active">
                    <img src="assets/banner1.jpg" class="d-block w-100" alt="Banner 1">
                </div>
                <div class="carousel-item">
                    <img src="assets/banner4.webp" class="d-block w-100" alt="Banner 2">
                </div>
                <div class="carousel-item">
                    <img src="assets/banner3.jpg" class="d-block w-100" alt="Banner 3">
                </div>
                <div class="carousel-item">
                    <img src="assets/banner5.webp" class="d-block w-100" alt="Banner 3">
                </div>
            </div>
            <button class="carousel-control-prev" type="button" data-bs-target="#bannerCarousel" data-bs-slide="prev">
                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#bannerCarousel" data-bs-slide="next">
                <span class="carousel-control-next-icon" aria-hidden="true"></span>
            </button>
        </div>

        <!-- Shop by Category -->
        <div class="category-scroll">
            <div class="row flex-nowrap">
                <div class="category-card">
                    <img src="https://via.placeholder.com/150" class="card-img-top" alt="Category 1">
                    <h5 class="card-title">Top Offers</h5>
                </div>
                <div class="category-card">
                    <img src="https://via.placeholder.com/150" class="card-img-top" alt="Category 2">
                    <h5 class="card-title">Mobiles & Tablets</h5>
                </div>
                <div class="category-card">
                    <img src="https://via.placeholder.com/150" class="card-img-top" alt="Category 3">
                    <h5 class="card-title">TVs & Appliances</h5>
                </div>
                <div class="category-card">
                    <img src="https://via.placeholder.com/150" class="card-img-top" alt="Category 4">
                    <h5 class="card-title">Electronics</h5>
                </div>
                <div class="category-card">
                    <img src="https://via.placeholder.com/150" class="card-img-top" alt="Category 5">
                    <h5 class="card-title">Fashion</h5>
                </div>
                <!-- Add more categories as needed -->
            </div>
        </div>

        <!-- Featured Products Section -->
        <section class="container my-5">
            <h2 class="text-center mb-4">Featured Products</h2>
            <div class="row">
                <div class="col-md-3 mb-4">
                    <div class="card product-card">
                        <img src="https://via.placeholder.com/300x200" class="card-img-top" alt="Product 1">
                        <div class="card-body">
                            <h5 class="card-title">Product 1</h5>
                            <p class="card-text">Price: $100</p>
                            <a href="#" class="btn btn-primary">Add to Cart</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-3 mb-4">
                    <div class="card product-card">
                        <img src="https://via.placeholder.com/300x200" class="card-img-top" alt="Product 2">
                        <div class="card-body">
                            <h5 class="card-title">Product 2</h5>
                            <p class="card-text">Price: $150</p>
                            <a href="#" class="btn btn-primary">Add to Cart</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-3 mb-4">
                    <div class="card product-card">
                        <img src="https://via.placeholder.com/300x200" class="card-img-top" alt="Product 3">
                        <div class="card-body">
                            <h5 class="card-title">Product 3</h5>
                            <p class="card-text">Price: $200</p>
                            <a href="#" class="btn btn-primary">Add to Cart</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-3 mb-4">
                    <div class="card product-card">
                        <img src="https://via.placeholder.com/300x200" class="card-img-top" alt="Product 4">
                        <div class="card-body">
                            <h5 class="card-title">Product 4</h5>
                            <p class="card-text">Price: $250</p>
                            <a href="#" class="btn btn-primary">Add to Cart</a>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Services Section -->
        <section id="services" class="bg-light py-5">
            <div class="container text-center">
                <h2>Our Services</h2>
                <p>Connecting you with suppliers for seamless transactions.</p>
                <div class="row">
                    <div class="col-md-4">
                        <div class="service-box p-4">
                            <h3>Bulk Ordering</h3>
                            <p>Place orders with Minimum Order Quantities (MOQs) directly</p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="service-box p-4">
                            <h3>Wishlist & Cart</h3>
                            <p>Add products to your wishlist and cart for easy future purchases.</p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="service-box p-4">
                            <h3>Order Management</h3>
                            <p>Track your recent orders and manage cancellations efficiently.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- include footer -->
        <%- include("includes/footer.ejs") %>

            <!-- Bootstrap JS -->
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>