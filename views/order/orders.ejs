<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Recent Orders - Kharidlow</title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <link rel="stylesheet" href="/styles/style.css">
    <link rel="stylesheet" href="/styles/navbar.css">
    <link rel="stylesheet" href="/styles/footer.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/1.10.24/css/jquery.dataTables.min.css">
    <style>
        body {
            background-color: #f8f9fa;
        }

        .orders-container {
            padding: 10px;
        }

        .section-title {
            font-size: 24px;
            font-weight: 500;
            margin-bottom: 20px;
        }

        .table th,
        .table td {
            text-align: center;
        }

        @media (max-width: 576px) {
            .table-responsive {
                padding: 0;
                font-size: 0.7rem;
            }

            .section-title {
                font-size: 20px;
                /* Adjust title size for smaller screens */
            }
        }
    </style>
</head>

<body>

    <!-- Include Navbar -->
    <%- include("../partials/navbar.ejs") %>

        <div class="container orders-container my-5">
            <h3 class="section-title">Your Recent Orders</h3>

            <!-- Search Input -->
            <!-- <div class="form-group">
                <input type="text" id="searchInput" class="form-control" placeholder="Search by Order ID or Status"
                    onkeyup="searchOrders()">
            </div> -->

            <div class="table-responsive">
                <% if(orders.length > 0 && orders) {%>
                <table class="table table-bordered table-striped" id="ordersTable">
                    <thead>
                        <tr>
                            <th>Order ID</th>
                            <th>Date</th>
                            <th>Status</th>
                            <th>Total</th>
                            <th>Details</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if(orders.length > 0 && orders) {%>
                            <% orders.forEach(order => { %>
                                <tr>
                                    <td>#<%= order.orderNumber %></td>
                                    <td><%= order.createdAt.toDateString(); %></td>
                                    <td><%= order.status %></td>
                                    <td>&#8377; <%= order.grandTotal %></td>
                                    <td><a href="/order/12345" class="btn btn-primary btn-sm">View</a></td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="5">No Orders</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
                <% } else { %>
                    <div class="alert alert-info text-center" style="font-size: 1rem;" role="alert">
                        No Orders Yet! Browse Our Range of Products! <a href="#" class="alert-link">Shop Now</a>.
                    </div>
                <% } %>
            </div>
        </div>

        <!-- Include Footer -->
        <%- include("../partials/footer.ejs") %>

            <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
            <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.6/dist/umd/popper.min.js"></script>
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
            <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
            <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
            <script src="https://cdn.datatables.net/1.10.24/js/jquery.dataTables.min.js"></script>
            <script>
                $(document).ready(function () {
                    $('#ordersTable').DataTable({
                        // Optional: Customize DataTable settings
                        paging: true,
                        searching: true,
                        ordering: true
                    });
                });
            </script>
</body>

</html>