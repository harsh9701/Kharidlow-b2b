<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Order Summary - Kharidlow</title>
    <link rel="icon" type="image/x-icon" href="/assets/Kharidlow.ico">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" />
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <link rel="stylesheet" href="/styles/navbar.css">
    <link rel="stylesheet" href="/styles/footer.css">
    <link rel="stylesheet" href="/styles/orderSummary.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/sweetalert/2.1.2/sweetalert.min.js"></script>
</head>

<body>

    <!-- include navbar -->
    <%- include("../includes/navbar.ejs") %>

        <div class="container order-summary-container mb-4">
            <h2 class="order-title">Order Summary</h2>

            <!-- Responsive Table Wrapper -->
            <div class="table-responsive">
                <!-- Order Summary Table -->
                <table class="table table-bordered table-striped">
                    <thead>
                        <tr>
                            <th style="display: none;">ProductId</th>
                            <th>Product</th>
                            <th>Product Name</th>
                            <th>Price</th>
                            <th>Tax Rate</th>
                            <th>Tax Type</th>
                            <th>Tax Amount</th>
                            <th>Quantity</th>
                            <th>Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- Product 1 -->
                        <% if(orderItems && cookieValue) { %>
                            <% orderItems.forEach(item=> { %>
                                <tr>
                                    <td data-label="ProductId" class="product-id" style="display: none;">
                                        <%= item.productId %>
                                    </td>
                                    <td data-label="Product"><img src="<%= item.mainImage %>" alt="Product Image"
                                            width="50" height="50"></td>
                                    <td data-label="Product Name">
                                        <%= item.productName %>
                                    </td>
                                    <td data-label="Price">&#8377; <%= item.price %>
                                    </td>
                                    <td data-label="taxRate">
                                        <%= item.taxRate %>
                                    </td>
                                    <td data-label="taxType">
                                        <%= item.taxType.charAt(0).toUpperCase() + item.taxType.slice(1).toLowerCase()
                                            %>
                                    </td>
                                    <td data-label="taxAmount">
                                        <%= item.taxAmount %>
                                    </td>
                                    <td data-label="Quantity">
                                        <%= item.quantity %>
                                    </td>
                                    <td data-label="Total" class="item-total">&#8377; <%= item.total.toFixed(2) %>
                                    </td>
                                    <td data-label="instruction" class="instruction" style="display: none;">
                                        <%= item.instruction %>
                                    </td>
                                </tr>
                                <% }) %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="8" class="text-center" style="font-size: 20px;">No Items</td>
                                        </tr>
                                        <% } %>
                    </tbody>
                </table>
            </div>

            <!-- Total Section -->
            <div class="total-section">
                <div class="d-flex justify-content-between total">
                    <strong>Grand Total</strong>
                    <strong>&#8377; <%= grandTotal ? grandTotal : "0" %></strong>
                </div>
            </div>

            <div class="address-section mt-4">
                <h5>Choose Delivery Address <span style="color: rgb(255, 0, 0);">*</span></h5>
                <select class="form-control" id="existingAddressSelect">
                    <option value="">Select Address</option>
                    <% if (userAddresses && userAddresses.length> 0) { %>
                        <% userAddresses.forEach((address, index)=> { %>
                            <option value="<%= address._id %>">
                                <%= address.flatNo %>, <%= address.streetNo %>, <%= address.area %>
                            </option>
                            <% }) %>
                                <% } %>
                </select>
                <small class="text-muted address-change-text">Select from your saved addresses or <a href="#"
                        id="newAddressLink">Enter a
                        new one</a>.</small>

                <div id="newAddressForm" style="display: none;">
                    <h5 class="mt-3">Enter New Address</h5>
                    <form id="newAddressFormFields">
                        <div class="form-group">
                            <label for="flatNo">Flat, House, Building No.</label>
                            <input type="text" class="form-control" id="flatNo" placeholder="Enter house no">
                        </div>
                        <div class="form-group">
                            <label for="streetNo">Street No</label>
                            <input type="text" class="form-control" id="streetNo" placeholder="Enter street">
                        </div>
                        <div class="form-group">
                            <label for="area">Area/Village/Locality</label>
                            <input type="text" class="form-control" id="area" placeholder="Enter locality">
                        </div>
                        <div class="form-group">
                            <label for="state">State</label>
                            <input type="text" class="form-control" id="state" placeholder="Enter state">
                        </div>
                        <div class="form-group">
                            <label for="pincode">Pincode</label>
                            <input type="number" class="form-control" id="pincode" placeholder="Enter pincode"
                                pattern="[0-9]{6}" title="Enter a valid pincode">
                        </div>
                        <div class="form-group">
                            <label for="company">Company Name (Optional)</label>
                            <input type="text" class="form-control" id="company" placeholder="Enter company name">
                        </div>
                        <div class="form-group">
                            <label for="gstNo">GST No (Optional)</label>
                            <input type="text" class="form-control" id="gstNo" placeholder="Enter GST No">
                        </div>
                        <div class="form-group">
                            <label for="altContact">Alternate Contact No (Optional)</label>
                            <input type="number" class="form-control" id="altContact"
                                placeholder="Enter alternate contact" pattern="[6789][0-9]{9}"
                                title="Enter a valid contact number">
                        </div>
                    </form>
                </div>
            </div>

            <!-- Checkout Button -->
            <button class="btn btn-success checkout-btn">Confirm Order</button>
        </div>

        <!-- include footer -->
        <%- include("../includes/footer.ejs") %>

            <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
            <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.6/dist/umd/popper.min.js"></script>
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
            <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
            <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
            <script>
                $(document).ready(function () {
                    // Initially disable the Confirm Order button
                    $('.checkout-btn').prop('disabled', true);

                    // Function to check if an address is selected or entered
                    function checkIfAddressSelectedOrEntered() {
                        // Check if an existing address is selected
                        const selectedAddress = $('#existingAddressSelect').val();
                        if (selectedAddress && selectedAddress !== "") {
                            return true;
                        }

                        // Check if new address fields are filled (example: flatNo, streetNo, etc.)
                        const flatNo = $('#flatNo').val();
                        const streetNo = $('#streetNo').val();
                        const area = $('#area').val();
                        const state = $('#state').val();
                        const pincode = $('#pincode').val();
                        // const altContact = $('#altContact').val();

                        // Validate new address fields
                        const isPincodeValid = /^\d{6}$/.test(pincode); // Check if pincode is exactly 6 digits
                        const isAltContactValid = /^[6789]\d{9}$/.test(altContact); // Check if alternate contact starts with 6, 7, 8, or 9 and is 10 digits

                        if (flatNo && streetNo && area && state && isPincodeValid) {
                            return true; // Only returns true if all required fields are valid
                        }

                        // If the pincode or alternate contact is invalid, disable the button
                        // if (altContact && !isAltContactValid) {
                        //     return false; // Alternate contact is invalid
                        // }

                        return false;
                    }

                    // Enable button if an existing address is selected
                    $('#existingAddressSelect').on('change', function () {
                        if (checkIfAddressSelectedOrEntered()) {
                            $('.checkout-btn').prop('disabled', false);
                        } else {
                            $('.checkout-btn').prop('disabled', true);
                        }
                    });

                    // Enable button if a new address is entered
                    $('#newAddressForm input').on('input', function () {
                        if (checkIfAddressSelectedOrEntered()) {
                            $('.checkout-btn').prop('disabled', false);
                        } else {
                            $('.checkout-btn').prop('disabled', true);
                        }
                    });

                    // Toggle new address form visibility and clear the existing address selection
                    $('#newAddressLink').on('click', function (e) {
                        e.preventDefault();
                        $('#newAddressForm').toggle(); // Show or hide the new address form

                        // If entering a new address, clear the existing address selection
                        if ($('#newAddressForm').is(':visible')) {
                            $('#existingAddressSelect').val(''); // Clear the existing address dropdown
                            $('#existingAddressSelect').prop('disabled', true);
                            $(this).text('Select Address');
                        } else {
                            $(this).text('Enter a new one');
                            $('#flatNo').val('');
                            $('#streetNo').val('');
                            $('#area').val('');
                            $('#state').val('');
                            $('#pincode').val('');
                            $('#company').val('');
                            $('#gstNo').val('');
                            $('#altContact').val('');
                            $('#existingAddressSelect').prop('disabled', false);
                        }

                        // Reset the form and disable the button if toggled back
                        $('.checkout-btn').prop('disabled', true);
                    });

                    // Random number generator
                    function generateRandomCode() {
                        return Math.floor(100000 + Math.random() * 900000); // Generates a 6-digit random number
                    }

                    let generatedCode;

                    // Reset modal state when it opens
                    $('#confirmationModal').on('show.bs.modal', function () {
                        generatedCode = generateRandomCode();
                        $('#generated-code').text(generatedCode);
                        $('#user-code-input').val(''); // Clear the input field
                        $('#submit-order-btn').prop('disabled', true); // Disable the submit button
                        $('#error-message').hide(); // Hide error message
                    });

                    // Open confirmation modal when user clicks "Proceed to Checkout"
                    $('.checkout-btn').on('click', function (event) {
                        event.preventDefault(); // Prevent default form submission
                        $('#confirmationModal').modal('show'); // Show the confirmation modal
                    });

                    // Check user input and enable submit button
                    $('#user-code-input').on('input', function () {
                        const userCode = $(this).val();
                        if (userCode === generatedCode.toString()) {
                            $('#submit-order-btn').prop('disabled', false);
                            $('#error-message').hide();
                        } else {
                            $('#submit-order-btn').prop('disabled', true);
                            if (userCode.length === 6) { // Only show the error message after full code is entered
                                $('#error-message').show();
                            } else {
                                $('#error-message').hide();
                            }
                        }
                    });

                    // Show loader function
                    function showLoader() {
                        $('#loader').show();
                    }

                    // Hide loader function
                    function hideLoader() {
                        $('#loader').hide();
                    }

                    // Handle order submission
                    $('#submit-order-btn').on('click', function (event) {
                        event.preventDefault(); // Prevent default form submission

                        // Show the loader when the order is being processed
                        showLoader();

                        // Gather order items data (same as your existing code)
                        const orderItems = [];
                        $('tbody tr').each(function () {
                            const productId = $(this).find('.product-id').text().trim();
                            const productName = $(this).find('td:eq(2)').text().trim();
                            const price = parseFloat($(this).find('td:eq(3)').text().replace('₹', '').trim());
                            const taxRate = parseInt($(this).find('td:eq(4)').text().trim());
                            const taxType = $(this).find('td:eq(5)').text().trim();
                            const taxAmount = parseFloat($(this).find('td:eq(6)').text().trim());
                            const quantity = parseInt($(this).find('td:eq(7)').text().trim());
                            const instruction = $(this).find('.instruction').text().trim();
                            const total = parseFloat($(this).find('.item-total').text().replace('₹', '').trim());

                            orderItems.push({
                                productId: productId,
                                productName: productName,
                                instruction: instruction,
                                price: price,
                                taxRate: taxRate,
                                taxType: taxType,
                                taxAmount: taxAmount,
                                quantity: quantity,
                                total: total
                            });
                        });

                        // Check if an existing address is selected
                        const selectedAddressId = $('#existingAddressSelect').val();

                        let addressData = {};
                        if (selectedAddressId && selectedAddressId !== "") {
                            // User selected an existing address
                            addressData = {
                                selectedAddressId: selectedAddressId
                            };
                        } else {
                            // User entered a new address
                            addressData = {
                                flatNo: $('#flatNo').val(),
                                streetNo: $('#streetNo').val(),
                                area: $('#area').val(),
                                state: $('#state').val(),
                                pincode: $('#pincode').val(),
                                company: $('#company').val(),
                                gstNo: $('#gstNo').val(),
                                altContact: $('#altContact').val()
                            };
                        }

                        // Send order and address data to the backend
                        const orderData = {
                            orderItems: orderItems,
                            address: addressData
                        };

                        $.ajax({
                            url: '/user/order',
                            type: 'POST',
                            contentType: 'application/json',
                            data: JSON.stringify(orderData),
                            success: function (response) {
                                hideLoader();
                                swal("🎊 Hooray!", "Your order was completed successfully! Thank you for trusting Kharidlow. Enjoy your shopping! 🛍️", "success", {
                                    html: true
                                }).then(() => {
                                    window.location.href = '/';
                                });
                            },
                            error: function (xhr, status, error) {
                                hideLoader(); // Hide the loader on error
                                console.error('Error placing order:', error);
                                const response = JSON.parse(xhr.responseText);
                                const errorMessage = response.message || "There was an error placing your order. Please try again.";
                                swal("Oops!", errorMessage, "error");
                            }
                        });
                    });
                });

            </script>

            <!-- Confirmation Modal -->
            <div class="modal fade" id="confirmationModal" tabindex="-1" aria-labelledby="confirmationModalLabel"
                aria-hidden="true">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title" id="confirmationModalLabel">Confirm Your Order</h5>
                            <button type="button" class="close" data-bs-dismiss="modal" aria-label="Close">
                                <span aria-hidden="true">&times;</span>
                            </button>
                        </div>
                        <div class="modal-body">
                            <p>Please enter the 6-digit code to confirm your order:</p>
                            <div class="text-center">
                                <strong id="generated-code" class="fs-4"></strong>
                                <!-- Random 6-digit code will display here -->
                            </div>
                            <div class="mt-3">
                                <input type="text" id="user-code-input" class="form-control"
                                    placeholder="Enter the code">
                            </div>
                            <input type="hidden" id="cartData" name="cartData" value="<%= orderItems %>">
                            <small class="text-danger" id="error-message" style="display: none;">Incorrect code! Please
                                try again.</small>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                            <button id="submit-order-btn" type="button" class="btn btn-success" disabled>Complete
                                Order</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Loader (Hidden by default) -->
            <div id="loader"
                style="display:none; position: fixed; left: 0; top: 0; width: 100%; height: 100%; z-index: 1000; background: rgba(255, 255, 255, 0.7); text-align: center; justify-content: center; align-items: center;">
                <div class="spinner-border text-primary" role="status"
                    style="width: 3rem; height: 3rem; margin-top: 20%;">
                    <span class="sr-only">Loading...</span>
                </div>
            </div>

</body>

</html>