<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Order Summary - Kharidlow</title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <link rel="stylesheet" href="/styles/style.css">
    <link rel="stylesheet" href="/styles/navbar.css">
    <link rel="stylesheet" href="/styles/footer.css">
    <link rel="stylesheet" href="/styles/orderSummary.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/sweetalert/2.1.2/sweetalert.min.js"></script>
</head>

<body>

    <!-- include navbar -->
    <%- include("../partials/navbar.ejs") %>

        <div class="container order-summary-container mb-4">
            <h2 class="order-title">Order Summary</h2>

            <!-- Responsive Table Wrapper -->
            <div class="table-responsive">
                <!-- Order Summary Table -->
                <table class="table table-bordered table-striped">
                    <thead>
                        <tr>
                            <th style="display: none;">ProductId</th>
                            <th>Product</th>
                            <th>Product Name</th>
                            <th>Price</th>
                            <th>Quantity</th>
                            <th>Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- Product 1 -->
                        <% if(orderItems) { %>
                            <% orderItems.forEach(item=> { %>
                                <tr>
                                    <td data-label="ProductId" class="product-id" style="display: none;">
                                        <%= item.productId %>
                                    </td>
                                    <td data-label="Product"><img src="/uploads/<%= item.mainImage %>"
                                            alt="Product Image" width="50" height="50"></td>
                                    <td data-label="Product Name">
                                        <%= item.productName %>
                                    </td>
                                    <td data-label="Price">&#8377; <%= item.price %>
                                    </td>
                                    <td data-label="Quantity">
                                        <%= item.quantity %>
                                    </td>
                                    <td data-label="Total" class="item-total">&#8377; <%= item.total %>
                                    </td>
                                </tr>
                                <% }) %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="5" class="text-center" style="font-size: 20px;">No Items</td>
                                        </tr>
                                        <% } %>
                    </tbody>
                </table>
            </div>

            <!-- Total Section -->
            <div class="total-section">
                <div class="d-flex justify-content-between total">
                    <strong>Grand Total</strong>
                    <strong>&#8377; <%= grandTotal ? grandTotal : "0" %></strong>
                </div>
            </div>

            <!-- Checkout Button -->
            <button class="btn btn-success checkout-btn">Confirm Order</button>
        </div>

        <!-- include footer -->
        <%- include("../partials/footer.ejs") %>

            <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
            <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.6/dist/umd/popper.min.js"></script>
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
            <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
            <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
            <script>
                $(document).ready(function () {

                    // Random number generator
                    function generateRandomCode() {
                        return Math.floor(100000 + Math.random() * 900000); // Generates a 6-digit random number
                    }

                    let generatedCode;

                    // Reset modal state when it opens
                    $('#confirmationModal').on('show.bs.modal', function () {
                        generatedCode = generateRandomCode();
                        $('#generated-code').text(generatedCode);
                        $('#user-code-input').val(''); // Clear the input field
                        $('#submit-order-btn').prop('disabled', true); // Disable the submit button
                        $('#error-message').hide(); // Hide error message
                    });

                    // Open confirmation modal when user clicks "Proceed to Checkout"
                    $('.checkout-btn').on('click', function (event) {
                        event.preventDefault(); // Prevent default form submission
                        $('#confirmationModal').modal('show'); // Show the confirmation modal
                    });

                    // Check user input and enable submit button
                    $('#user-code-input').on('input', function () {
                        const userCode = $(this).val();
                        if (userCode === generatedCode.toString()) {
                            $('#submit-order-btn').prop('disabled', false);
                            $('#error-message').hide();
                        } else {
                            $('#submit-order-btn').prop('disabled', true);
                            if (userCode.length === 6) { // Only show the error message after full code is entered
                                $('#error-message').show();
                            } else {
                                $('#error-message').hide();
                            }
                        }
                    });

                    // Handle final order submission using AJAX
                    $('#submit-order-btn').on('click', function () {

                        const orderItems = [];

                        // Gather data from the order summary table
                        $('tbody tr').each(function () {
                            const productId = $(this).find('.product-id').text().trim();
                            const productName = $(this).find('td:eq(2)').text().trim();
                            const price = parseFloat($(this).find('td:eq(3)').text().replace('₹', '').trim());
                            const quantity = parseInt($(this).find('td:eq(4)').text().trim());
                            const total = parseFloat($(this).find('.item-total').text().replace('₹', '').trim());

                            orderItems.push({
                                productId: productId,
                                productName: productName,
                                price: price,
                                quantity: quantity,
                                total: total
                            });
                        });

                        $.ajax({
                            url: '/user/order',
                            type: 'POST',
                            contentType: 'application/json',
                            data: JSON.stringify(orderItems),
                            success: function (response) {
                                swal("🎊 Hooray!", "Your order was completed successfully! Thank you for trusting Kharidlow. Enjoy your shopping! 🛍️", "success", {
                                    html: true
                                }).then(() => {
                                    window.location.href = '/';
                                });
                            },
                            error: function (xhr, status, error) {
                                console.error('Error placing order:', error);
                                const response = JSON.parse(xhr.responseText);
                                const errorMessage = response.message || "There was an error placing your order. Please try again.";
                                swal("Oops!", errorMessage, "error")
                            }
                        });
                    });
                });

            </script>

            <!-- Confirmation Modal -->
            <div class="modal fade" id="confirmationModal" tabindex="-1" aria-labelledby="confirmationModalLabel"
                aria-hidden="true">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title" id="confirmationModalLabel">Confirm Your Order</h5>
                            <button type="button" class="close" data-bs-dismiss="modal" aria-label="Close">
                                <span aria-hidden="true">&times;</span>
                            </button>
                        </div>
                        <div class="modal-body">
                            <p>Please enter the 6-digit code to confirm your order:</p>
                            <div class="text-center">
                                <strong id="generated-code" class="fs-4"></strong>
                                <!-- Random 6-digit code will display here -->
                            </div>
                            <div class="mt-3">
                                <input type="text" id="user-code-input" class="form-control"
                                    placeholder="Enter the code">
                            </div>
                            <input type="hidden" id="cartData" name="cartData" value="<%= orderItems %>">
                            <small class="text-danger" id="error-message" style="display: none;">Incorrect code! Please
                                try again.</small>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                            <button id="submit-order-btn" type="button" class="btn btn-success" disabled>Submit
                                Order</button>
                        </div>
                    </div>
                </div>
            </div>


</body>

</html>